<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>U&I Logistics - Login</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <style>
      :root {
        --ui-navy: #0f2444; /* Màu chủ đạo sâu lắng */
        --ui-bronze: #b89b5e; /* Màu nhấn sang trọng, không chói */
        --ui-bg-light: #f8f9fb; /* Màu nền sạch */
        --text-dark: #1a1a1a;
        --text-muted: #6c757d;
      }

      body,
      html {
        height: 100%;
        font-family: "Montserrat", sans-serif;
        background-color: var(--ui-bg-light);
      }

      .login-container {
        min-height: 100vh;
      }

      /* Cột bên trái - Chứa thông tin thương hiệu */
      .brand-side {
        background-color: var(--ui-navy);
        /* Giả lập hình ảnh logistics bằng gradient tinh tế. 
               Thực tế bạn nên thay bằng ảnh chất lượng cao của cty */
        background-image: linear-gradient(
            135deg,
            rgba(15, 36, 68, 0.9) 0%,
            rgba(15, 36, 68, 0.7) 100%
          ),
          url("https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80");
        background-size: cover;
        background-position: center;
        color: white;
        padding: 4rem;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }

      .brand-logo-text {
        font-weight: 800;
        font-size: 3rem;
        letter-spacing: 2px;
        color: var(--ui-bronze); /* Logo màu đồng */
      }

      .brand-tagline {
        font-weight: 400;
        font-size: 1.2rem;
        opacity: 0.9;
        max-width: 400px;
      }

      /* Cột bên phải - Chứa form */
      .form-side {
        background: white;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem;
      }

      .form-wrapper {
        width: 100%;
        max-width: 400px;
      }

      .login-title {
        color: var(--ui-navy);
        font-weight: 700;
        font-size: 1.75rem;
        margin-bottom: 0.5rem;
      }

      .login-subtitle {
        color: var(--text-muted);
        margin-bottom: 2.5rem;
      }

      .form-label {
        font-weight: 600;
        font-size: 0.85rem;
        color: var(--ui-navy);
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      .form-control {
        padding: 1rem;
        border: 1px solid #e0e0e0;
        border-radius: 0; /* Bo góc vuông vức, mạnh mẽ hơn */
        background-color: var(--ui-bg-light);
        font-weight: 500;
        transition: all 0.3s;
      }

      .form-control:focus {
        background-color: #fff;
        border-color: var(--ui-navy);
        box-shadow: none; /* Loại bỏ shadow mặc định của bootstrap */
        border-left: 4px solid var(--ui-bronze); /* Điểm nhấn khi focus */
      }

      /* Nút bấm chính */
      .btn-premium {
        background-color: var(--ui-navy);
        color: var(--ui-bronze); /* Chữ màu đồng trên nền navy */
        border: 1px solid var(--ui-navy);
        padding: 1rem;
        font-weight: 700;
        border-radius: 0;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
      }

      .btn-premium:hover {
        background-color: var(--ui-bronze);
        color: var(--ui-navy);
        border-color: var(--ui-bronze);
      }

      .error-alert {
        background-color: #fef2f2;
        color: #b91c1c;
        border: none;
        border-left: 4px solid #b91c1c;
        font-size: 0.9rem;
        border-radius: 0;
      }
    </style>
  </head>
  <body>
    <div class="container-fluid p-0">
      <div class="row g-0 login-container">
        <div class="col-lg-6 d-none d-lg-flex brand-side">
          <div>
            <div class="brand-logo-text">U&I</div>
            <p style="letter-spacing: 1px; font-weight: 500">
              LOGISTICS CORPORATION
            </p>
          </div>
          <div>
            <h2 class="fw-bold mb-3">Connecting Global Trade.</h2>
            <p class="brand-tagline">
              Đối tác tin cậy trong mọi giải pháp giao nhận và kho vận.
            </p>
          </div>
          <div class="small opacity-50">
            © 2026 U&I Logistics. Premium Portal.
          </div>
        </div>

        <div class="col-lg-6 form-side">
          <div class="form-wrapper">
            <div class="d-lg-none mb-4 text-center">
              <span class="brand-logo-text fs-2">U&I</span>
            </div>

            <h3 class="login-title">Welcome Back</h3>
            <p class="login-subtitle">
              Vui lòng đăng nhập vào hệ thống quản trị.
            </p>

            <% if (typeof error !== "undefined") { %>
            <div class="alert error-alert py-3 mb-4 d-flex align-items-center">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                fill="currentColor"
                class="bi bi-exclamation-diamond-fill me-2"
                viewBox="0 0 16 16"
              >
                <path
                  d="M9.05.435c-.58-.58-1.52-.58-2.1 0L.435 6.95c-.58.58-.58 1.52 0 2.1l6.515 6.515c.58.58 1.52.58 2.1 0l6.515-6.515c.58-.58.58-1.52 0-2.1L9.05.435zM8 4c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 4.995A.905.905 0 0 1 8 4zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"
                />
              </svg>
              <%= error %>
            </div>
            <% } %>

            <form method="POST" action="/user/login">
              <div class="mb-4">
                <label class="form-label">Tên đăng nhập</label>
                <input
                  name="username"
                  class="form-control"
                  placeholder="Nhập username của bạn"
                  value="admin"
                  required
                />
              </div>

              <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center">
                  <label class="form-label mb-0">Mật khẩu</label>
                  <a
                    href="#"
                    class="small text-decoration-none"
                    style="color: var(--ui-bronze)"
                  >
                    Quên mật khẩu?
                  </a>
                </div>
                <input
                  name="password"
                  type="password"
                  value="admin"
                  class="form-control mt-2"
                  placeholder="••••••••"
                  required
                />
              </div>

              <button class="btn btn-premium w-100 mt-3">
                Đăng nhập hệ thống
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
