<ul class="nav flex-column pt-3">
  <li class="nav-item">
    <a
      href="/dashboard/menus"
      class="nav-link <%= !currentMenuId ? 'fw-bold active' : '' %>"
    >
      Home
    </a>
  </li>

  <% /* True EJS recursion for tree menu, no stack */ %> <% function
  getChildren(parentId) { return menus.filter(function(m) { return (m.parentId ?
  m.parentId.toString() : null) === (parentId ? parentId.toString() : null); });
  } %> <% function renderTree(parentId, level) { var children =
  getChildren(parentId); children.forEach(function(menu) { %>
  <li class="nav-item" style="padding-left: <%= level * 16 %>px">
    <a
      href="/groups/<%= menu._id %>"
      class="nav-link <%= currentMenuId === menu._id.toString() ? 'fw-bold active' : '' %>"
    >
      <%= menu.title.en %>
    </a>
    <% if (getChildren(menu._id).length) { %>
    <ul class="nav flex-column ms-2">
      <% renderTree(menu._id, level + 1); %>
    </ul>
    <% } %>
  </li>
  <% }); } %> <% renderTree(null, 0); %>
</ul>
