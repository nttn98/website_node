    </div>
  </div>

  <div id="menuEmptyState" class="menu-empty-state">No matching menu item.</div>

  <% function getChildren(parentId) { return menus.filter(function(m) {
  return (m.parentId ? m.parentId.toString() : null) === (parentId ?
  parentId.toString() : null); }).sort(function(a, b) {
  var aTime = Date.parse(a && a.createdAt) || 0;
  var bTime = Date.parse(b && b.createdAt) || 0;
  if (bTime !== aTime) return bTime - aTime;
  return (a.order || 0) - (b.order || 0);
  }); } %>

  <% var INSIGHTS_PARENT_ID = '698191a46ea27a5d8ccbf724'; %>
  <% var menuById = {}; menus.forEach(function(m) { menuById[m._id.toString()] = m; }); %>

  <% function getMenuTitle(menu) {
      return (menu.title && menu.title.en) ? menu.title.en : 'Untitled';
    }
  %>

  <% function isInActivePath(menu) {
      if (!currentMenuId || !menu) return false;
      if (menu._id.toString() === currentMenuId) return true;

      var cursor = menuById[currentMenuId] || null;
      while (cursor && cursor.parentId) {
        if (cursor.parentId.toString() === menu._id.toString()) return true;
        cursor = menuById[cursor.parentId.toString()] || null;
      }
      return false;
    }
  %>

  <% function hasActiveMenuInList(items) {
      return items.some(function(item) {
        return isInActivePath(item);
      });
    }
  %>

  <% function renderMenuNode(menu, level, isChild) { var menuId = menu._id.toString(); var menuTitle = getMenuTitle(menu); var hasKids = getChildren(menu._id).length > 0; var shouldOpen = hasKids && isInActivePath(menu); %>
  <li class="nav-item menu-node" data-menu-title="<%= menuTitle.toLowerCase() %>">
    <div class="d-flex align-items-center menu-node-row <%= isChild ? 'nav-child-item' : '' %>" <%= isChild ? 'data-nav-level="' + level + '"' : '' %>>
      <% if (isChild) { %>
      <span class="indent-marker">></span>
      <% } %>
      <a
        href="/dashboard/groups?menuId=<%= menuId %>"
        class="nav-link <%= currentMenuId === menuId ? 'active fw-bold' : '' %> nav-parent-text flex-grow-1"
        title="<%= menuTitle %>"
      >
        <span class="menu-item-text"><%= menuTitle %></span>
      </a>
      <% if (hasKids) { %>
      <button class="toggle-btn <%= shouldOpen ? 'open' : '' %>" data-target="children-<%= menuId %>" type="button" title="Expand/Collapse" aria-expanded="<%= shouldOpen ? 'true' : 'false' %>">
        <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
          <path d="M8.5 6.5a.5.5 0 0 0-.707 0l-3 3a.5.5 0 0 0 .707.707L8 7.207l2.646 2.647a.5.5 0 0 0 .707-.707l-3-3z"/>
        </svg>
      </button>
      <% } else { %>
      <span style="width: 20px;"></span>
      <% } %>
    </div>
    <% if (hasKids) { %>
    <ul
      class="nav flex-column ms-2 children-list <%= shouldOpen ? '' : 'd-none' %>"
      id="children-<%= menuId %>"
    >
      <% renderTree(menu._id, level + 1, true); %>
    </ul>
    <% } %>
  </li>
  <% } %>

  <% function renderInsightsBranch(label, branchKey, items, level) { if (!items.length) return; var shouldOpen = hasActiveMenuInList(items); %>
  <li class="nav-item menu-node menu-branch-node" data-menu-title="<%= ('insights ' + label).toLowerCase() %>" data-branch-key="<%= branchKey %>">
    <div class="d-flex align-items-center menu-node-row nav-child-item menu-branch-row" data-nav-level="<%= level %>">
      <span class="indent-marker branch-indent">+</span>
      <div class="nav-link nav-parent-text nav-branch-label flex-grow-1">
        <div class="branch-content">
          <span class="branch-copy">
            <span class="branch-title"><%= label %> </span>
          </span>
          <span class="branch-count" data-branch-count="<%= branchKey %>"><%= items.length %></span>
        </div>
      </div>
      <button class="toggle-btn <%= shouldOpen ? 'open' : '' %>" data-target="children-<%= branchKey %>" type="button" title="Expand/Collapse" aria-expanded="<%= shouldOpen ? 'true' : 'false' %>">
        <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
          <path d="M8.5 6.5a.5.5 0 0 0-.707 0l-3 3a.5.5 0 0 0 .707.707L8 7.207l2.646 2.647a.5.5 0 0 0 .707-.707l-3-3z"/>
        </svg>
      </button>
    </div>
    <ul
      class="nav flex-column ms-2 children-list <%= shouldOpen ? '' : 'd-none' %>"
      id="children-<%= branchKey %>"
    >
      <% items.forEach(function(menu) { %>
      <% renderMenuNode(menu, level + 1, true); %>
      <% }); %>
    </ul>
  </li>
  <% } %>

  <% function renderTree(parentId, level, isChild) { var normalizedParentId = parentId ? parentId.toString() : null; if (normalizedParentId === INSIGHTS_PARENT_ID) { var insightChildren = getChildren(parentId); var caseStudyChildren = insightChildren.filter(function(menu) { return menu.caseStudies; }); var featuredChildren = insightChildren.filter(function(menu) { return menu.featuredInsights; }); var regularChildren = insightChildren.filter(function(menu) { return !menu.caseStudies && !menu.featuredInsights; }); %>
  <% renderInsightsBranch('Case Studies', 'insights-case-studies', caseStudyChildren, level); %>
  <% renderInsightsBranch('Featured Insights', 'insights-featured-insights', featuredChildren, level); %>
  <% regularChildren.forEach(function(menu) { %>
  <% renderMenuNode(menu, level, true); %>
  <% }); %>
  <% return; } var children = getChildren(parentId); children.forEach(function(menu) { %>
  <% renderMenuNode(menu, level, isChild); %>
  <% }); } %>

  <!-- TOP MENUS -->
  <% var topMenus = menus.filter(function(m) { return !m.parentId && m.type === 'top'; }).sort(function(a, b) { return (a.order || 0) - (b.order || 0); }); %>
  <div class="menu-section-label">TOP MENUS</div>
  <% topMenus.forEach(function(menu) { %>
  <% var menuId = menu._id.toString(); var menuTitle = (menu.title && menu.title.en) ? menu.title.en : 'Untitled'; var hasKids = getChildren(menu._id).length > 0; var shouldOpen = hasKids && isInActivePath(menu); %>
  <li class="nav-item menu-node" data-menu-title="<%= menuTitle.toLowerCase() %>">
    <div class="d-flex align-items-center menu-node-row">
      <a
        href="/dashboard/groups?menuId=<%= menuId %>"
        class="nav-link <%= currentMenuId === menuId ? 'active fw-bold' : '' %> nav-parent-text flex-grow-1"
        title="<%= menuTitle %>"
      >
        <span class="menu-item-text"><%= menuTitle %></span>
      </a>
      <% if (hasKids) { %>
      <button class="toggle-btn <%= shouldOpen ? 'open' : '' %>" data-target="children-<%= menuId %>" type="button" title="Expand/Collapse" aria-expanded="<%= shouldOpen ? 'true' : 'false' %>">
        <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
          <path d="M8.5 6.5a.5.5 0 0 0-.707 0l-3 3a.5.5 0 0 0 .707.707L8 7.207l2.646 2.647a.5.5 0 0 0 .707-.707l-3-3z"/>
        </svg>
      </button>
      <% } else { %>
      <span style="width: 20px;"></span>
      <% } %>
    </div>
    <% if (hasKids) { %>
    <ul
      class="nav flex-column ms-2 children-list <%= shouldOpen ? '' : 'd-none' %>"
      id="children-<%= menuId %>"
    >
      <% renderTree(menu._id, 1, true); %>
    </ul>
    <% } %>
  </li>
  <% }); %>

  <!-- FOOTER MENUS -->
  <% var footerMenus = menus.filter(function(m) { return !m.parentId && m.type === 'bot'; }).sort(function(a, b) { return (a.order || 0) - (b.order || 0); }); %>
  <% if (footerMenus.length) { %>
  <div class="menu-section-label">FOOTER MENUS</div>
  <% footerMenus.forEach(function(menu) { %>
  <% var menuId = menu._id.toString(); var menuTitle = (menu.title && menu.title.en) ? menu.title.en : 'Untitled'; var hasKids = getChildren(menu._id).length > 0; var shouldOpen = hasKids && isInActivePath(menu); %>
  <li class="nav-item menu-node" data-menu-title="<%= menuTitle.toLowerCase() %>">
    <div class="d-flex align-items-center menu-node-row">
      <a
        href="/dashboard/groups?menuId=<%= menuId %>"
        class="nav-link <%= currentMenuId === menuId ? 'active fw-bold' : '' %> nav-parent-text flex-grow-1"
        title="<%= menuTitle %>"
      >
        <span class="menu-item-text"><%= menuTitle %></span>
      </a>
      <% if (hasKids) { %>
      <button class="toggle-btn <%= shouldOpen ? 'open' : '' %>" data-target="children-<%= menuId %>" type="button" title="Expand/Collapse" aria-expanded="<%= shouldOpen ? 'true' : 'false' %>">
        <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
          <path d="M8.5 6.5a.5.5 0 0 0-.707 0l-3 3a.5.5 0 0 0 .707.707L8 7.207l2.646 2.647a.5.5 0 0 0 .707-.707l-3-3z"/>
        </svg>
      </button>
      <% } else { %>
      <span style="width: 20px;"></span>
      <% } %>
    </div>
    <% if (hasKids) { %>
    <ul
      class="nav flex-column ms-2 children-list <%= shouldOpen ? '' : 'd-none' %>"
      id="children-<%= menuId %>"
    >
      <% renderTree(menu._id, 1, true); %>
    </ul>
    <% } %>
  </li>
  <% }); %>
  <% } %>

  <div class="menu-divider">SETTING</div>

  <li class="nav-item">
    <a
      href="/dashboard/groups"
      class="nav-link <%= locals.currentPage === 'groups' ? 'active fw-bold' : '' %>"
    >
