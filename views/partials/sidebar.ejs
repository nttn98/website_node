<style>
  :root {
    --ui-navy: #0f2444;
    --ui-bronze: #b89b5e;
    --ui-bronze-soft: rgba(184, 155, 94, 0.2);
  }

  /* Menu section labels */
  .menu-section-label {
    font-size: 0.65rem;
    font-weight: 800;
    color: rgba(184, 155, 94, 0.7);
    letter-spacing: 1.2px;
    text-transform: uppercase;
    margin-top: 20px;
    margin-bottom: 12px;
    padding: 0 16px;
    display: block;
  }

  /* Controls for long trees */
  .menu-tools {
    padding: 0 16px 14px;
  }
  .menu-tools .menu-search-wrap {
    position: relative;
  }
  .menu-tools .menu-search-wrap i {
    position: absolute;
    top: 50%;
    left: 10px;
    transform: translateY(-50%);
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.75rem;
  }
  .menu-search-input {
    width: 100%;
    height: 34px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.04);
    color: #fff;
    border-radius: 7px;
    font-size: 0.82rem;
    padding: 0 12px 0 30px;
    outline: none;
  }
  .menu-search-input::placeholder {
    color: rgba(255, 255, 255, 0.45);
  }
  .menu-search-input:focus {
    border-color: var(--ui-bronze);
    box-shadow: 0 0 0 2px var(--ui-bronze-soft);
  }
  .menu-tools-footer {
    margin-top: 10px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .menu-action-btn {
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: transparent;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    border-radius: 6px;
    padding: 5px 9px;
    transition: 0.2s ease;
  }
  .menu-action-btn:hover {
    border-color: var(--ui-bronze);
    color: var(--ui-bronze);
    background: rgba(184, 155, 94, 0.08);
  }
  .menu-count-hint {
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.72rem;
  }
  .menu-empty-state {
    display: none;
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.82rem;
    padding: 4px 16px 8px;
  }

  /* Toggle button styling */
  .toggle-btn {
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 3px;
    background: transparent;
    color: var(--ui-bronze);
    transition: all 0.2s ease;
    font-size: 12px;
    padding: 0;
    border: none;
    flex-shrink: 0;
  }
  .toggle-btn:hover {
    background: rgba(184, 155, 94, 0.15);
    color: var(--ui-bronze);
  }
  .toggle-btn.open {
    transform: rotate(90deg);
  }

  /* Child menu styling */
  .menu-node-row {
    min-height: 34px;
    gap: 6px;
  }
  .nav-child-item {
    display: flex;
    align-items: center;
    padding-left: 14px;
    font-size: 0.88rem;
  }
  .nav-child-item[data-nav-level="1"] {
    padding-left: 22px;
  }
  .nav-child-item[data-nav-level="2"] {
    padding-left: 30px;
  }
  .nav-child-item[data-nav-level="3"] {
    padding-left: 38px;
  }
  .nav-child-item[data-nav-level="4"] {
    padding-left: 46px;
  }

  /* Indent marker */
  .indent-marker {
    color: rgba(184, 155, 94, 0.48);
    font-size: 0.62rem;
    width: 10px;
    text-align: center;
    flex-shrink: 0;
  }

  /* Parent menu styling */
  .nav-parent-text {
    flex-grow: 1;
    font-weight: 500;
    min-width: 0;
    display: flex;
    align-items: center;
    padding-top: 7px !important;
    padding-bottom: 7px !important;
  }
  .nav-parent-text.active {
    font-weight: 700;
    color: var(--ui-bronze);
  }
  .menu-item-text {
    display: -webkit-box;
    line-clamp: 2;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    white-space: normal;
    line-height: 1.25;
  }

  /* Children list */
  .children-list {
    transition: all 0.3s ease;
    border-left: 1px dashed rgba(184, 155, 94, 0.22);
    margin-left: 14px !important;
    padding-left: 2px;
  }
  .children-list.d-none {
    display: none !important;
  }

  .menu-node[data-hidden="true"] {
    display: none;
  }

  .sidebar-wrapper .nav-link {
    padding-right: 6px !important;
  }

  .menu-branch-node {
    margin-top: 2px;
  }

  .menu-branch-row {
    gap: 8px;
  }

  .nav-branch-label {
    min-height: 36px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.03);
    padding: 6px 10px;
    justify-content: space-between;
    gap: 10px;
  }

  .branch-count {
    font-size: 0.65rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.74);
    background: rgba(255, 255, 255, 0.06);
    border-radius: 999px;
    padding: 2px 7px;
    flex-shrink: 0;
  }

  .branch-indent {
    color: rgba(184, 155, 94, 0.62);
    font-size: 0.72rem;
  }

  .branch-content {
    min-width: 0;
    display: flex;
    align-items: center;
  }

  .branch-copy {
    min-width: 0;
    display: flex;
    align-items: center;
  }

  .branch-title {
    color: rgba(255, 255, 255, 0.88);
    font-size: 0.8rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .menu-branch-node .toggle-btn {
    width: 24px;
    height: 24px;
    border-radius: 6px;
    background: transparent;
    border: none;
  }

  .menu-branch-node .toggle-btn:hover {
    background: rgba(184, 155, 94, 0.12);
  }

  .menu-branch-node .children-list {
    margin-top: 2px;
  }

  .menu-branch-node .nav-child-item[data-nav-level="2"] {
    padding-left: 34px;
  }
</style>

<ul class="nav flex-column pt-3">
