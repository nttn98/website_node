</ul>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const toggleButtons = document.querySelectorAll(".toggle-btn");
    const menuNodes = document.querySelectorAll(".menu-node");
    const searchInput = document.getElementById("menuSearchInput");
    const collapseAllBtn = document.getElementById("collapseAllMenus");
    const menuMatchCount = document.getElementById("menuMatchCount");
    const menuEmptyState = document.getElementById("menuEmptyState");

    function closeBranch(rootUl) {
      if (!rootUl) return;
      rootUl.classList.add("d-none");
      const ownerButton = document.querySelector(
        '.toggle-btn[data-target="' + rootUl.id + '"]'
      );
      if (ownerButton) {
        ownerButton.classList.remove("open");
        ownerButton.setAttribute("aria-expanded", "false");
      }
      localStorage.setItem(rootUl.id, "closed");

      rootUl.querySelectorAll(".children-list").forEach((childUl) => {
        childUl.classList.add("d-none");
        localStorage.setItem(childUl.id, "closed");
      });

      rootUl.querySelectorAll(".toggle-btn").forEach((childBtn) => {
        childBtn.classList.remove("open");
        childBtn.setAttribute("aria-expanded", "false");
      });
    }

    function closeSiblings(targetUl) {
      const ownerNode = targetUl.closest("li.menu-node");
      if (!ownerNode || !ownerNode.parentElement) return;
      const siblingLists = ownerNode.parentElement.querySelectorAll(
        ":scope > li.menu-node > ul.children-list"
      );
      siblingLists.forEach((listEl) => {
        if (listEl.id !== targetUl.id) {
          closeBranch(listEl);
        }
      });
    }

    function updateMatchLabel(visibleCount, keyword) {
      if (!keyword) {
        menuMatchCount.textContent = "";
        return;
      }
      menuMatchCount.textContent = visibleCount + " match" + (visibleCount > 1 ? "es" : "");
    }

    function showAncestorPath(node) {
      let cursor = node;
      while (cursor) {
        cursor.dataset.hidden = "false";

        const parentList = cursor.parentElement.closest("ul.children-list");
        if (!parentList) break;

        parentList.classList.remove("d-none");
        const ownerButton = document.querySelector(
          '.toggle-btn[data-target="' + parentList.id + '"]'
        );
        if (ownerButton) {
          ownerButton.classList.add("open");
          ownerButton.setAttribute("aria-expanded", "true");
        }

        cursor = parentList.closest("li.menu-node");
      }
    }

    function applyFilter(keyword) {
      const normalized = (keyword || "").trim().toLowerCase();

      if (!normalized) {
        menuNodes.forEach((node) => {
          node.dataset.hidden = "false";
        });
        updateMatchLabel(0, "");
        menuEmptyState.style.display = "none";
        return;
      }

      let matchCount = 0;
      menuNodes.forEach((node) => {
        const title = node.dataset.menuTitle || "";
        const isMatch = title.includes(normalized);
        node.dataset.hidden = isMatch ? "false" : "true";
        if (isMatch) {
          matchCount += 1;
        }
      });

      if (matchCount > 0) {
        menuNodes.forEach((node) => {
          if (node.dataset.hidden === "false") {
            showAncestorPath(node);
          }
        });
      }

      updateMatchLabel(matchCount, normalized);
      menuEmptyState.style.display = matchCount === 0 ? "block" : "none";
    }

    // Restore toggle states from localStorage while preserving default active path.
    toggleButtons.forEach((btn) => {
      const targetId = btn.getAttribute("data-target");
      const targetUl = document.getElementById(targetId);
      if (!targetUl) return;

      const savedState = localStorage.getItem(targetId);
      if (savedState === "open") {
        targetUl.classList.remove("d-none");
      }
      if (savedState === "closed") {
        targetUl.classList.add("d-none");
      }

      const isOpen = !targetUl.classList.contains("d-none");
      btn.classList.toggle("open", isOpen);
      btn.setAttribute("aria-expanded", isOpen ? "true" : "false");
    });

    toggleButtons.forEach((btn) => {
      btn.addEventListener("click", function (e) {
        e.preventDefault();
        const targetId = this.getAttribute("data-target");
        const targetUl = document.getElementById(targetId);
        if (!targetUl) return;

        const willOpen = targetUl.classList.contains("d-none");
        if (willOpen) {
          closeSiblings(targetUl);
          targetUl.classList.remove("d-none");
          this.classList.add("open");
          this.setAttribute("aria-expanded", "true");
          localStorage.setItem(targetId, "open");
        } else {
          closeBranch(targetUl);
        }
      });
    });

    if (collapseAllBtn) {
      collapseAllBtn.addEventListener("click", function () {
        document.querySelectorAll(".children-list").forEach((listEl) => {
          listEl.classList.add("d-none");
          localStorage.setItem(listEl.id, "closed");
        });
        toggleButtons.forEach((btn) => {
          btn.classList.remove("open");
          btn.setAttribute("aria-expanded", "false");
        });
      });
    }

    if (searchInput) {
      searchInput.addEventListener("input", function () {
        applyFilter(this.value);
      });
    }
  });
</script>
