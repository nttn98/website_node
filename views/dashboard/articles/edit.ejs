<h4>Edit Article</h4>
<form method="POST" action="/articles/<%= article._id %>/update">
  <!-- DETAIL (READONLY) -->
  <input type="hidden" name="parentId" value="<%= article.parentId %>" />
  <div class="mb-3">
    <label class="form-label">Detail</label>
    <input type="text" class="form-control" value="<%= article.parentName %>" readonly />
  </div>
  <!-- MENU (READONLY) -->
  <input type="hidden" name="subParentId" value="<%= article.subParentId %>" />
  <div class="mb-3">
    <label class="form-label">Menu</label>
    <input type="text" class="form-control" value="<%= article.subParentName %>" readonly />
  </div>
  <!-- TYPE -->
  <div class="mb-3">
    <label class="form-label">Type</label>
    <select name="type" id="typeSelect" class="form-select" required>
      <option value="html" <%= article.type === 'html' ? 'selected' : '' %>>HTML Block</option>
      <option value="editor" <%= article.type === 'editor' ? 'selected' : '' %>>Text Editor</option>
    </select>
  </div>
  <!-- LANGUAGE TABS -->
  <ul class="nav nav-tabs mb-3" role="tablist">
    <li class="nav-item">
      <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-en" type="button">EN</button>
    </li>
    <li class="nav-item">
      <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-vi" type="button">VI</button>
    </li>
    <li class="nav-item">
      <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-zh" type="button">ZH</button>
    </li>
  </ul>
  <div class="tab-content">
    <!-- EN -->
    <div class="tab-pane fade show active" id="tab-en">
      <input class="form-control mb-2" name="title_en" value="<%= article.title?.en || '' %>" placeholder="Title EN">
      <input class="form-control mb-3" name="subtitle_en" value="<%= article.subtitle?.en || '' %>" placeholder="Subtitle EN">
    </div>
    <!-- VI -->
    <div class="tab-pane fade" id="tab-vi">
      <input class="form-control mb-2" name="title_vi" value="<%= article.title?.vi || '' %>" placeholder="Title VI">
      <input class="form-control mb-3" name="subtitle_vi" value="<%= article.subtitle?.vi || '' %>" placeholder="Subtitle VI">
    </div>
    <!-- ZH -->
    <div class="tab-pane fade" id="tab-zh">
      <input class="form-control mb-2" name="title_zh" value="<%= article.title?.zh || '' %>" placeholder="Title ZH">
      <input class="form-control mb-3" name="subtitle_zh" value="<%= article.subtitle?.zh || '' %>" placeholder="Subtitle ZH">
    </div>
  </div>
  <!-- HTML -->
  <div id="htmlBlock" class="<%= article.type === 'html' ? '' : 'd-none' %>">
    <textarea name="content" class="form-control font-monospace" rows="8"><%= article.content || '' %></textarea>
  </div>
  <!-- EDITOR -->
  <div id="editorBlock" class="<%= article.type === 'editor' ? '' : 'd-none' %>">
    <textarea id="editor"><%= article.content || '' %></textarea>
  </div>
  <button class="btn btn-success mt-3">Update</button>
</form>
<script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js"></script>
<script>
  const typeSelect = document.getElementById("typeSelect");
  const htmlBlock = document.getElementById("htmlBlock");
  const editorBlock = document.getElementById("editorBlock");
  let editor;
  function toggleType(type) {
    htmlBlock.classList.toggle("d-none", type === "editor");
    editorBlock.classList.toggle("d-none", type === "html");
    if (type === "editor" && !editor) {
      ClassicEditor.create(document.getElementById("editor")).then(e => {
        editor = e;
        editor.model.document.on("change:data", () => {
          document.querySelector('[name="content"]').value = editor.getData();
        });
      });
    }
  }
  toggleType(typeSelect.value);
  typeSelect.addEventListener("change", e => toggleType(e.target.value));
</script>
