<h4>Articles</h4>
<a href="/articles/create" class="btn btn-primary mb-3">+ Create Article</a>
<% if (!articles || articles.length === 0) { %>
<div class="text-center py-5 border rounded bg-light">
  <h5>No article yet</h5>
</div>
<% } else { %>
<div class="row g-3">
  <% articles.forEach(article => { %>
  <div class="col-md-6 col-lg-4">
    <div class="card shadow-sm h-100 border-0 article-card">
      <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-2">
          <h5 class="mb-0"><%= article.title?.en || 'Article' %></h5>
          <span class="badge bg-info">Type: <%= article.type %></span>
        </div>
        <% if (article.subtitle?.en) { %>
        <p class="text-muted small mb-2"><%= article.subtitle.en %></p>
        <% } %>
        <div class="mb-2">
          <span
            class="badge <%= article.isStatus ? 'bg-success' : 'bg-secondary' %>"
          >
            <%= article.isStatus ? 'Active' : 'Inactive' %>
          </span>
        </div>
        <div class="mb-2">
          <span class="badge bg-secondary">
            Detail: <%= article.parentName %>
          </span>
          <span class="badge bg-warning ms-2">
            Menu: <%= article.subParentName %>
          </span>
        </div>
        <div class="article-content mb-2" style="min-height: 40px">
          <%- article.content || '' %>
        </div>
        <div class="d-flex gap-2 flex-wrap">
          <form
            method="POST"
            action="/articles/<%= article._id %>/toggle"
            style="display: inline"
          >
            <button class="btn btn-sm btn-outline-warning" type="submit">
              <%= article.isStatus ? 'Deactivate' : 'Activate' %>
            </button>
          </form>
          <a
            href="/articles/<%= article._id %>/edit"
            class="btn btn-sm btn-outline-primary"
          >
            Edit
          </a>
          <form
            method="POST"
            action="/articles/<%= article._id %>?_method=DELETE"
            style="display: inline"
            onsubmit="return confirm('Are you sure to delete?')"
          >
            <button class="btn btn-sm btn-outline-danger" type="submit">
              Delete
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
  <% }) %>
</div>
<style>
  .article-card:hover {
    box-shadow: 0 0 0 2px #17a2b8, 0 2px 8px rgba(0, 0, 0, 0.08);
    border-color: #17a2b8;
    transition: box-shadow 0.2s;
  }
  .article-content {
    font-size: 0.97em;
    color: #333;
  }
</style>
<% } %>
