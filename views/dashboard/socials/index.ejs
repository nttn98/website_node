<link rel="stylesheet" href="/css/socials/edit.css" />

<div class="d-flex justify-content-between align-items-end mb-4">
  <div>
    <h4 class="fw-800 mb-1" style="color: var(--ui-navy); letter-spacing: -1px">
      SOCIALS
    </h4>
    <div class="d-flex align-items-center gap-2">
      <p class="small text-muted mb-0">Social icons shown on the homepage</p>
    </div>
  </div>

  <button id="add-item-btn" class="btn-ui-main">
    <span class="plus-symbol">+</span>
    ADD ITEM
  </button>
</div>

<div id="social-list" class="table-container-minimal"></div>

<!-- Icon Picker Modal -->
<div id="icon-picker-modal" class="icon-picker-overlay" style="display: none">
  <div class="icon-picker-container">
    <div class="icon-picker-header">
      <h5>Select Icon</h5>
      <button class="icon-picker-close" onclick="closeIconPicker()">✕</button>
    </div>
    <div class="icon-picker-search">
      <input type="text" id="icon-search" placeholder="Search icons..." />
    </div>
    <div class="icon-picker-grid" id="icon-picker-grid"></div>
  </div>
</div>

<script src="/js/socials.index.js"></script>
