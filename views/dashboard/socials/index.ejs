<link rel="stylesheet" href="/css/socials/edit.css" />

<div class="d-flex justify-content-between align-items-end mb-4">
  <div>
    <h4 class="fw-800 mb-1" style="color: var(--ui-navy); letter-spacing: -1px">
      SOCIALS
    </h4>
    <div class="d-flex align-items-center gap-2">
      <p class="small text-muted mb-0">Social icons shown on the homepage</p>
    </div>
  </div>

  <button id="add-item-btn" class="btn-ui-main">
    <span class="plus-symbol">+</span>
    ADD ITEM
  </button>
</div>

<div class="d-flex justify-content-between align-items-end gap-3 mb-3">
  <div
    class="search-wrap flex-grow-1"
    style="max-width: 340px; position: relative"
  >
    <i
      class="bi bi-search"
      style="
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #999;
        font-size: 0.9rem;
      "
    ></i>
    <input
      id="socialSearchInput"
      type="search"
      placeholder="Search by name..."
      class="search-input"
      style="
        width: 100%;
        padding: 10px 16px 10px 36px;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-size: 0.9rem;
        outline: none;
      "
    />
  </div>
  <div class="limit-wrap d-flex align-items-center gap-2">
    <label
      for="socialPageLimitSelect"
      style="font-size: 0.85rem; color: #666; margin: 0"
    >
      Show:
    </label>
    <select
      id="socialPageLimitSelect"
      class="form-select-minimal"
      style="
        padding: 8px 12px;
        border: 1px solid #ddd;
        border-radius: 6px;
        font-size: 0.9rem;
        outline: none;
      "
    >
      <option value="10">10</option>
      <option value="25" selected>25</option>
      <option value="50">50</option>
      <option value="100">100</option>
    </select>
  </div>
</div>

<div id="social-list" class="table-container-minimal"></div>

<div
  id="social-pagination-controls"
  class="pagination-controls mt-4"
  style="display: none; text-align: center"
></div>

<!-- Icon Picker Modal -->
<div id="icon-picker-modal" class="icon-picker-overlay" style="display: none">
  <div class="icon-picker-container">
    <div class="icon-picker-header">
      <h5>Select Icon</h5>
      <button class="icon-picker-close" onclick="closeIconPicker()">✕</button>
    </div>
    <div class="icon-picker-search">
      <input type="text" id="icon-search" placeholder="Search icons..." />
    </div>
    <div class="icon-picker-grid" id="icon-picker-grid"></div>
  </div>
</div>

<script src="/js/socials.index.js"></script>
