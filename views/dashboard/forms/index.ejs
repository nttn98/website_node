<link rel="stylesheet" href="/css/buttons/index.css" />
<link rel="stylesheet" href="/css/form-modal.css" />

<div class="d-flex justify-content-between align-items-end mb-4">
  <div>
    <h4 class="fw-800 mb-1" style="color: var(--ui-navy); letter-spacing: -1px">
      FORM
    </h4>
    <div class="d-flex align-items-center gap-2">
      <p class="small text-muted mb-0">Manage site forms</p>
    </div>
  </div>

  <a href="/dashboard/forms/create" class="btn-ui-main">
    <span class="plus-symbol">+</span>
    ADD FORM
  </a>
</div>

<div class="table-container-minimal">
  <table class="table-clean">
    <thead>
      <tr>
        <th>Title</th>
        <th>Fields</th>
        <th>Route</th>
        <th class="text-center">Status</th>
        <th class="text-end"></th>
      </tr>
    </thead>
    <tbody id="form-list-body"></tbody>
  </table>
</div>

<!-- form renderer (preview modal) -->
<script src="/js/form.renderer.js"></script>

<!-- Client-side management JS -->
<script src="/js/forms.index.js"></script>

<script>
  $(document).on("click", ".btn-delete", function () {
    const id = $(this).data("id");
    if (!confirm("Delete this form?")) return;
    fetch(`/forms/${id}`, { method: "DELETE" })
      .then((r) => r.json())
      .then((resp) => {
        if (resp.success) {
          showToast("Deleted");
          setTimeout(() => location.reload(), 300);
        } else showToast("Delete failed", true);
      })
      .catch((err) => {
        showToast("Delete failed", true);
      });
  });
</script>
