<link rel="stylesheet" href="/css/buttons/index.css" />
<link rel="stylesheet" href="/css/form-modal.css" />

<div class="d-flex justify-content-between align-items-end mb-4">
  <div>
    <h4 class="fw-800 mb-1" style="color: var(--ui-navy); letter-spacing: -1px">
      FORM SUBMISSIONS
    </h4>
    <div class="d-flex align-items-center gap-2">
      <p class="small text-muted mb-0">Manage form submissions</p>
    </div>
  </div>

  <button id="export-csv" class="btn-ui-main">
    <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
      <path
        d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"
      />
      <path
        d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z"
      />
    </svg>
    EXPORT CSV
  </button>
</div>

<div class="d-flex justify-content-between align-items-end gap-3 mb-3">
  <div
    class="search-wrap flex-grow-1"
    style="max-width: 340px; position: relative"
  >
    <i
      class="bi bi-search"
      style="
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #999;
        font-size: 0.9rem;
      "
    ></i>
    <input
      id="submissionSearchInput"
      type="search"
      placeholder="Search by form type..."
      class="search-input"
      style="
        width: 100%;
        padding: 10px 16px 10px 36px;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-size: 0.9rem;
        outline: none;
      "
    />
  </div>
  <div class="limit-wrap d-flex align-items-center gap-2">
    <label
      for="submissionPageLimitSelect"
      style="font-size: 0.85rem; color: #666; margin: 0"
    >
      Show:
    </label>
    <select
      id="submissionPageLimitSelect"
      class="form-select-minimal"
      style="
        padding: 8px 12px;
        border: 1px solid #ddd;
        border-radius: 6px;
        font-size: 0.9rem;
        outline: none;
      "
    >
      <option value="10">10</option>
      <option value="25" selected>25</option>
      <option value="50">50</option>
      <option value="100">100</option>
    </select>
  </div>
</div>

<div class="table-container-minimal">
  <div id="submission-list"></div>
</div>

<div
  id="submission-pagination-controls"
  class="pagination-controls mt-4"
  style="display: none; text-align: center"
></div>

<div id="submission-detail-modal" style="display: none"></div>

<script src="/js/submissions.index.js"></script>
