<link rel="stylesheet" href="/css/groups/create.css" />

<div class="header-minimal mb-5">
  <div
    class="d-flex justify-content-between align-items-center border-bottom pb-3"
  >
    <div>
      <h4 class="fw-800 text-navy mb-0">TẠO GROUP MỚI</h4>
      <p class="text-muted small mb-0">Cấu trúc nội dung theo menu hệ thống</p>
    </div>
    <button
      type="button"
      onclick="history.back()"
      class="btn-back text-decoration-none"
    >
      QUAY LẠI
    </button>
  </div>
</div>

<form id="group-create-form" enctype="multipart/form-data" class="row g-4">
  <input type="hidden" name="parentName" id="parentNameInput" value="" />

  <div class="col-md-8">
    <div class="card shadow-sm">
      <div class="card-body">
        <div class="form-group-minimal mb-4">
          <label>TITLE (EN)</label>
          <input
            type="text"
            name="title_en"
            id="title_en"
            placeholder="Enter English title..."
          />
        </div>
        <div class="form-group-minimal mb-4">
          <label>SUBTITLE (EN)</label>
          <input
            type="text"
            name="subtitle_en"
            id="subtitle_en"
            placeholder="Enter English subtitle..."
          />
        </div>

    <div class="content-block border-top pt-4">
      <div class="d-flex align-items-center gap-4 mb-4">
        <div class="d-flex align-items-center gap-2">
          <label for="orderInput" class="form-label mb-0 small">
            Thứ tự:
          </label>
          <input
            type="number"
            name="order"
            id="orderInput"
            class="form-control form-control-sm text-center"
            value="0"
            min="0"
            style="width: 70px"
          />
        </div>
        <div class="d-flex align-items-center gap-2">
          <label for="typeSelect" class="form-label mb-0 small">Loại:</label>
          <select name="type" id="typeSelect" class="select-clean-sm">
            <option value="html">HTML Block</option>
            <option value="editor">Rich Text Editor</option>
          </select>
        </div>
        <label class="label-bronze mb-0 ms-auto">NỘI DUNG CHI TIẾT</label>
      </div>

      <div id="htmlBlock">
        <textarea
          name="content"
          class="form-control-minimal code-font"
          rows="10"
          placeholder="<div>Your HTML here...</div>"
        ></textarea>
      </div>
      <div id="editorBlock" class="d-none">
        <textarea id="editor"></textarea>
      </div>
    </div>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card shadow-sm">
      <div class="card-body">
    <div class="form-group-minimal mb-4">
      <label>LIÊN KẾT MENU CHA</label>
      <select
        name="listParents"
        id="parentIdSelect"
        class="form-select"
        multiple
        required
      ></select>
      <small class="text-muted mt-2 d-block">
        Có thể chọn nhiều menu để hiển thị group này.
      </small>
    </div>

    <div class="form-group-minimal mb-4">
      <label>HÌNH ẢNH HÀNH LANG (GALLERY)</label>
      <div class="custom-file-upload">
        <input
          type="file"
          name="images"
          id="imageInput"
          multiple
          accept="image/*"
        />
        <span class="upload-label">Chọn ảnh hoặc kéo thả vào đây</span>
      </div>
      <div id="imagePreviewList" class="d-flex flex-wrap mt-3 gap-2"></div>
    </div>

    <div class="form-group-minimal mb-5">
      <label>CẤU HÌNH NÚT</label>
      <div id="buttonsContainer">
        <!-- Buttons will be added here -->
      </div>
      <button
        type="button"
        id="addButton"
        class="btn btn-sm btn-outline-primary"
      >
        + Thêm nút
      </button>
    </div>

    <button type="submit" class="btn-save-minimal">HOÀN TẤT & LƯU GROUP</button>
  </div>
</form>
</div>
</div>

<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css"
/>
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
/>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js"></script>

<script>
  $(document).ready(function () {
    const currentMenuId = '<%= currentMenuId || '' %>';

    // 1. SELECT2 INITIALIZATION
    const parentSelect = $("#parentIdSelect");
    parentSelect.select2({
      placeholder: "Tìm & chọn menu cha...",
      width: "100%",
    });

    // 2. FETCH MENUS
    fetch("/api/menus")
      .then((res) => res.json())
      .then((data) => {
        const menus = data.data || data;
        const groups = {
          top: $('<optgroup label="Header"></optgroup>'),
          bot: $('<optgroup label="Footer"></optgroup>'),
          other: $('<optgroup label="Khác"></optgroup>'),
        };

        menus.forEach((m) => {
          const opt = new Option(m.title?.en || m.title || "-", m._id);
          opt.setAttribute("data-title-en", m.title?.en || m.title || "-");
          if (m.type === "top") groups.top.append(opt);
          else if (m.type === "bot") groups.bot.append(opt);
          else groups.other.append(opt);
        });

        if (groups.top.children().length) parentSelect.append(groups.top);
        if (groups.bot.children().length) parentSelect.append(groups.bot);
        parentSelect.trigger("change");

        // 3. AUTO SET ORDER ON PARENT SELECT
        parentSelect.on('change', function() {
          const selected = $(this).val();
          if (selected && selected.length > 0) {
            const menuId = selected[0];
            fetch(`/groups/next-order/${menuId}`)
              .then(res => res.json())
              .then(data => {
                document.getElementById('orderInput').value = data.nextOrder;
              })
              .catch(err => console.error('Error fetching next order:', err));
          }
        });

        // 4. PRE-SELECT PARENT IF currentMenuId EXISTS
        const currentMenuId = "<%= currentMenuId %>";
        if (currentMenuId && currentMenuId !== "undefined") {
          parentSelect.val([currentMenuId]).trigger("change");
        }
      });

    // 3. CKEDITOR LOGIC
    let editor;
    const typeSelect = document.getElementById("typeSelect");

    function toggleType(type) {
      document
        .getElementById("htmlBlock")
        .classList.toggle("d-none", type === "editor");
      document
        .getElementById("editorBlock")
        .classList.toggle("d-none", type === "html");
      if (type === "editor" && !editor) {
        ClassicEditor.create(document.getElementById("editor")).then((e) => {
          editor = e;
          editor.model.document.on("change:data", () => {
            document.querySelector('[name="content"]').value = editor.getData();
          });
        });
      }
    }
    typeSelect.addEventListener("change", (e) => toggleType(e.target.value));

    // 5. IMAGE PREVIEW
    document
      .getElementById("imageInput")
      .addEventListener("change", function () {
        const preview = document.getElementById("imagePreviewList");
        preview.innerHTML = "";
        Array.from(this.files).forEach((file) => {
          const reader = new FileReader();
          reader.onload = (e) => {
            const img = `<img src="${e.target.result}" style="width: 80px; height: 60px; object-fit: cover; border-radius: 4px; border: 1px solid #ddd;">`;
            preview.insertAdjacentHTML("beforeend", img);
          };
          reader.readAsDataURL(file);
        });
      });

    // 6. HANDLE BUTTONS
    const buttonsContainer = document.getElementById("buttonsContainer");
    const addButton = document.getElementById("addButton");

    addButton.addEventListener("click", function () {
      const newRow = document.createElement("div");
      newRow.className = "button-row row g-3 mb-3";
      newRow.innerHTML = `
        <div class="col-md-5">
          <input
            type="text"
            name="buttonTitle[]"
            class="form-control-minimal"
            placeholder="Tiêu đề nút"
          />
        </div>
        <div class="col-md-5">
          <input
            type="text"
            name="buttonUrl[]"
            class="form-control-minimal"
            placeholder="URL hành động"
          />
        </div>
        <div class="col-md-2">
          <button type="button" class="btn btn-sm btn-outline-danger remove-button">Xóa</button>
        </div>
      `;
      buttonsContainer.appendChild(newRow);
    });

    buttonsContainer.addEventListener("click", function (e) {
      if (e.target.classList.contains("remove-button")) {
        e.target.closest(".button-row").remove();
      }
    });

    // 7. SUBMIT FORM
    document
      .getElementById("group-create-form")
      .addEventListener("submit", function (e) {
        e.preventDefault();
        const formData = new FormData(this);

        const selectedParents = (parentSelect.val() || []).map((id) => {
          const text = parentSelect.find(`option[value='${id}']`).text();
          return { parentId: id, parentName: text };
        });

        formData.set("listParents", JSON.stringify(selectedParents));

        const buttonTitles = document.querySelectorAll(
          'input[name="buttonTitle[]"]'
        );
        const buttonUrls = document.querySelectorAll(
          'input[name="buttonUrl[]"]'
        );
        const buttons = [];
        buttonTitles.forEach((titleInput, index) => {
          const urlInput = buttonUrls[index];
          if (titleInput.value && urlInput.value) {
            buttons.push({ label: titleInput.value, action: urlInput.value });
          }
        });
        if (buttons.length > 0) {
          formData.set("listButtons", JSON.stringify(buttons));
        }

        fetch("/groups/create", { method: "POST", body: formData })
          .then((res) => res.json())
          .then((resp) => {
            if (resp.success) {
              showToast("Lưu thành công");
              setTimeout(() => {
                const menuId = (selectedParents[0]?.parentId || '');
                const url = menuId ? '/dashboard/groups?menuId=' + menuId : '/dashboard/groups';
                window.location.replace(url);
              }, 500);
            } else showToast("Lưu thất bại!", true);
          });
      });
  });
</script>
