<a href="#" id="create-group-btn" class="btn btn-primary mb-3">
  + Create Group
</a>
<div id="group-list"></div>

<script>
  // Lấy menuId từ query string nếu có
  function getMenuId() {
    const url = new URL(window.location.href);
    return url.searchParams.get("menuId") || "";
  }

  function renderGroups(groups, menuId) {
    if (!groups || !groups.length) {
      document.getElementById(
        "group-list"
      ).innerHTML = `<div class="text-center py-5 border rounded bg-light"><h5>No group yet</h5></div>`;
      return;
    }
    let html = '<div class="row g-3">';
    groups.forEach((group) => {
      html += `<div class="col-md-6 col-lg-4">
        <div class="card shadow-sm h-100 border-0 group-card">
          ${
            Array.isArray(group.images) && group.images.length > 0
              ? group.images
                  .map(
                    (img) =>
                      `<img src="${img}" alt="Image" class="card-img-top" style="max-height:180px;object-fit:cover" />`
                  )
                  .join("")
              : group.image
              ? `<img src="${group.image}" alt="Image" class="card-img-top" style="max-height:180px;object-fit:cover" />`
              : ""
          }
          <div class="card-body">
            <div class="d-flex align-items-center justify-content-between mb-2">
              <h5 class="mb-0">${group.title?.en || "Group"}</h5>
              <span class="badge bg-info">Type: ${group.type}</span>
            </div>
            ${
              group.subtitle?.en
                ? `<p class="text-muted small mb-2">${group.subtitle.en}</p>`
                : ""
            }
            <div class="mb-2"><span class="badge ${
              group.isStatus ? "bg-success" : "bg-secondary"
            }">${group.isStatus ? "Active" : "Inactive"}</span></div>
            <div class="group-content mb-2" style="min-height:40px">${
              group.content || ""
            }</div>
            <div class="mb-2">
              <div class="fw-bold text-primary">Parents:</div>
              ${
                Array.isArray(group.listParents) && group.listParents.length > 0
                  ? group.listParents
                      .map(
                        (p) =>
                          `<span class="badge bg-secondary me-1">${p.parentName}</span>`
                      )
                      .join("")
                  : '<span class="text-muted small">No parent</span>'
              }
            </div>
            <div class="mb-2">
              <div class="fw-bold text-primary">Buttons:</div>
              ${
                Array.isArray(group.listButtons) && group.listButtons.length > 0
                  ? group.listButtons
                      .map(
                        (b) =>
                          `<button class="btn btn-sm btn-outline-dark me-1">${
                            b.label || b.text || "Button"
                          }</button>`
                      )
                      .join("")
                  : '<span class="text-muted small">No buttons</span>'
              }
            </div>
            <div class="mt-2">
              <div class="d-flex align-items-center justify-content-between mb-1">
                <div class="fw-bold text-primary">Details:</div>
                <a href="/details/create?parentId=${
                  group._id
                }&subParentId=${menuId}" class="btn btn-sm btn-success">+ Add Detail</a>
              </div>
              ${
                group.listArticles && group.listArticles.length > 0
                  ? `<ul class="list-group list-group-flush">${group.listArticles
                      .map(
                        (detail) =>
                          `<li class="list-group-item px-0 py-1"><a href="/details/${
                            detail._id
                          }" class="text-decoration-none">${
                            detail.title || "Detail"
                          }</a></li>`
                      )
                      .join("")}</ul>`
                  : '<div class="text-muted small">No details yet.</div>'
              }
            </div>
            <div class="d-flex gap-2 flex-wrap mt-2">
              <button class="btn btn-sm btn-outline-warning" onclick="toggleGroupStatus('${
                group._id
              }', this)">${group.isStatus ? "Deactivate" : "Activate"}</button>
              <a href="/groups/${
                group._id
              }/edit" class="btn btn-sm btn-outline-primary">Edit</a>
              <button class="btn btn-sm btn-outline-danger" onclick="deleteGroup('${
                group._id
              }')">Delete</button>
            </div>
          </div>
        </div>
      </div>`;
    });
    html += "</div>";
    document.getElementById("group-list").innerHTML = html;
  }

  function fetchGroups() {
    const menuId = getMenuId();
    fetch(`/groups?menuId=${menuId}`)
      .then((res) => res.json())
      .then((data) => renderGroups(data.groups, menuId));
  }

  function toggleGroupStatus(id, btn) {
    fetch(`/groups/${id}/toggle`, { method: "POST" })
      .then((res) => res.json())
      .then((data) => {
        if (data.success) fetchGroups();
        else alert("Toggle failed");
      });
  }

  function deleteGroup(id) {
    if (!confirm("Are you sure to delete?")) return;
    fetch(`/groups/${id}`, { method: "DELETE" })
      .then((res) => res.json())
      .then((data) => {
        if (data.success) fetchGroups();
        else alert("Delete failed");
      });
  }

  document
    .getElementById("create-group-btn")
    .addEventListener("click", function () {
      const menuId = getMenuId();
      window.location.href = `/groups/create?menuId=${menuId}`;
    });

  fetchGroups();
</script>

<style>
  .group-card:hover {
    box-shadow: 0 0 0 2px #ffc107, 0 2px 8px rgba(0, 0, 0, 0.08);
    border-color: #ffc107;
    transition: box-shadow 0.2s;
  }
  .group-content {
    font-size: 0.97em;
    color: #333;
  }
</style>
