<link rel="stylesheet" href="/css/groups/index.css" />

<% const currentMenu = menus.find(m => m._id.toString() === currentMenuId); %>

<div class="d-flex justify-content-between align-items-end mb-4">
  <div>
    <h4 class="fw-800 mb-1" style="color: var(--ui-navy); letter-spacing: -1px">
      GROUP MANAGEMENT<% if (currentMenu) { %>: <%= currentMenu.title.en %><% }
      %>
    </h4>
    <div class="d-flex align-items-center gap-2">
      <p class="small text-muted mb-0">
        <% if (currentMenu) { %>Groups in menu "<%= currentMenu.title.en %>"<% }
        else { %>Content grouped by Menu<% } %>
      </p>
    </div>
  </div>

  <a
    href="/dashboard/groups/create<% if (currentMenuId) { %>?menuId=<%= currentMenuId %><% } %>"
    class="btn-ui-main"
  >
    <span class="plus-symbol">+</span>
    ADD NEW GROUP
  </a>
</div>

<div class="d-flex justify-content-between align-items-end gap-3 mb-3">
  <div
    class="search-wrap flex-grow-1"
    style="max-width: 340px; position: relative"
  >
    <i
      class="bi bi-search"
      style="
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #999;
        font-size: 0.9rem;
      "
    ></i>
    <input
      id="groupSearchInput"
      type="search"
      placeholder="Search by name..."
      class="group-search-input"
      style="
        width: 100%;
        padding: 10px 16px 10px 36px;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-size: 0.9rem;
        outline: none;
      "
    />
  </div>
  <div class="limit-wrap d-flex align-items-center gap-2">
    <label
      for="pageLimitSelect"
      style="font-size: 0.85rem; color: #666; margin: 0"
    >
      Show:
    </label>
    <select
      id="pageLimitSelect"
      class="form-select-minimal"
      style="
        padding: 8px 12px;
        border: 1px solid #ddd;
        border-radius: 6px;
        font-size: 0.9rem;
        outline: none;
      "
    >
      <option value="5" selected>5</option>
      <option value="10">10</option>
      <option value="25">25</option>
      <option value="50">50</option>
    </select>
  </div>
</div>

<div id="group-list" class="table-container-minimal"></div>

<div
  id="pagination-controls"
  class="pagination-controls mt-4"
  style="display: none; text-align: center"
></div>

<script>
  const currentMenuId = <%- JSON.stringify(currentMenuId || '') %>;
  let currentPage = 1;
  let currentLimit = 5;
  let totalPages = 1;

  function renderGroups(groupsData) {
    const listContainer = document.getElementById("group-list");
    const { groups, pagination } = groupsData;
    const page = pagination?.page || 1;
    const limit = pagination?.limit || 5;
    const total = pagination?.total || 0;
    currentPage = page;
    currentLimit = limit;
    totalPages = pagination?.totalPages || 1;

    if (!groups || !groups.length) {
      listContainer.innerHTML = `<div class="p-5 text-center text-muted">No groups found.</div>`;
      document.getElementById("pagination-controls").style.display = "none";
      return;
    }

    const tableStyle = currentMenuId ? '--drag-w:56px;' : '--drag-w:0px;';
    let html = `
     <table class="table-clean" style="${tableStyle}">
    <thead>
    <tr>
     ${currentMenuId ? '<th class="text-center">&nbsp;</th>' : ''}
     <th>Details</th>
     <th>Type</th>
     <th>Parent Menu(s)</th>
    ${currentMenuId ? '<th class="text-center">Order</th>' : ''}
     <th class="text-center">Status</th>
     <th class="text-center">Actions</th>
    </tr>
    </thead>
    <tbody id="group-list-tbody">`;

    groups.forEach((group) => {
      const imgUrl =
        group.image ||
        "https://placehold.co/100x75?text=No+Image";

      html += `
      <tr data-group-id="${group._id}" class="${currentMenuId ? 'drag-row' : ''}">
        ${currentMenuId ? `
        <td class="text-center drag-cell">
          <span class="drag-handle" title="Drag to reorder">≡</span>
        </td>
        ` : ''}
        <td>
          <div class="d-flex align-items-center">
            <img src="${imgUrl}" style="width: 60px; height: 45px; object-fit: cover; border-radius: 4px; margin-right: 12px;" />
            <div style="max-width: 496px">
              <div class="fw-bold">${group.title?.en || "-"}</div>
              <div class="text-muted small">${group.subtitle?.en || "-"}</div>
            </div>
          </div>
        </td>
        <td>
          <span class="badge-minimal">${group.type}</span>
        </td>
        <td>
          <div style="max-width: 400px">
            ${
              (group.listParents || [])
                .map(
                  (p) => `<span class="badge-minimal me-1">${p.parentName}</span>`
                )
            }
          </div>
        </td>
        ${
          currentMenuId
            ? (() => {
                const p = (group.listParents || []).find((pp) => String(pp.parentId) === String(currentMenuId));
                return p
                ?`<td class="text-center"><span class="badge-minimal">${p.order}</span></td>`
                :"";
              })()
            :
                ""
        }
        <td class="text-center">
          <span class="badge-minimal ${group.isStatus ? "badge-active" : ""}">
            ${group.isStatus ? "SHOW" : "HIDE"}
          </span>
        </td>
        <td class="text-center">
          <button class="action-circle" onclick="toggleGroupStatus('${
            group._id
          }', this)" title="Toggle status">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </button>
          <a href="/dashboard/groups/${
            group._id
          }/edit<% if (currentMenuId) { %>?menuId=<%= currentMenuId %><% } %>" class="action-circle" title="Edit">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7M18.5 2.5a2.121 2.121 0 113 3L12 15l-4 1 1-4 9.5-9.5z"></path>
            </svg>
          </a>
          <button onclick="deleteGroup('${
            group._id
          }')" class="action-circle btn-del" title="Delete">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
            </svg>
          </button>
        </td>
      </tr>`;
    });

    html += "</tbody></table>";
    listContainer.innerHTML = html;

    renderPagination();
  }

  function renderPagination() {
    const paginationDiv = document.getElementById("pagination-controls");
    if (totalPages <= 1) {
      paginationDiv.style.display = "none";
      return;
    }

    paginationDiv.style.display = "block";
    let paginationHtml = `<div style="display: flex; justify-content: center; align-items: center; gap: 6px; flex-wrap: wrap;">`;

    if (currentPage > 1) {
      paginationHtml += `<button class="pagination-btn" onclick="goToPage(1)" style="padding: 6px 10px; border: 1px solid #ddd; border-radius: 4px; background: #fff; cursor: pointer; transition: 0.2s;">« First</button>`;
      paginationHtml += `<button class="pagination-btn" onclick="goToPage(${currentPage - 1})" style="padding: 6px 10px; border: 1px solid #ddd; border-radius: 4px; background: #fff; cursor: pointer; transition: 0.2s;">‹ Prev</button>`;
    }

    const startPage = Math.max(1, currentPage - 2);
    const endPage = Math.min(totalPages, currentPage + 2);

    for (let i = startPage; i <= endPage; i++) {
      const isActive = i === currentPage;
      const btnStyle = isActive
        ? "background: var(--ui-navy); color: var(--ui-bronze); font-weight: 700;"
        : "background: #fff; color: #333;";
      paginationHtml += `<button class="pagination-btn" onclick="goToPage(${i})" style="padding: 6px 12px; border: 1px solid #ddd; border-radius: 4px; ${btnStyle} cursor: pointer; transition: 0.2s;">${i}</button>`;
    }

    if (currentPage < totalPages) {
      paginationHtml += `<button class="pagination-btn" onclick="goToPage(${currentPage + 1})" style="padding: 6px 10px; border: 1px solid #ddd; border-radius: 4px; background: #fff; cursor: pointer; transition: 0.2s;">Next ›</button>`;
      paginationHtml += `<button class="pagination-btn" onclick="goToPage(${totalPages})" style="padding: 6px 10px; border: 1px solid #ddd; border-radius: 4px; background: #fff; cursor: pointer; transition: 0.2s;">Last »</button>`;
    }

    paginationHtml += `<span style="margin-left: 16px; font-size: 0.85rem; color: #666;">Page ${currentPage}/${totalPages}</span>`;
    paginationHtml += `</div>`;
    paginationDiv.innerHTML = paginationHtml;
  }

  function goToPage(page) {
    currentPage = page;
    loadGroups();
  }

  function getMenuId() {
    const url = new URL(window.location.href);
    return url.searchParams.get("menuId") || "";
  }

  function loadGroups() {
    const menuId = getMenuId();
    const search = document.getElementById("groupSearchInput")?.value || "";

    const params = new URLSearchParams();
    if (menuId) params.append("menuId", menuId);
    if (search) params.append("search", search);
    params.append("page", currentPage);
    params.append("limit", currentLimit);

    const url = `/groups?${params.toString()}`;
    return fetch(url)
      .then((res) => res.json())
      .then((data) => renderGroups(data));
  }

  function toggleGroupStatus(id, btn) {
    fetch(`/groups/${id}/toggle`, { method: "POST" })
      .then((res) => res.json())
      .then((data) => {
        if (data.success) loadGroups();
        else alert("Toggle failed");
      });
  }

  function deleteGroup(id) {
    if (!confirm("Are you sure to delete?")) return;
    fetch(`/groups/${id}`, { method: "DELETE" })
      .then((res) => res.json())
      .then((data) => {
        if (data.success) {
          currentPage = 1;
          loadGroups();
        }
        else alert("Delete failed");
      });
  }

  // Ensure Sortable is available (load if missing)
  function ensureSortable() {
    return new Promise((resolve) => {
      if (window.Sortable) return resolve();
      const s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js';
      s.onload = () => resolve();
      document.head.appendChild(s);
    });
  }

  let sortableInstance = null;
  function initSortable() {
    const tbody = document.getElementById('group-list-tbody');
    if (!tbody || !currentMenuId) return Promise.resolve();
    if (sortableInstance) {
      try { sortableInstance.destroy(); } catch (e) {}
      sortableInstance = null;
    }
    return ensureSortable().then(() => {
      sortableInstance = Sortable.create(tbody, {
        draggable: 'tr.drag-row',
        filter: 'button, a, input, textarea, select',
        preventOnFilter: false,
        animation: 170,
        easing: 'cubic-bezier(0.22, 1, 0.36, 1)',
        chosenClass: 'drag-chosen',
        ghostClass: 'drag-ghost',
        dragClass: 'drag-active',
        scroll: true,
        bubbleScroll: true,
        scrollSensitivity: 80,
        scrollSpeed: 14,
        onEnd: function (evt) {
          const items = Array.from(tbody.children);
          const updates = items.map((tr, index) => {
            const groupId = tr.dataset.groupId;
            return { groupId, order: index + 1 };
          });
          fetch('/groups/update-orders', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ updates, parentId: currentMenuId }),
          })
            .then((res) => res.json())
            .then((data) => {
              if (data && data.success) showToast('Order saved');
              else showToast('Order save failed', true);
              return loadGroups();
            })
            .then(() => initSortable())
            .catch(() => {
              showToast('Order save failed', true);
              return loadGroups().then(() => initSortable());
            });
        },
      });
    });
  }

  // Event listeners for search and limit
  document.getElementById("groupSearchInput")?.addEventListener("input", () => {
    currentPage = 1;
    loadGroups();
  });

  document.getElementById("pageLimitSelect")?.addEventListener("change", (e) => {
    currentLimit = parseInt(e.target.value, 10);
    currentPage = 1;
    loadGroups();
  });

  // Initialize list and sortable
  loadGroups().then(() => initSortable());
</script>
