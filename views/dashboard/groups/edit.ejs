<link rel="stylesheet" href="/css/groups/edit.css" />

<div class="header-minimal mb-5">
  <div
    class="d-flex justify-content-between align-items-center border-bottom pb-3"
  >
    <div>
      <h4 class="fw-800 text-navy mb-0">EDIT GROUP</h4>
      <p class="text-muted small mb-0">Update group information</p>
    </div>
    <button
      type="button"
      onclick="history.back()"
      class="btn-back text-decoration-none"
    >
      BACK 
    </button>
  </div>
</div>

<form id="group-edit-form" enctype="multipart/form-data" class="row g-4">
  <input type="hidden" name="parentName" id="parentNameInput" value="" />

  <div class="col-md-8">
    <div class="card shadow-sm">
      <div class="card-body">
    <ul class="nav nav-tabs-minimal mb-4" id="langTab">
      <li class="nav-item">
        <button class="nav-link active" data-tab-target="#tab-en" type="button">
          ENGLISH
        </button>
      </li>
      <li class="nav-item">
        <button class="nav-link" data-tab-target="#tab-vi" type="button">
          VIETNAMESE
        </button>
      </li>
      <li class="nav-item">
        <button class="nav-link" data-tab-target="#tab-zh" type="button">
          中文 (ZH)
        </button>
      </li>
    </ul>

    <div class="tab-content-minimal mb-5">
      <div class="tab-pane-custom active" id="tab-en">
        <div class="form-group-minimal mb-4">
          <label>TITLE (EN)</label>
          <input
            type="text"
            name="title_en"
            id="title_en"
            value="<%= group.title?.en || '' %>"
            placeholder="Enter English title..."
          />
        </div>
        <div class="form-group-minimal mb-4">
          <label>SUBTITLE (EN)</label>
          <input
            type="text"
            name="subtitle_en"
            id="subtitle_en"
            value="<%= group.subtitle?.en || '' %>"
            placeholder="Enter English subtitle..."
          />
        </div>
      </div>
      <div class="tab-pane-custom" id="tab-vi">
        <div class="form-group-minimal mb-4">
          <label>TITLE (VI)</label>
          <input
            type="text"
            name="title_vi"
            id="title_vi"
            value="<%= group.title?.vi || '' %>"
            placeholder="Enter Vietnamese title..."
          />
        </div>
        <div class="form-group-minimal mb-4">
          <label>SUBTITLE (VI)</label>
          <input
            type="text"
            name="subtitle_vi"
            id="subtitle_vi"
            value="<%= group.subtitle?.vi || '' %>"
            placeholder="Enter Vietnamese subtitle..."
          />
        </div>
      </div>
      <div class="tab-pane-custom" id="tab-zh">
        <div class="form-group-minimal mb-4">
          <label>TITLE (ZH)</label>
          <input
            type="text"
            name="title_zh"
            id="title_zh"
            value="<%= group.title?.zh || '' %>"
            placeholder="Enter Chinese title..."
          />
        </div>
        <div class="form-group-minimal mb-4">
          <label>SUBTITLE (ZH)</label>
          <input
            type="text"
            name="subtitle_zh"
            id="subtitle_zh"
            value="<%= group.subtitle?.zh || '' %>"
            placeholder="Enter Chinese subtitle..."
          />
        </div>
      </div>
    </div>

    <div class="content-block border-top pt-4">
      <div class="d-flex align-items-center gap-4 mb-4">
          <div class="d-flex align-items-center gap-2">
            <label for="typeSelect" class="form-label mb-0 small">Type:</label>
            <select name="type" id="typeSelect" class="select-clean-sm">              <option value="-" <%= (!group.type || group.type === '-') ? 'selected' : '' %>>-</option>              <option value="html" <%= group.type === 'html' ? 'selected' : '' %>>HTML Block</option>
              <option value="editor" <%= group.type === 'editor' ? 'selected' : '' %>>Rich Text Editor</option>
            </select>
          </div>
          <label class="label-bronze mb-0 ms-auto">DETAIL CONTENT</label>
        </div>

      <div id="htmlBlock">
        <textarea
          name="content"
          class="form-control-minimal code-font"
          rows="10"
          placeholder="<div>Your HTML here...</div>"
        ><%= group.content || '' %></textarea>
      </div>
      <div id="editorBlock" class="d-none">
        <textarea id="editor"><%= group.content || '' %></textarea>
      </div>
    </div>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <h6 class="card-title text-navy mb-4">
          <i class="fas fa-cogs me-2"></i>Settings
        </h6>

        <div class="form-group-minimal mb-4">
          <label>Parent Menus</label>
          <select
            name="listParents"
            id="parentIdSelect"
            class="form-select"
            multiple
          ></select>
          <small class="text-muted mt-2 d-block">
            You can select multiple menus to display this group.
          </small>
          <div id="selectedParentsList" class="mt-3"></div>
        </div>

        <div class="form-group-minimal mb-4">
          <label>Buttons</label>
          <select name="listButtonsSelect" id="buttonIdSelect" class="form-select" multiple></select>
          <small class="text-muted mt-2 d-block">Select existing buttons to attach to this group. Custom buttons (not in the list) are shown below and editable.</small>
        </div>



        <div class="form-group-minimal mb-4">
          <label>FEATURE IMAGE</label>
          <div class="custom-file-upload">
            <input
              type="file"
              name="image"
              id="imageInput"
              accept="image/*"
            />
            <span class="upload-label">Choose image or drag & drop here</span>
          </div>
          <% if (Array.isArray(group.images) && group.images.length) { %>
          <div id="imagePreviewList" class="mt-2 d-flex gap-2">
            <% group.images.forEach(function(img) { %>
              <img
                src="<%= img %>"
                alt="Current image"
                class="img-thumbnail"
                style="max-width: 100px; max-height: 100px;"
              />
            <% }) %>
          </div>
          <% } else if (group.image) { %>
          <div id="imagePreviewList" class="mt-2 d-flex gap-2">
            <img
              src="<%= group.image %>"
              alt="Current image"
              class="img-thumbnail"
              style="max-width: 100px; max-height: 100px;"
            />
          </div>
          <% } else { %>
          <div id="imagePreviewList" class="mt-2 d-flex gap-2"></div>
          <% } %>
        </div>

        <div class="d-grid gap-2">
          <button type="submit" class="btn-save-minimal">
            <i class="fas fa-save me-2"></i>UPDATE
          </button>
        </div>
      </div>
    </div>
  </div>
</form>

<!-- inline script removed; logic re-inserted below after library includes -->

<link
  href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css"
  rel="stylesheet"
/>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js"></script>

<script>
  $(document).ready(function () {
    const currentMenuId = <%- JSON.stringify(currentMenuId || '') %>;
    const existingParents = <%- JSON.stringify(group.listParents || []) %>;

    // Buttons select (make jQuery reference available to entire ready scope)
    const buttonIdSelect = $('#buttonIdSelect');
    buttonIdSelect.select2({ placeholder: 'Select buttons...', width: '100%' });

    // TAB SWITCH (jQuery)
    $('.nav-tabs-minimal .nav-link').on('click', function () {
      const target = $(this).attr('data-tab-target');
      $('.nav-tabs-minimal .nav-link').removeClass('active');
      $('.tab-pane-custom').removeClass('active');
      $(this).addClass('active');
      $(target).addClass('active');
    });

    // TYPE / CKEDITOR TOGGLE
    let editor;
    function toggleType(type) {
      const $html = $('#htmlBlock');
      const $editor = $('#editorBlock');

      if (type === '-') {
        $html.addClass('d-none');
        $editor.addClass('d-none');
        return;
      }

      if (type === 'html') {
        $html.removeClass('d-none');
        $editor.addClass('d-none');
        return;
      }

      // editor
      $html.addClass('d-none');
      $editor.removeClass('d-none');
      if (type === 'editor' && !editor) {
        ClassicEditor.create(document.getElementById('editor')).then((e) => {
          editor = e;
          editor.model.document.on('change:data', () => {
            $('[name="content"]').val(editor.getData());
          });
        });
      }
    }
    $('#typeSelect').on('change', function () {
      toggleType(this.value);
    });
    // initialize according to current value
    toggleType($('#typeSelect').val() || '-');

    // PARENT SELECT: initialize Select2 and load grouped options
    const parentSelect = $('#parentIdSelect');
    parentSelect.select2({ placeholder: 'Search & select parent menus...', width: '100%' });

    // IMAGE PREVIEW (client-side before upload)
    document.getElementById("imageInput").addEventListener("change", function () {
      const preview = document.getElementById("imagePreviewList");
      // clear current previews
      preview.innerHTML = "";
      Array.from(this.files).forEach((file) => {
        const reader = new FileReader();
        reader.onload = (e) => {
          const img = `<img src="${e.target.result}" style="width: 100px; height: 100px; object-fit: cover; border-radius: 4px; border: 1px solid #ddd;">`;
          preview.insertAdjacentHTML("beforeend", img);
        };
        reader.readAsDataURL(file);
      });
    });

    function updateSelectedParentsList() {
      const selectedIds = parentSelect.val() || [];
      const listContainer = document.getElementById('selectedParentsList');
      if (selectedIds.length === 0) {
        listContainer.innerHTML = '';
        return;
      }
      let html = '<div class="selected-parents-list">';
      selectedIds.forEach(id => {
        const text = parentSelect.find(`option[value='${id}']`).text();
        html += `
          <div class="d-flex align-items-center mb-2">
            <span class="me-3">${text}</span>
          </div>
        `;
      });
      html += '</div>';
      listContainer.innerHTML = html;
    }

    parentSelect.on('change', updateSelectedParentsList);

    fetch('/api/menus')
      .then((res) => res.json())
      .then((data) => {
        const menus = data.data || [];
        const groups = {
          top: $('<optgroup label="Header"></optgroup>'),
          bot: $('<optgroup label="Footer"></optgroup>'),
          other: $('<optgroup label="Other"></optgroup>'),
        };

        menus.forEach((m) => {
          const opt = new Option(m.title?.en || m.title || '-', m._id);
          $(opt).attr('data-title-en', m.title?.en || m.title || '-');
          if (m.type === 'top') groups.top.append(opt);
          else if (m.type === 'bot') groups.bot.append(opt);
          else groups.other.append(opt);
        });

        if (groups.top.children().length) parentSelect.append(groups.top);
        if (groups.bot.children().length) parentSelect.append(groups.bot);
        if (groups.other.children().length) parentSelect.append(groups.other);
        parentSelect.trigger('change');

        // Pre-select based on existing group.listParents
        const groupParents = Array.isArray(existingParents) ? existingParents : [];
        const selectedIds = groupParents.map((p) => String(p.parentId));
        if (selectedIds.length) parentSelect.val(selectedIds).trigger('change');

        // ----------------- BUTTONS: load and pre-select -----------------
        const existingButtons = <%- JSON.stringify(group.listButtons || []) %>;

        // Populate options and then pre-select matching existingButtons, render custom ones
        fetch('/buttons')
          .then((res) => res.json())
          .then((data) => {
            const list = data.buttons || data;
            const idByRoute = {};
            const idByTitle = {};
            list.forEach((b) => {
              const title = b.title?.en || b.title || '-';
              const opt = new Option(title, b._id);
              $(opt).attr('data-route', b.route || '');
              $(opt).attr('data-type', b.type || 'route');
              $(opt).attr('data-form-id', (b.form && b.form.id && b.form.id._id) ? b.form.id._id : '');
              buttonIdSelect.append(opt);
              if (b.route) idByRoute[b.route] = b._id;
              if (title) idByTitle[title] = b._id;
            });

            // Determine which existingButtons map to server buttons
            const idsToSelect = [];
            (existingButtons || []).forEach((cb) => {
                  const actionOrLink = (cb && (cb.buttonRoute || cb.link || cb.action || cb.route)) || '';
            const idToSelect = (cb && (cb.buttonId || cb.id)) || null;
            if (idToSelect) {
              idsToSelect.push(String(idToSelect));
            } else {
              const matchId = (actionOrLink && idByRoute[actionOrLink]) || (cb && cb.buttonName && idByTitle[cb.buttonName]) || (cb && cb.label && idByTitle[cb.label]);
              if (matchId) idsToSelect.push(matchId);
            }
            });

            if (idsToSelect.length) {
              buttonIdSelect.val(idsToSelect).trigger('change');
            }
          })
          .catch(() => {});


      })
      .catch(() => {});

    // SUBMIT FORM
    $('#group-edit-form').on('submit', function (e) {
      e.preventDefault();
      const form = this;
      const formData = new FormData(form);

      const selectedIds = parentSelect.val() || [];
      const selectedParents = selectedIds.map((id) => {
        const text = parentSelect.find(`option[value='${id}']`).text();
        const existing = (existingParents || []).find(p => String(p.parentId) === id) || {};
        const order = existing.order || 0;
        return { parentId: id, parentName: text, order };
      });
      formData.set('listParents', JSON.stringify(selectedParents));

      // images
      const imageInput = document.getElementById('imageInput');
      if (imageInput && imageInput.files.length > 0) {
        for (let i = 0; i < imageInput.files.length; i++) formData.append('images', imageInput.files[i]);
      }

      // buttons (selected existing ones)
      const buttons = [];

      // Add selected existing buttons from select
      const selectedButtonIds = buttonIdSelect.val() || [];
      selectedButtonIds.forEach((id) => {
        const opt = buttonIdSelect.find(`option[value='${id}']`);
        const label = opt.text();
        const action = opt.data('route') || '';
        const type = opt.data('type') || 'route';
        const formId = opt.data('form-id') || null;
        if (label) buttons.push({ buttonId: id, buttonName: label, buttonRoute: action, buttonType: type, buttonFormId: formId });
      });
      formData.set('listButtons', JSON.stringify(buttons)); // Always set, even if empty

      fetch('/groups/<%= group._id %>/update', { method: 'POST', body: formData })
        .then((res) => res.json())
        .then((resp) => {
          const isArray = Array.isArray(resp);
          const data = resp && resp.data ? resp.data : resp;
          const isOk = (resp && (resp.success === true || resp.success === 'true')) || (resp && resp._id) || isArray || (Array.isArray(data) && data.length > 0) || (resp && resp.groups);
          if (isOk) {
             showToast('Update successful');
            setTimeout(() => {
              const urlMenuId = new URL(window.location.href).searchParams.get('menuId') || '';
              if (urlMenuId) {
                window.location.replace('/dashboard/groups?menuId=' + urlMenuId);
              } else {
                window.location.replace('/dashboard/groups');
              }
            }, 500);
          } else {
            console.warn('Update considered failure, server responded:', resp);
            showToast('Update failed', true);
          }
        })
        .catch((err) => {
          console.error('Fetch/update error', err);
          showToast('Update failed — check console', true);
        });
    });
  });
</script>


