<h4>Edit Group</h4>

<form method="POST" action="/groups/<%= group._id %>/update" enctype="multipart/form-data">

  <!-- MENU (READONLY) -->
  <% if (!group.parentId) { %>
    <select name="parentId" class="form-select mb-3" required>
      <% menus.forEach(m => { %>
        <option
          value="<%= m._id %>"
          <%= m._id.toString() === group.parentId?.toString() ? 'selected' : '' %>
        >
          <%= m.title.en %>
        </option>
      <% }) %>
    </select>
  <% } else { %>
    <input type="hidden" name="parentId" value="<%= group.parentId %>" />
  <% } %>

  <!-- TYPE -->
  <select name="type" id="typeSelect" class="form-select mb-3">
    <option value="html" <%= group.type === 'html' ? 'selected' : '' %>>
      HTML Block
    </option>
    <option value="editor" <%= group.type === 'editor' ? 'selected' : '' %>>
      Text Editor
    </option>
  </select>


  <!-- IMAGE UPLOAD (show old, preview new) -->
  <div class="mb-3">
    <label class="form-label">Image</label>
    <div class="row g-2 align-items-center">
      <% if (group.image) { %>
        <div class="col-auto text-center">
          <div class="small text-muted mb-1">Current Image</div>
          <img src="<%= group.image %>" alt="Current Image" class="img-thumbnail border border-primary" style="max-width: 160px;" id="oldImage" />
        </div>
      <% } %>
      <div class="col-auto text-center">
        <div class="small text-muted mb-1">New Image Preview</div>
        <img id="imagePreview" src="#" alt="Preview" class="img-thumbnail border border-success d-none" style="max-width: 160px;" />
      </div>
      <div class="col-12 mt-2">
        <input type="file" name="image" id="imageInput" class="form-control" accept="image/*" />
      </div>
    </div>
  </div>

  <!-- LANGUAGE TABS -->
  <ul class="nav nav-tabs mb-3" role="tablist">
    <li class="nav-item">
      <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-en" type="button">
        EN
      </button>
    </li>
    <li class="nav-item">
      <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-vi" type="button">
        VI
      </button>
    </li>
    <li class="nav-item">
      <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-zh" type="button">
        ZH
      </button>
    </li>
  </ul>

  <div class="tab-content">
    <!-- EN -->
    <div class="tab-pane fade show active" id="tab-en">
      <input
        class="form-control mb-2"
        name="title_en"
        value="<%= group.title?.en || '' %>"
        placeholder="Title EN"
      />
      <input
        class="form-control mb-3"
        name="subtitle_en"
        value="<%= group.subtitle?.en || '' %>"
        placeholder="Subtitle EN"
      />
    </div>

    <!-- VI -->
    <div class="tab-pane fade" id="tab-vi">
      <input
        class="form-control mb-2"
        name="title_vi"
        value="<%= group.title?.vi || '' %>"
        placeholder="Title VI"
      />
      <input
        class="form-control mb-3"
        name="subtitle_vi"
        value="<%= group.subtitle?.vi || '' %>"
        placeholder="Subtitle VI"
      />
    </div>

    <!-- ZH -->
    <div class="tab-pane fade" id="tab-zh">
      <input
        class="form-control mb-2"
        name="title_zh"
        value="<%= group.title?.zh || '' %>"
        placeholder="Title ZH"
      />
      <input
        class="form-control mb-3"
        name="subtitle_zh"
        value="<%= group.subtitle?.zh || '' %>"
        placeholder="Subtitle ZH"
      />
    </div>
  </div>

  <!-- HTML -->
  <div id="htmlBlock" class="<%= group.type === 'html' ? '' : 'd-none' %>">
    <label class="form-label text-danger">HTML</label>
    <textarea
      name="content"
      class="form-control font-monospace"
      rows="8"
    ><%= group.content || '' %></textarea>
  </div>

  <!-- EDITOR -->
  <div id="editorBlock" class="<%= group.type === 'editor' ? '' : 'd-none' %>">
    <label class="form-label text-success">Editor</label>
    <textarea id="editor"><%= group.content || '' %></textarea>
  </div>

  <button class="btn btn-success mt-3">Update</button>
<a href="/groups?menuId=<%= group.parentId %>" class="btn btn-secondary mt-3 ms-2">Cancel</a>
</form>
<script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js"></script>
<script>
    // Image preview with filename suggestion for edit
    const imageInput = document.getElementById('imageInput');
    const imagePreview = document.getElementById('imagePreview');
    const titleEnInput = document.getElementById('title_en');
    function getSafeFilename(title, id, ext) {
      return (
        (title || 'group')
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-+|-+$/g, '') +
        '-' + id + ext
      );
    }
    if (imageInput) {
      imageInput.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
          const reader = new FileReader();
          reader.onload = function(ev) {
            imagePreview.src = ev.target.result;
            imagePreview.classList.remove('d-none');
          };
          reader.readAsDataURL(file);
          // Show filename suggestion (for backend to use)
          let ext = file.name.substring(file.name.lastIndexOf('.'));
          let title = titleEnInput.value || 'group';
          let filename = getSafeFilename(title, '<%= group._id %>', ext);
          imageInput.setAttribute('data-filename', filename);
        } else {
          imagePreview.src = '#';
          imagePreview.classList.add('d-none');
        }
      });
    }
  const typeSelect = document.getElementById("typeSelect");
  const htmlBlock = document.getElementById("htmlBlock");
  const editorBlock = document.getElementById("editorBlock");
  let editor;

  function toggleType(type) {
    htmlBlock.classList.toggle("d-none", type === "editor");
    editorBlock.classList.toggle("d-none", type === "html");

    if (type === "editor" && !editor) {
      ClassicEditor.create(document.getElementById("editor")).then(e => {
        editor = e;
        editor.model.document.on("change:data", () => {
          document.querySelector('[name="content"]').value = editor.getData();
        });
      });
    }
  }

  toggleType(typeSelect.value);
  typeSelect.addEventListener("change", e => toggleType(e.target.value));
</script>
