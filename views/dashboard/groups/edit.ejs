<h4>Edit Group</h4>

<form id="group-edit-form" enctype="multipart/form-data">

  <!-- MENU (multi-parent) -->
  <label class="form-label">Parents</label>
  <select name="listParents" id="parentIdSelect" class="form-select mb-3" multiple required></select>

  <!-- TYPE -->
  <select name="type" id="typeSelect" class="form-select mb-3">
    <option value="html" <%= group.type === 'html' ? 'selected' : '' %>>
      HTML Block
    </option>
    <option value="editor" <%= group.type === 'editor' ? 'selected' : '' %>>
      Text Editor
    </option>
  </select>


  <!-- IMAGE UPLOAD (show old, preview new) -->
  <div class="mb-3">
    <label class="form-label">Images</label>
    <div id="oldImageList" class="d-flex flex-wrap mb-2">
      <% if (Array.isArray(group.images) && group.images.length) { group.images.forEach(function(img) { %>
        <img src="<%= img %>" alt="Current Image" class="img-thumbnail border border-primary me-2 mb-2" style="max-width: 120px;" />
      <% }) } %>
    </div>
    <input type="file" name="images" id="imageInput" class="form-control" accept="image/*" multiple />
    <div class="form-text">Chọn nhiều hình ảnh cho group.</div>
    <div id="imagePreviewList" class="d-flex flex-wrap mt-2"></div>
    <!-- BUTTONS -->
    <div class="mb-3">
      <label class="form-label">Buttons</label>
      <input type="text" name="listButtons" id="buttonsInput" class="form-control" value='<%= JSON.stringify(group.listButtons || []) %>' placeholder='[{"label":"Button1","action":"#"}]' />
      <div class="form-text">Nhập JSON cho nút (label, action, ...).</div>
    </div>
  </div>

  <!-- LANGUAGE TABS -->
  <ul class="nav nav-tabs mb-3" role="tablist">
    <li class="nav-item">
      <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-en" type="button">
        EN
      </button>
    </li>
    <li class="nav-item">
      <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-vi" type="button">
        VI
      </button>
    </li>
    <li class="nav-item">
      <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-zh" type="button">
        ZH
      </button>
    </li>
  </ul>

  <div class="tab-content">
    <!-- EN -->
    <div class="tab-pane fade show active" id="tab-en">
      <input
        class="form-control mb-2"
        name="title_en"
        value="<%= group.title?.en || '' %>"
        placeholder="Title EN"
      />
      <input
        class="form-control mb-3"
        name="subtitle_en"
        value="<%= group.subtitle?.en || '' %>"
        placeholder="Subtitle EN"
      />
    </div>

    <!-- VI -->
    <div class="tab-pane fade" id="tab-vi">
      <input
        class="form-control mb-2"
        name="title_vi"
        value="<%= group.title?.vi || '' %>"
        placeholder="Title VI"
      />
      <input
        class="form-control mb-3"
        name="subtitle_vi"
        value="<%= group.subtitle?.vi || '' %>"
        placeholder="Subtitle VI"
      />
    </div>

    <!-- ZH -->
    <div class="tab-pane fade" id="tab-zh">
      <input
        class="form-control mb-2"
        name="title_zh"
        value="<%= group.title?.zh || '' %>"
        placeholder="Title ZH"
      />
      <input
        class="form-control mb-3"
        name="subtitle_zh"
        value="<%= group.subtitle?.zh || '' %>"
        placeholder="Subtitle ZH"
      />
    </div>
  </div>

  <!-- HTML -->
  <div id="htmlBlock" class="<%= group.type === 'html' ? '' : 'd-none' %>">
    <label class="form-label text-danger">HTML</label>
    <textarea
      name="content"
      class="form-control font-monospace"
      rows="8"
    ><%= group.content || '' %></textarea>
  </div>

  <!-- EDITOR -->
  <div id="editorBlock" class="<%= group.type === 'editor' ? '' : 'd-none' %>">
    <label class="form-label text-success">Editor</label>
    <textarea id="editor"><%= group.content || '' %></textarea>
  </div>

  <button class="btn btn-success mt-3">Update</button>
<a href="/groups?menuId=<%= group.parentId %>" class="btn btn-secondary mt-3 ms-2">Cancel</a>
  <button class="btn btn-success mt-3" type="submit">Update</button>
</form>

<script>
  // Lấy danh sách menu cho select
  // Lấy danh sách menu cho select (multi-parent)
  fetch('/api/menus')
    .then(res => res.json())
    .then(data => {
      const menus = data.data || [];
      const select = document.getElementById('parentIdSelect');
      const groupParents = Array.isArray(<%= JSON.stringify(group.listParents || []) %>) ? <%= JSON.stringify(group.listParents || []) %> : [];
      menus.forEach(m => {
        const opt = document.createElement('option');
        opt.value = m._id;
        opt.textContent = m.title?.en || m.title || '-';
        if (groupParents.some(p => p.parentId === m._id)) opt.selected = true;
        select.appendChild(opt);
      });
    });

  // Submit form bằng fetch
  document.getElementById('group-edit-form').addEventListener('submit', function(e) {
    e.preventDefault();
    const form = e.target;
    const formData = new FormData(form);
    // Multi-parent
    const parentSelect = document.getElementById('parentIdSelect');
    const selectedParents = Array.from(parentSelect.selectedOptions).map(opt => ({ parentId: opt.value, parentName: opt.textContent }));
    formData.delete('listParents');
    formData.append('listParents', JSON.stringify(selectedParents));
    // Multi-images
    const imageInput = document.getElementById('imageInput');
    if (imageInput && imageInput.files.length > 0) {
      for (let i = 0; i < imageInput.files.length; i++) {
        formData.append('images', imageInput.files[i]);
      }
    }
    // Buttons
    const buttonsInput = document.getElementById('buttonsInput');
    if (buttonsInput && buttonsInput.value) {
      formData.delete('listButtons');
      formData.append('listButtons', buttonsInput.value);
    }
    fetch('/groups/<%= group._id %>/update', {
      method: 'POST',
      body: formData
    })
      .then(res => res.json())
      .then(resp => {
        if (resp.success) window.location.href = '/groups?menuId=' + (selectedParents[0]?.parentId || '');
        else alert('Update failed');
      })
      .catch(() => alert('Update failed'));
  });
</script>
<script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js"></script>
<script>
    // Image preview (multi)
    const imageInput = document.getElementById('imageInput');
    const imagePreviewList = document.getElementById('imagePreviewList');
    if (imageInput && imagePreviewList) {
      imageInput.addEventListener('change', function(e) {
        imagePreviewList.innerHTML = '';
        Array.from(imageInput.files).forEach(file => {
          const reader = new FileReader();
          reader.onload = function(ev) {
            const img = document.createElement('img');
            img.src = ev.target.result;
            img.className = 'img-thumbnail me-2 mb-2';
            img.style.maxWidth = '120px';
            imagePreviewList.appendChild(img);
          };
          reader.readAsDataURL(file);
        });
      });
    }
  const typeSelect = document.getElementById("typeSelect");
  const htmlBlock = document.getElementById("htmlBlock");
  const editorBlock = document.getElementById("editorBlock");
  let editor;

  function toggleType(type) {
    htmlBlock.classList.toggle("d-none", type === "editor");
    editorBlock.classList.toggle("d-none", type === "html");

    if (type === "editor" && !editor) {
      ClassicEditor.create(document.getElementById("editor")).then(e => {
        editor = e;
        editor.model.document.on("change:data", () => {
          document.querySelector('[name="content"]').value = editor.getData();
        });
      });
    }
  }

  toggleType(typeSelect.value);
  typeSelect.addEventListener("change", e => toggleType(e.target.value));
</script>
