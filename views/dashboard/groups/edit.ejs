<link rel="stylesheet" href="/css/groups/edit.css" />

<div class="header-minimal mb-5">
  <div
    class="d-flex justify-content-between align-items-center border-bottom pb-3"
  >
    <div>
      <h4 class="fw-800 text-navy mb-0">CHỈNH SỬA GROUP</h4>
      <p class="text-muted small mb-0">Cập nhật thông tin group</p>
    </div>
    <button
      type="button"
      onclick="history.back()"
      class="btn-back text-decoration-none"
    >
      QUAY LẠI
    </button>
  </div>
</div>

<form id="group-edit-form" enctype="multipart/form-data" class="row g-4">
  <input type="hidden" name="parentName" id="parentNameInput" value="" />

  <div class="col-md-8">
    <div class="card shadow-sm">
      <div class="card-body">
    <ul class="nav nav-tabs-minimal mb-4" id="langTab">
      <li class="nav-item">
        <button class="nav-link active" data-tab-target="#tab-en" type="button">
          ENGLISH
        </button>
      </li>
      <li class="nav-item">
        <button class="nav-link" data-tab-target="#tab-vi" type="button">
          TIẾNG VIỆT
        </button>
      </li>
      <li class="nav-item">
        <button class="nav-link" data-tab-target="#tab-zh" type="button">
          中文 (ZH)
        </button>
      </li>
    </ul>

    <div class="tab-content-minimal mb-5">
      <div class="tab-pane-custom active" id="tab-en">
        <div class="form-group-minimal mb-4">
          <label>TITLE (EN)</label>
          <input
            type="text"
            name="title_en"
            id="title_en"
            value="<%= group.title?.en || '' %>"
            placeholder="Enter English title..."
          />
        </div>
        <div class="form-group-minimal mb-4">
          <label>SUBTITLE (EN)</label>
          <input
            type="text"
            name="subtitle_en"
            id="subtitle_en"
            value="<%= group.subtitle?.en || '' %>"
            placeholder="Enter English subtitle..."
          />
        </div>
      </div>
      <div class="tab-pane-custom" id="tab-vi">
        <div class="form-group-minimal mb-4">
          <label>TIÊU ĐỀ (VI)</label>
          <input
            type="text"
            name="title_vi"
            id="title_vi"
            value="<%= group.title?.vi || '' %>"
            placeholder="Nhập tiêu đề tiếng Việt..."
          />
        </div>
        <div class="form-group-minimal mb-4">
          <label>PHỤ ĐỀ (VI)</label>
          <input
            type="text"
            name="subtitle_vi"
            id="subtitle_vi"
            value="<%= group.subtitle?.vi || '' %>"
            placeholder="Nhập phụ đề tiếng Việt..."
          />
        </div>
      </div>
      <div class="tab-pane-custom" id="tab-zh">
        <div class="form-group-minimal mb-4">
          <label>标题 (ZH)</label>
          <input
            type="text"
            name="title_zh"
            id="title_zh"
            value="<%= group.title?.zh || '' %>"
            placeholder="输入中文标题..."
          />
        </div>
        <div class="form-group-minimal mb-4">
          <label>副标题 (ZH)</label>
          <input
            type="text"
            name="subtitle_zh"
            id="subtitle_zh"
            value="<%= group.subtitle?.zh || '' %>"
            placeholder="输入中文副标题..."
          />
        </div>
      </div>
    </div>

    <div class="content-block border-top pt-4">
      <div class="d-flex align-items-center gap-4 mb-4">
        <div class="d-flex align-items-center gap-2">
          <label for="orderInput" class="form-label mb-0 small">
            Thứ tự:
          </label>
          <input
            type="number"
            name="order"
            id="orderInput"
            class="form-control form-control-sm text-center"
            value="<%= group.order || 0 %>"
            min="0"
            style="width: 70px"
          />
        </div>
        <div class="d-flex align-items-center gap-2">
          <label for="typeSelect" class="form-label mb-0 small">Loại:</label>
          <select name="type" id="typeSelect" class="select-clean-sm">
            <option value="html" <%= group.type === 'html' ? 'selected' : '' %>>HTML Block</option>
            <option value="editor" <%= group.type === 'editor' ? 'selected' : '' %>>Rich Text Editor</option>
          </select>
        </div>
        <label class="label-bronze mb-0 ms-auto">NỘI DUNG CHI TIẾT</label>
      </div>

      <div id="htmlBlock">
        <textarea
          name="content"
          class="form-control-minimal code-font"
          rows="10"
          placeholder="<div>Your HTML here...</div>"
        ><%= group.content || '' %></textarea>
      </div>
      <div id="editorBlock" class="d-none">
        <textarea id="editor"><%= group.content || '' %></textarea>
      </div>
    </div>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <h6 class="card-title text-navy mb-4">
          <i class="fas fa-cogs me-2"></i>THIẾT LẬP
        </h6>

        <div class="form-group-minimal mb-4">
          <label>LIÊN KẾT MENU CHA</label>
          <select
            name="listParents"
            id="parentIdSelect"
            class="form-select"
            multiple
            required
          ></select>
          <small class="text-muted mt-2 d-block">
            Có thể chọn nhiều menu để hiển thị group này.
          </small>
        </div>

        <div class="form-group-minimal mb-4">
          <label>ẢNH ĐẠI DIỆN</label>
          <div class="custom-file-upload">
            <input
              type="file"
              name="image"
              id="imageInput"
              accept="image/*"
            />
            <span class="upload-label">Chọn ảnh hoặc kéo thả vào đây</span>
          </div>
          <% if (group.image) { %>
          <div class="mt-2">
            <img
              src="<%= group.image %>"
              alt="Current image"
              class="img-thumbnail"
              style="max-width: 100px; max-height: 100px;"
            />
          </div>
          <% } %>
        </div>

        <div class="form-group-minimal mb-4">
          <label>TRẠNG THÁI</label>
          <select name="status" id="statusSelect" class="select-clean">
            <option value="active" <%= group.status === 'active' ? 'selected' : '' %>>Hoạt động</option>
            <option value="inactive" <%= group.status === 'inactive' ? 'selected' : '' %>>Không hoạt động</option>
          </select>
        </div>

        <div class="d-grid gap-2">
          <button type="submit" class="btn-save-minimal">
            <i class="fas fa-save me-2"></i>CẬP NHẬT
          </button>
        </div>
      </div>
    </div>
  </div>
</form>

<!-- inline script removed; logic re-inserted below after library includes -->

<link
  href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css"
  rel="stylesheet"
/>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js"></script>

<script>
  $(document).ready(function () {
    const currentMenuId = '<%= currentMenuId || '' %>';
    // TAB SWITCH (jQuery)
    $('.nav-tabs-minimal .nav-link').on('click', function () {
      const target = $(this).attr('data-tab-target');
      $('.nav-tabs-minimal .nav-link').removeClass('active');
      $('.tab-pane-custom').removeClass('active');
      $(this).addClass('active');
      $(target).addClass('active');
    });

    // TYPE / CKEDITOR TOGGLE
    let editor;
    function toggleType(type) {
      $('#htmlBlock').toggleClass('d-none', type === 'editor');
      $('#editorBlock').toggleClass('d-none', type === 'html');
      if (type === 'editor' && !editor) {
        ClassicEditor.create(document.getElementById('editor')).then((e) => {
          editor = e;
          editor.model.document.on('change:data', () => {
            $('[name="content"]').val(editor.getData());
          });
        });
      }
    }
    $('#typeSelect').on('change', function () {
      toggleType(this.value);
    });

    // PARENT SELECT: initialize Select2 and load grouped options
    const parentSelect = $('#parentIdSelect');
    parentSelect.select2({ placeholder: 'Tìm &amp; chọn menu cha...', width: '100%' });

    fetch('/api/menus')
      .then((res) => res.json())
      .then((data) => {
        const menus = data.data || [];
        const groups = {
          top: $('<optgroup label="Header"></optgroup>'),
          bot: $('<optgroup label="Footer"></optgroup>'),
          other: $('<optgroup label="Khác"></optgroup>'),
        };

        menus.forEach((m) => {
          const opt = new Option(m.title?.en || m.title || '-', m._id);
          $(opt).attr('data-title-en', m.title?.en || m.title || '-');
          if (m.type === 'top') groups.top.append(opt);
          else if (m.type === 'bot') groups.bot.append(opt);
          else groups.other.append(opt);
        });

        if (groups.top.children().length) parentSelect.append(groups.top);
        if (groups.bot.children().length) parentSelect.append(groups.bot);
        if (groups.other.children().length) parentSelect.append(groups.other);
        parentSelect.trigger('change');

        // Pre-select based on existing group.listParents
        const groupParents = Array.isArray(<%- JSON.stringify(group.listParents || []) %>) ? <%- JSON.stringify(group.listParents || []) %> : [];
        const selectedIds = groupParents.map((p) => p.parentId);
        if (selectedIds.length) parentSelect.val(selectedIds).trigger('change');

        // Auto set order when parent changes (use first selected)
        parentSelect.on('change', function () {
          const selected = $(this).val();
          if (selected && selected.length > 0) {
            const menuId = selected[0];
            fetch(`/groups/next-order/${menuId}`)
              .then((res) => res.json())
              .then((data) => {
                $('#orderInput').val(data.nextOrder);
              })
              .catch(() => {});
          }
        });
      })
      .catch(() => {});

    // SUBMIT FORM
    $('#group-edit-form').on('submit', function (e) {
      e.preventDefault();
      const form = this;
      const formData = new FormData(form);

      const selectedParents = (parentSelect.val() || []).map((id) => {
        const text = parentSelect.find(`option[value='${id}']`).text();
        return { parentId: id, parentName: text };
      });
      formData.set('listParents', JSON.stringify(selectedParents));

      // images
      const imageInput = document.getElementById('imageInput');
      if (imageInput && imageInput.files.length > 0) {
        for (let i = 0; i < imageInput.files.length; i++) formData.append('images', imageInput.files[i]);
      }

      // buttons (if any)
      const buttonTitles = document.querySelectorAll('input[name="buttonTitle[]"]');
      const buttonUrls = document.querySelectorAll('input[name="buttonUrl[]"]');
      const buttons = [];
      buttonTitles.forEach((titleInput, index) => {
        const urlInput = buttonUrls[index];
        if (titleInput.value && urlInput.value) buttons.push({ label: titleInput.value, action: urlInput.value });
      });
      if (buttons.length) formData.set('listButtons', JSON.stringify(buttons));

      fetch('/groups/<%= group._id %>/update', { method: 'POST', body: formData })
        .then((res) => res.json())
        .then((resp) => {
          console.log('group update response:', resp);
          // Accept multiple server response shapes: { success: true }, object with _id, array, or { data: [...] }
          const isArray = Array.isArray(resp);
          const data = resp && resp.data ? resp.data : resp;
          const isOk = (resp && (resp.success === true || resp.success === 'true')) || (resp && resp._id) || isArray || (Array.isArray(data) && data.length > 0) || (resp && resp.groups);
          if (isOk) {
            console.log('Update success detected, showing toast and redirecting...');
            showToast('Cập nhật thành công');
            setTimeout(() => {
              console.log('Redirecting now...');
              const menuId = currentMenuId;
              const url = menuId ? '/dashboard/groups?menuId=' + menuId : '/dashboard/groups';
              window.location.replace(url);
            }, 500);
          } else {
            console.warn('Update considered failure, server responded:', resp);
            showToast('Cập nhật thất bại', true);
          }
        })
        .catch((err) => {
          console.error('Fetch/update error', err);
          showToast('Cập nhật thất bại — xem console', true);
        });
    });
  });
</script>


