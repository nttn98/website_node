<link rel="stylesheet" href="/css/buttons/edit.css" />

<div class="header-minimal mb-5">
  <div
    class="d-flex justify-content-between align-items-center border-bottom pb-3"
  >
    <div>
      <h4 class="fw-800 text-navy mb-0">EDIT BUTTON</h4>
      <p class="text-muted small mb-0">Update button</p>
    </div>
    <button type="button" onclick="history.back()" class="btn-back">
      BACK
    </button>
  </div>
</div>

<form id="button-edit-form" class="row g-4">
  <div class="col-md-8">
    <div class="card shadow-sm">
      <div class="card-body">
        <div class="mb-4">
          <ul class="nav nav-tabs-minimal mb-3">
            <li class="nav-item">
              <button
                type="button"
                class="nav-link active"
                data-tab-target="#tab-en"
              >
                EN
              </button>
            </li>
            <li class="nav-item">
              <button type="button" class="nav-link" data-tab-target="#tab-vi">
                VI
              </button>
            </li>
            <li class="nav-item">
              <button type="button" class="nav-link" data-tab-target="#tab-zh">
                ZH
              </button>
            </li>
          </ul>

          <div id="tab-en" class="tab-pane-custom active mb-3">
            <label>TITLE (EN)</label>
            <input
              type="text"
              name="title_en"
              class="form-control-minimal"
              value="<%= button.title?.en || '' %>"
              required
            />
          </div>

          <div id="tab-vi" class="tab-pane-custom mb-3">
            <label>TITLE (VI)</label>
            <input
              type="text"
              name="title_vi"
              class="form-control-minimal"
              value="<%= button.title?.vi || '' %>"
            />
          </div>

          <div id="tab-zh" class="tab-pane-custom mb-3">
            <label>TITLE (ZH)</label>
            <input
              type="text"
              name="title_zh"
              class="form-control-minimal"
              value="<%= button.title?.zh || '' %>"
            />
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <div class="form-group-minimal mb-4">
          <label>Type</label>
          <select name="type" id="buttonTypeSelect" class="form-control-minimal">
            <option value="route" <%= (button.type === 'route' || !button.type) ? 'selected' : '' %>>Route / URL</option>
            <option value="form" <%= button.type === 'form' ? 'selected' : '' %>>Open Form</option>
          </select>
        </div>

        <div id="routeField" class="form-group-minimal mb-4">
          <label>Route / URL</label>
          <input
            type="text"
            name="route"
            class="form-control-minimal"
            value="<%= button.route || '' %>"
          />
        </div>

        <div id="formField" class="form-group-minimal mb-4" style="display:none">
          <label>Form</label>
          <select name="formId" id="formSelect" class="form-control-minimal">
            <option value="">-- Select a form --</option>
            <% (forms || []).forEach(function(f){ %>
              <option value="<%= f._id %>" <%= String(button.form?.id || '') === String(f._id) ? 'selected' : '' %>><%= f.title?.en || f.title %></option>
            <% }) %>
          </select>
        </div>

        <div class="d-grid gap-2">
          <button type="submit" class="btn-save-minimal">UPDATE</button>
        </div>
      </div>
    </div>
  </div>
</form>

<script>
  $(document).ready(function () {
    $(".nav-tabs-minimal .nav-link").on("click", function () {
      const target = $(this).attr("data-tab-target");
      $(".nav-tabs-minimal .nav-link").removeClass("active");
      $(".tab-pane-custom").removeClass("active");
      $(this).addClass("active");
      $(target).addClass("active");
    });

    // load groups is no longer needed since groups are passed from server
    // but keep for backward compatibility if needed

    $("#button-edit-form").on("submit", function (e) {
      e.preventDefault();
      const title_en = $(this).find('[name="title_en"]').val().trim();
      const title_vi = $(this).find('[name="title_vi"]').val().trim();
      const title_zh = $(this).find('[name="title_zh"]').val().trim();
      if (!title_en) return showToast("Title (EN) is required", true);
      const type = $(this).find('[name="type"]').val();
      const route = $(this).find('[name="route"]').val().trim();
      const formId = $(this).find('[name="formId"]').val() || null;
       const payload = { title_en, title_vi, title_zh, route, type, formId };

      fetch("/buttons/<%= button._id %>/update", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      })
        .then((r) => r.json())
        .then((resp) => {
          console.log("Update response", resp);
          if (resp.success) {
            showToast("Updated");
            setTimeout(() => (location.href = "/dashboard/buttons"), 400);
          } else showToast(resp.message || "Update failed", true);
        })
        .catch((err) => {
          console.error("Update error", err);
          showToast("Update failed", true);
        });
    });

    // toggle fields based on type
    (function initTypeToggle() {
      const t = $('#buttonTypeSelect').val();
      if (t === 'form') {
        $('#routeField').hide();
        $('#formField').show();
      } else {
        $('#routeField').show();
        $('#formField').hide();
      }
    })();

    $(document).on('change', '#buttonTypeSelect', function() {
      const t = $(this).val();
      if (t === 'form') {
        $('#routeField').hide();
        $('#formField').show();
      } else {
        $('#routeField').show();
        $('#formField').hide();
      }
    });
  });
</script>
