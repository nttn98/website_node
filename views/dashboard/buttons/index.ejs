<link rel="stylesheet" href="/css/buttons/index.css" />

<div class="header-minimal mb-5">
  <div
    class="d-flex justify-content-between align-items-center border-bottom pb-3"
  >
    <div>
      <h4 class="fw-800 text-navy mb-0">BUTTONS</h4>
      <p class="text-muted small mb-0">
        Manage action buttons linked to groups
      </p>
    </div>
    <a href="/dashboard/buttons/create" class="btn-ui-main">+ ADD BUTTON</a>
  </div>
</div>

<div class="d-flex justify-content-between align-items-end gap-3 mb-3">
  <div
    class="search-wrap flex-grow-1"
    style="max-width: 340px; position: relative"
  >
    <i
      class="bi bi-search"
      style="
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #999;
        font-size: 0.9rem;
      "
    ></i>
    <input
      id="buttonSearchInput"
      type="search"
      placeholder="Search by title..."
      class="search-input"
      style="
        width: 100%;
        padding: 10px 16px 10px 36px;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-size: 0.9rem;
        outline: none;
      "
    />
  </div>
  <div class="limit-wrap d-flex align-items-center gap-2">
    <label
      for="buttonPageLimitSelect"
      style="font-size: 0.85rem; color: #666; margin: 0"
    >
      Show:
    </label>
    <select
      id="buttonPageLimitSelect"
      class="form-select-minimal"
      style="
        padding: 8px 12px;
        border: 1px solid #ddd;
        border-radius: 6px;
        font-size: 0.9rem;
        outline: none;
      "
    >
      <option value="5" selected>5</option>
      <option value="10">10</option>
      <option value="25">25</option>
      <option value="50">50</option>
    </select>
  </div>
</div>

<div class="table-container-minimal">
  <table class="table-clean">
    <thead>
      <tr>
        <th>Title</th>
        <th>Route</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody id="button-list-body"></tbody>
  </table>
</div>

<div
  id="button-pagination-controls"
  class="pagination-controls mt-3"
  style="display: none; text-align: center"
></div>

<script>
  let currentPage = 1;
  let currentLimit = 5;
  let totalPages = 1;
  let totalItems = 0;

  function renderPagination() {
    const paginationDiv = document.getElementById("button-pagination-controls");
    if (totalPages <= 1) {
      paginationDiv.style.display = "none";
      return;
    }

    paginationDiv.style.display = "block";
    let paginationHtml = `<div style="display: flex; justify-content: center; align-items: center; gap: 6px; flex-wrap: wrap;">`;

    if (currentPage > 1) {
      paginationHtml += `<button class="pagination-btn" onclick="goToPage(1)" style="padding: 6px 10px; border: 1px solid #ddd; border-radius: 4px; background: #fff; cursor: pointer; transition: 0.2s;">« First</button>`;
      paginationHtml += `<button class="pagination-btn" onclick="goToPage(${
        currentPage - 1
      })" style="padding: 6px 10px; border: 1px solid #ddd; border-radius: 4px; background: #fff; cursor: pointer; transition: 0.2s;">‹ Prev</button>`;
    }

    const startPage = Math.max(1, currentPage - 2);
    const endPage = Math.min(totalPages, currentPage + 2);

    for (let i = startPage; i <= endPage; i++) {
      const isActive = i === currentPage;
      const btnStyle = isActive
        ? "background: var(--ui-navy); color: var(--ui-bronze); font-weight: 700;"
        : "background: #fff; color: #333;";
      paginationHtml += `<button class="pagination-btn" onclick="goToPage(${i})" style="padding: 6px 12px; border: 1px solid #ddd; border-radius: 4px; ${btnStyle} cursor: pointer; transition: 0.2s;">${i}</button>`;
    }

    if (currentPage < totalPages) {
      paginationHtml += `<button class="pagination-btn" onclick="goToPage(${
        currentPage + 1
      })" style="padding: 6px 10px; border: 1px solid #ddd; border-radius: 4px; background: #fff; cursor: pointer; transition: 0.2s;">Next ›</button>`;
      paginationHtml += `<button class="pagination-btn" onclick="goToPage(${totalPages})" style="padding: 6px 10px; border: 1px solid #ddd; border-radius: 4px; background: #fff; cursor: pointer; transition: 0.2s;">Last »</button>`;
    }

    paginationHtml += `<span style="margin-left: 16px; font-size: 0.85rem; color: #666;">Page ${currentPage}/${totalPages}</span>`;
    paginationHtml += `</div>`;
    paginationDiv.innerHTML = paginationHtml;
  }

  function goToPage(page) {
    currentPage = page;
    fetchButtons();
  }

  async function fetchButtons() {
    const search = document.getElementById("buttonSearchInput")?.value || "";
    const params = new URLSearchParams();
    if (search) params.append("search", search);
    params.append("page", currentPage);
    params.append("limit", currentLimit);

    const res = await fetch(`/buttons?${params.toString()}`);
    const data = await res.json();
    const tbody = document.getElementById("button-list-body");

    if (!data.buttons || !data.buttons.length) {
      tbody.innerHTML = `<tr><td colspan="4" class="text-center p-5 text-muted">No buttons found.</td></tr>`;
      document.getElementById("button-pagination-controls").style.display =
        "none";
      return;
    }

    tbody.innerHTML = "";
    const pagination = data.pagination || {};
    currentPage = pagination.page || 1;
    totalPages = pagination.totalPages || 1;
    totalItems = pagination.total || 0;

    (data.buttons || []).forEach((b) => {
      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td>${b.title?.en || ""}</td>
        <td>${
          b.type === "form"
            ? b.form?.id?.title?.en || b.form?.id?.title || "Form"
            : b.route || ""
        }</td>
        <td><span class="badge-minimal ${b.isStatus ? "badge-active" : ""}">${
        b.isStatus ? "SHOW" : "HIDE"
      }</span></td>
        <td class="text-end">
          <button class="action-circle" onclick="toggleButtonStatus('${
            b._id
          }', this)" title="Toggle status">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </button>
          <a class="action-circle" href="/dashboard/buttons/${
            b._id
          }/edit" title="Edit">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7M18.5 2.5a2.121 2.121 0 113 3L12 15l-4 1 1-4 9.5-9.5z"></path>
            </svg>
          </a>
          <button class="action-circle btn-del" onclick="deleteButton('${
            b._id
          }')" title="Delete">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
            </svg>
          </button>
        </td>
      `;
      tbody.appendChild(tr);
    });

    renderPagination();
  }

  async function deleteButton(id) {
    if (!confirm("Delete this button?")) return;
    await fetch("/buttons/" + id, { method: "DELETE" });
    currentPage = 1;
    fetchButtons();
  }

  async function toggleButtonStatus(id, btn) {
    await fetch(`/buttons/${id}/toggle`, { method: "POST" });
    fetchButtons();
  }

  document
    .getElementById("buttonSearchInput")
    ?.addEventListener("input", () => {
      currentPage = 1;
      fetchButtons();
    });

  document
    .getElementById("buttonPageLimitSelect")
    ?.addEventListener("change", (e) => {
      currentLimit = parseInt(e.target.value, 10);
      currentPage = 1;
      fetchButtons();
    });

  fetchButtons();
</script>
