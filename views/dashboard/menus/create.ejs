<link rel="stylesheet" href="/css/menus/create.css" />

<div class="header-minimal mb-5">
  <div
    class="d-flex justify-content-between align-items-center border-bottom pb-3"
  >
    <div>
      <h4 class="fw-800 text-navy mb-0">HỆ THỐNG MENU</h4>
      <p class="text-muted small mb-0">Cấu trúc danh mục hệ thống</p>
    </div>
    <a href="/dashboard/menus" class="btn-back">QUAY LẠI</a>
  </div>
</div>

<form id="menu-create-form" class="row">
  <div class="col-md-7">
    <div class="form-group-minimal mb-4">
      <label>TIÊU ĐỀ (EN)</label>
      <input type="text" name="title" placeholder="Nhập tên menu..." required />
    </div>

    <div class="form-group-minimal mb-4">
      <label>ĐƯỜNG DẪN (ROUTE)</label>
      <input type="text" name="route" placeholder="/duong-dan" />
    </div>

    <div class="row">
      <div class="col-6">
        <div class="form-group-minimal mb-4">
          <label>VỊ TRÍ</label>
          <select name="type" id="typeSelect">
            <option value="top">Header Menu</option>
            <option value="bot">Footer Menu</option>
          </select>
        </div>
      </div>
      <div class="col-6">
        <div class="form-group-minimal mb-4">
          <label>THỨ TỰ</label>
          <input type="number" name="order" value="0" />
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-5 ps-md-5">
    <div class="form-group-minimal mb-4">
      <label>DANH MỤC CHA</label>
      <select name="parentId" id="parentId">
        <option value="">-- Menu gốc --</option>
        <optgroup label="Top" id="topMenuGroup"></optgroup>
        <optgroup label="Footer" id="botMenuGroup"></optgroup>
      </select>
    </div>

    <div class="switch-card mb-5">
      <div class="d-flex justify-content-between">
        <span class="fw-700 small text-navy">HIỂN THỊ DẠNG NÚT</span>
        <div class="form-check form-switch">
          <input
            class="form-check-input"
            type="checkbox"
            name="isButton"
            id="isButton"
          />
        </div>
      </div>
    </div>

    <button type="submit" class="btn-save-minimal">LƯU CẤU HÌNH</button>
  </div>
</form>

<script>
  // 1. Fetch & Render Parent Options
  fetch("/api/menus")
    .then((res) => res.json())
    .then((data) => {
      const topGroup = document.getElementById("topMenuGroup");
      const botGroup = document.getElementById("botMenuGroup");

      // Xóa trắng nội dung cũ trước khi render (đề phòng)
      topGroup.innerHTML = "";
      botGroup.innerHTML = "";

      // Kiểm tra dữ liệu và lặp
      const menus = data.data || data; // Hỗ trợ cả 2 định dạng trả về

      menus.forEach((m) => {
        // Chỉ những menu nào không có parentId thì mới được làm Menu Cha
        if (!m.parentId) {
          const opt = document.createElement("option");
          opt.value = m._id;
          opt.textContent = `↳ ${m.title?.en || m.title || "No Title"}`;
          opt.dataset.type = m.type;

          if (m.type === "top") {
            topGroup.appendChild(opt);
          } else {
            botGroup.appendChild(opt);
          }
        }
      });

      console.log("Đã render danh mục cha thành công.");
    })
    .catch((err) => console.error("Lỗi khi load danh mục cha:", err));

  // 2. Auto-logic cho Parent/Type (Giữ nguyên)
  document.getElementById("parentId").addEventListener("change", function () {
    const selectedOption = this.options[this.selectedIndex];
    const parentType = selectedOption.dataset.type;
    const typeSelect = document.getElementById("typeSelect");

    if (this.value && parentType) {
      typeSelect.value = parentType;
      typeSelect.style.pointerEvents = "none";
      typeSelect.style.opacity = "0.5";
    } else {
      typeSelect.style.pointerEvents = "auto";
      typeSelect.style.opacity = "1";
    }
  });

  // 3. Submit Form (Giữ nguyên)
  document
    .getElementById("menu-create-form")
    .addEventListener("submit", function (e) {
      e.preventDefault();
      const formData = new FormData(this);
      const data = Object.fromEntries(formData.entries());
      data.isButton = document.getElementById("isButton").checked;

      fetch("/api/menus", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      })
        .then((res) => res.json())
        .then((resp) => {
          if (resp.success) window.location.href = "/dashboard/menus";
          else alert("Lưu thất bại!");
        });
    });
</script>
