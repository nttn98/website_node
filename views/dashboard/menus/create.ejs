<link rel="stylesheet" href="/css/menus/create.css" />

<div class="header-minimal mb-5">
  <div
    class="d-flex justify-content-between align-items-center border-bottom pb-3"
  >
    <div>
      <h4 class="fw-800 text-navy mb-0">MENU SYSTEM</h4>
      <p class="text-muted small mb-0">Site menu structure</p>
    </div>
    <a href="/dashboard/menus" class="btn-back">BACK</a>
  </div>
</div>

<form id="menu-create-form" class="row">
  <div class="col-md-7">
    <div class="form-group-minimal mb-4">
      <label>TITLE (EN)</label>
      <input
        type="text"
        name="title"
        placeholder="Enter menu name..."
        required
      />
    </div>

    <div class="form-group-minimal mb-4">
      <label>SUBTITLE (EN)</label>
      <input type="text" name="subtitle" placeholder="Enter subtitle" />
    </div>

    <div class="form-group-minimal mb-4">
      <label>ROUTE</label>
      <input type="text" name="route" placeholder="/path-name" />
    </div>

    <div class="form-group-minimal mb-4">
      <label>TAGS</label>
      <select name="tagId" id="tagIdSelect" class="tag-select">
        <option value="">-- No tag --</option>
      </select>
      <small class="text-muted d-block mt-1"></small>
        Choose one tag to attach this menu.
      </small>
    </div>

    <div class="row">
      <div class="col-6">
        <div class="form-group-minimal mb-4">
          <label>POSITION</label>
          <select name="type" id="typeSelect">
            <option value="top">Header Menu</option>
            <option value="bot">Footer Menu</option>
          </select>
        </div>
      </div>
      <div class="col-6">
        <div class="form-group-minimal mb-4">
          <label>Order</label>
          <input type="number" name="order" value="0" />
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-5 ps-md-5">
    <div class="form-group-minimal mb-4">
      <label>Feature Image</label>
      <div class="custom-file-upload">
        <input type="file" name="image" id="imageInput" accept="image/*" />
        <span class="upload-label">Choose image or drag & drop here</span>
      </div>
      <div id="imagePreviewList" class="d-flex flex-wrap mt-3 gap-2"></div>
    </div>

    <div class="form-group-minimal mb-4">
      <label>Parent Menu</label>
      <select name="parentId" id="parentId">
        <option value="">-- Root Menu --</option>
        <optgroup label="Top" id="topMenuGroup"></optgroup>
        <optgroup label="Footer" id="botMenuGroup"></optgroup>
      </select>
    </div>

    <div class="switch-card mb-3" id="showHomePageCard" style="display: none">
      <div class="d-flex justify-content-between">
        <span class="fw-700 small text-navy">SHOW ON HOMEPAGE</span>
        <div class="form-check form-switch">
          <input
            class="form-check-input"
            type="checkbox"
            name="showHomePage"
            id="showHomePage"
          />
        </div>
      </div>
    </div>

    <div class="switch-card mb-3" id="showFooterCard" style="display: none">
      <div class="d-flex justify-content-between">
        <span class="fw-700 small text-navy">SHOW ON FOOTER</span>
        <div class="form-check form-switch">
          <input
            class="form-check-input"
            type="checkbox"
            name="showFooter"
            id="showFooter"
          />
        </div>
      </div>
    </div>

    <div
      class="switch-card mb-3"
      id="featuredInsightsCard"
      style="display: none"
    >
      <div class="d-flex justify-content-between">
        <span class="fw-700 small text-navy">FEATURED INSIGHTS</span>
        <div>
          <input
            type="checkbox"
            name="featuredInsights"
            id="featuredInsights"
            style="display: none"
          />
          <button
            type="button"
            class="featured-star-btn"
            id="featuredInsightsStar"
            aria-label="Toggle Featured Insights"
            aria-pressed="false"
          >
            ☆
          </button>
        </div>
      </div>
    </div>

    <div class="switch-card mb-3" id="caseStudiesCard" style="display: none">
      <div class="d-flex justify-content-between">
        <span class="fw-700 small text-navy">CASE STUDIES</span>
        <div>
          <input
            type="checkbox"
            name="caseStudies"
            id="caseStudies"
            style="display: none"
          />
          <button
            type="button"
            class="featured-star-btn"
            id="caseStudiesStar"
            aria-label="Toggle Case Studies"
            aria-pressed="false"
          >
            ☆
          </button>
        </div>
      </div>
    </div>

    <div class="switch-card mb-5">
      <div class="d-flex justify-content-between">
        <span class="fw-700 small text-navy">DISPLAY AS BUTTON</span>
        <div class="form-check form-switch">
          <input
            class="form-check-input"
            type="checkbox"
            name="isButton"
            id="isButton"
          />
        </div>
      </div>
    </div>

    <button type="submit" class="btn-save-minimal">SAVE MENU</button>
  </div>
</form>

<script>
  const INSIGHTS_PARENT_ID = "698191a46ea27a5d8ccbf724";

  function notify(message, isError = false) {
    if (typeof window.showToast === "function") {
      window.showToast(message, isError);
      return;
    }
    window.alert(message);
  }

  // 1. Fetch & Render Parent Options
  fetch("/api/menus")
    .then((res) => res.json())
    .then((data) => {
      const topGroup = document.getElementById("topMenuGroup");
      const botGroup = document.getElementById("botMenuGroup");

      // Xóa trắng nội dung cũ trước khi render (đề phòng)
      topGroup.innerHTML = "";
      botGroup.innerHTML = "";

      // Kiểm tra dữ liệu và lặp
      const menus = data.data || data; // Hỗ trợ cả 2 định dạng trả về

      menus.forEach((m) => {
        // Chỉ những menu nào không có parentId thì mới được làm Menu Cha
        if (!m.parentId) {
          const opt = document.createElement("option");
          opt.value = m._id;
          opt.textContent = `↳ ${m.title?.en || m.title || "No Title"}`;
          opt.dataset.type = m.type;

          if (m.type === "top") {
            topGroup.appendChild(opt);
          } else {
            botGroup.appendChild(opt);
          }
        }
      });

      console.log("Parent categories rendered.");
    })
    .catch((err) => console.error("Failed to load parent categories:", err));

  // Load tags from database and render dropdown options
  fetch("/api/tags?limit=300&targetType=menu")
    .then((res) => res.json())
    .then((resp) => {
      const tagSelect = document.getElementById("tagIdSelect");
      if (!tagSelect) return;

      const tags = Array.isArray(resp.data) ? resp.data : [];
      tagSelect.innerHTML = '<option value="">-- No tag --</option>';

      if (!tags.length) {
        return;
      }

      tags.forEach((tag) => {
        const opt = document.createElement("option");
        opt.value = tag._id || "";
        opt.textContent = tag.name || tag.slug || "Unnamed tag";
        tagSelect.appendChild(opt);
      });
    })
    .catch((err) => {
      console.error("Failed to load tags:", err);
      const tagSelect = document.getElementById("tagIdSelect");
      if (tagSelect) {
        tagSelect.innerHTML = '<option value="">-- No tag --</option>';
      }
    });

  // 2. Auto-logic cho Parent/Type
  document.getElementById("parentId").addEventListener("change", function () {
    const selectedOption = this.options[this.selectedIndex];
    const parentType = selectedOption.dataset.type;
    const typeSelect = document.getElementById("typeSelect");
    const showHomePageCard = document.getElementById("showHomePageCard");
    const showFooterCard = document.getElementById("showFooterCard");
    const featuredInsightsCard = document.getElementById(
      "featuredInsightsCard"
    );
    const featuredInsightsCheckbox =
      document.getElementById("featuredInsights");
    const featuredInsightsStar = document.getElementById(
      "featuredInsightsStar"
    );
    const caseStudiesCard = document.getElementById("caseStudiesCard");
    const caseStudiesCheckbox = document.getElementById("caseStudies");
    const caseStudiesStar = document.getElementById("caseStudiesStar");
    const isInsightsMenu = this.value === INSIGHTS_PARENT_ID;

    if (this.value && parentType) {
      typeSelect.value = parentType;
      typeSelect.style.pointerEvents = "none";
      typeSelect.style.opacity = "0.5";
      // Show homepage toggle only if parent is selected
      showHomePageCard.style.display = "block";
      showFooterCard.style.display = "block";
    } else {
      typeSelect.style.pointerEvents = "auto";
      typeSelect.style.opacity = "1";
      // Hide homepage toggle if no parent selected (root menu)
      showHomePageCard.style.display = "none";
      showFooterCard.style.display = "none";
      document.getElementById("showHomePage").checked = false;
      document.getElementById("showFooter").checked = false;
    }

    featuredInsightsCard.style.display = isInsightsMenu ? "block" : "none";
    if (!isInsightsMenu) {
      featuredInsightsCheckbox.checked = false;
    }
    featuredInsightsStar.classList.toggle(
      "active",
      featuredInsightsCheckbox.checked
    );
    featuredInsightsStar.textContent = featuredInsightsCheckbox.checked
      ? "★"
      : "☆";
    featuredInsightsStar.setAttribute(
      "aria-pressed",
      featuredInsightsCheckbox.checked ? "true" : "false"
    );

    caseStudiesCard.style.display = isInsightsMenu ? "block" : "none";
    if (!isInsightsMenu) {
      caseStudiesCheckbox.checked = false;
    }
    caseStudiesStar.classList.toggle("active", caseStudiesCheckbox.checked);
    caseStudiesStar.textContent = caseStudiesCheckbox.checked ? "★" : "☆";
    caseStudiesStar.setAttribute(
      "aria-pressed",
      caseStudiesCheckbox.checked ? "true" : "false"
    );
  });

  const featuredInsightsCheckbox = document.getElementById("featuredInsights");
  const featuredInsightsStar = document.getElementById("featuredInsightsStar");
  featuredInsightsStar.addEventListener("click", function () {
    if (document.getElementById("parentId").value !== INSIGHTS_PARENT_ID) {
      return;
    }
    featuredInsightsCheckbox.checked = !featuredInsightsCheckbox.checked;
    featuredInsightsStar.classList.toggle(
      "active",
      featuredInsightsCheckbox.checked
    );
    featuredInsightsStar.textContent = featuredInsightsCheckbox.checked
      ? "★"
      : "☆";
    featuredInsightsStar.setAttribute(
      "aria-pressed",
      featuredInsightsCheckbox.checked ? "true" : "false"
    );

    if (featuredInsightsCheckbox.checked) {
      const caseStudiesCheckbox = document.getElementById("caseStudies");
      const caseStudiesStar = document.getElementById("caseStudiesStar");
      caseStudiesCheckbox.checked = false;
      caseStudiesStar.classList.remove("active");
      caseStudiesStar.textContent = "☆";
      caseStudiesStar.setAttribute("aria-pressed", "false");
    }
  });

  const caseStudiesCheckbox = document.getElementById("caseStudies");
  const caseStudiesStar = document.getElementById("caseStudiesStar");
  caseStudiesStar.addEventListener("click", function () {
    if (document.getElementById("parentId").value !== INSIGHTS_PARENT_ID) {
      return;
    }
    caseStudiesCheckbox.checked = !caseStudiesCheckbox.checked;
    caseStudiesStar.classList.toggle("active", caseStudiesCheckbox.checked);
    caseStudiesStar.textContent = caseStudiesCheckbox.checked ? "★" : "☆";
    caseStudiesStar.setAttribute(
      "aria-pressed",
      caseStudiesCheckbox.checked ? "true" : "false"
    );

    if (caseStudiesCheckbox.checked) {
      const featuredInsightsCheckbox = document.getElementById(
        "featuredInsights"
      );
      const featuredInsightsStar = document.getElementById(
        "featuredInsightsStar"
      );
      featuredInsightsCheckbox.checked = false;
      featuredInsightsStar.classList.remove("active");
      featuredInsightsStar.textContent = "☆";
      featuredInsightsStar.setAttribute("aria-pressed", "false");
    }
  });

  // 3. Image Preview
  document.getElementById("imageInput").addEventListener("change", function () {
    const preview = document.getElementById("imagePreviewList");
    preview.innerHTML = "";
    if (this.files && this.files[0]) {
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = `<img src="${e.target.result}" style="width: 80px; height: 60px; object-fit: cover; border-radius: 4px; border: 1px solid #ddd;">`;
        preview.insertAdjacentHTML("beforeend", img);
      };
      reader.readAsDataURL(this.files[0]);
    }
  });

  // 4. Submit Form
  document
    .getElementById("menu-create-form")
    .addEventListener("submit", function (e) {
      e.preventDefault();
      const formData = new FormData(this);
      formData.set("isButton", document.getElementById("isButton").checked);
      formData.set(
        "showHomePage",
        document.getElementById("showHomePage").checked
      );
      formData.set(
        "showFooter",
        document.getElementById("showFooter").checked
      );
      formData.set(
        "featuredInsights",
        document.getElementById("parentId").value === INSIGHTS_PARENT_ID &&
          document.getElementById("featuredInsights").checked
      );
      formData.set(
        "caseStudies",
        document.getElementById("parentId").value === INSIGHTS_PARENT_ID &&
          document.getElementById("caseStudies").checked
      );

      console.log(
        "Form data - isButton:",
        document.getElementById("isButton").checked
      );
      console.log(
        "Form data - showHomePage:",
        document.getElementById("showHomePage").checked
      );
      console.log(
        "Form data - showFooter:",
        document.getElementById("showFooter").checked
      );
      console.log(
        "Form data - parentId:",
        document.getElementById("parentId").value
      );
      console.log(
        "Form data - featuredInsights:",
        document.getElementById("featuredInsights").checked
      );

      fetch("/api/menus", {
        method: "POST",
        body: formData,
      })
        .then((res) => res.json())
        .then((resp) => {
          console.log("Create response:", resp);
          if (resp.success) {
            if (typeof window.redirectWithToast === "function") {
              window.redirectWithToast(
                "/dashboard/menus",
                "Menu created successfully"
              );
            } else {
              notify("Menu created successfully");
              setTimeout(() => {
                window.location.href = "/dashboard/menus";
              }, 350);
            }
          } else {
            notify("Save failed: " + (resp.message || "Unknown error"), true);
          }
        })
        .catch((err) => {
          console.error("Create menu error", err);
          notify("Save failed — see console", true);
        });
    });
</script>
