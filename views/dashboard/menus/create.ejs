<h4 class="mb-4">Create Menu</h4>

<form id="menu-create-form">
  <!-- TITLE -->
  <div class="mb-3">
    <label class="form-label">Title (EN)</label>
    <input type="text" name="title" class="form-control" required />
  </div>

  <!-- ROUTE -->
  <div class="mb-3">
    <label class="form-label">Route</label>
    <input type="text" name="route" class="form-control" placeholder="/about" />
  </div>

  <!-- PARENT MENU -->
  <div class="mb-3">
    <label class="form-label">Parent Menu (optional)</label>
    <select name="parentId" id="parentId" class="form-select">
      <option value="">-- None --</option>
      <optgroup label="Top menu" id="topMenuGroup"></optgroup>
      <optgroup label="Footer menu" id="botMenuGroup"></optgroup>
    </select>
  </div>

  <!-- TYPE -->
  <div class="mb-3">
    <label class="form-label">Type</label>
    <select name="type" id="typeSelect" class="form-select" required>
      <option value="top">Top menu</option>
      <option value="bot">Footer menu</option>
    </select>
  </div>

  <!-- ORDER -->
  <div class="mb-3">
    <label class="form-label">Order</label>
    <input type="number" name="order" class="form-control" value="0" />
  </div>

  <!-- IS BUTTON -->
  <div class="form-check mb-3">
    <input
      type="checkbox"
      name="isButton"
      class="form-check-input"
      id="isButton"
    />
    <label for="isButton" class="form-check-label">Display as button</label>
  </div>

  <!-- SUBMIT -->

  <button class="btn btn-primary" type="submit">Save</button>
  <a href="/dashboard/menus" class="btn btn-secondary ms-2">Cancel</a>
</form>

<script>
  // Lấy danh sách menu cho select parent
  fetch("/api/menus")
    .then((res) => res.json())
    .then((data) => {
      const menus = data.data || [];
      const topGroup = document.getElementById("topMenuGroup");
      const botGroup = document.getElementById("botMenuGroup");
      if (topGroup) topGroup.innerHTML = "";
      if (botGroup) botGroup.innerHTML = "";
      menus.forEach((menu) => {
        const opt = document.createElement("option");
        opt.value = menu._id;
        opt.setAttribute("data-type", menu.type);
        opt.textContent = menu.title?.en || menu.title || "-";
        if (menu.type === "top") topGroup.appendChild(opt);
        else if (menu.type === "bot") botGroup.appendChild(opt);
      });
    });

  // Submit form bằng fetch
  document
    .getElementById("menu-create-form")
    .addEventListener("submit", function (e) {
      e.preventDefault();
      const form = e.target;
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      if (!data.title) return alert("Title is required");
      fetch("/api/menus", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      })
        .then((res) => res.json())
        .then((resp) => {
          if (resp.success) window.location.href = "/dashboard/menus";
          else alert("Create failed");
        })
        .catch(() => alert("Create failed"));
    });
</script>

<script>
  // Auto-set type if parent selected, else allow user to pick
  const parentSelect = document.getElementById("parentId");
  const typeSelect = document.getElementById("typeSelect");
  parentSelect.addEventListener("change", function () {
    const selected = parentSelect.options[parentSelect.selectedIndex];
    const parentType = selected.getAttribute("data-type");
    if (parentSelect.value && parentType) {
      typeSelect.value = parentType;
      typeSelect.setAttribute("readonly", "readonly");
      typeSelect.setAttribute("disabled", "disabled");
    } else {
      typeSelect.removeAttribute("readonly");
      typeSelect.removeAttribute("disabled");
    }
  });
</script>
