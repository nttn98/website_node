<link rel="stylesheet" href="/css/menus/index.css" />

<div class="d-flex justify-content-between align-items-end mb-4">
  <div>
    <h4 class="fw-800 mb-1" style="color: var(--ui-navy); letter-spacing: -1px">
      MENU SYSTEM
    </h4>
    <div class="d-flex align-items-center gap-2">
      <p class="small text-muted mb-0">Manage site menu structure</p>
    </div>
  </div>

  <a href="/dashboard/menus/create" class="btn-ui-main">
    <span class="plus-symbol">+</span>
    ADD MENU
  </a>
</div>

<div class="menu-filter-bar mb-3">
  <div class="menu-filter-item grow"></div>
  <div class="menu-filter-item">
    <select id="parentFilterSelect" class="menu-filter-select">
      <option value="all">All Parent Menus</option>
      <option value="root">Root Menus Only</option>
    </select>
  </div>
</div>

<div id="menu-list" class="table-container-minimal"></div>

<script>
  const INSIGHTS_PARENT_ID = "698191a46ea27a5d8ccbf724";
  let allMenusData = [];

  function notify(message, isError = false) {
    if (typeof window.showToast === "function") {
      window.showToast(message, isError);
      return;
    }
    window.alert(message);
  }

  function sortByCreatedAtThenOrder(a, b) {
    const aTime = Date.parse(a?.createdAt) || 0;
    const bTime = Date.parse(b?.createdAt) || 0;
    if (bTime !== aTime) return bTime - aTime;
    return (a.order || 0) - (b.order || 0);
  }

  function renderMenus(menus) {
    const listContainer = document.getElementById("menu-list");
    if (!menus || !menus.length) {
      listContainer.innerHTML = `<div class="p-5 text-center text-muted">No data available</div>`;
      return;
    }

    // Tách menu theo type (top/footer) và sắp xếp theo order
    const topMenus = menus
      .filter((m) => !m.parentId && m.type === "top")
      .sort((a, b) => (a.order || 0) - (b.order || 0));
    const botMenus = menus
      .filter((m) => !m.parentId && m.type === "bot")
      .sort((a, b) => (a.order || 0) - (b.order || 0));

    let html = "";

    // Render TOP MENUS
    if (topMenus.length) {
      html += `<div class="menu-section">
        <h5 class="menu-section-heading">TOP NAVIGATION</h5>
        <table class="table-clean">
          <thead>
            <tr>
              <th width="30%">Details</th>
              <th width="10%" class="text-center">Order</th>
              <th width="14%">Parent</th>
              <th width="10%" class="text-center">Homepage</th>
              <th width="12%" class="text-center">Featured Insights</th>
              <th width="10%" class="text-center">Status</th>
              <th width="14%" class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>`;

      topMenus.forEach((menu) => {
        const hasChildren = menus.some(
          (m) => m.parentId && m.parentId.toString() === menu._id.toString()
        );
        html += renderMenuRow(menu, menus, true, hasChildren);
        if (hasChildren) {
          const children = menus
            .filter(
              (c) => c.parentId && c.parentId.toString() === menu._id.toString()
            )
            .sort(sortByCreatedAtThenOrder);
          children.forEach((child) => {
            html += renderMenuRow(child, menus, false, false);
          });
        }
      });

      html += `</tbody></table></div>`;
    }

    // Render FOOTER MENUS
    if (botMenus.length) {
      html += `<div class="menu-section">
        <h5 class="menu-section-heading">FOOTER NAVIGATION</h5>
        <table class="table-clean">
          <thead>
            <tr>
              <th width="30%">Details</th>
              <th width="10%" class="text-center">Order</th>
              <th width="14%">Parent</th>
              <th width="10%" class="text-center">Homepage</th>
              <th width="12%" class="text-center">Featured Insights</th>
              <th width="10%" class="text-center">Status</th>
              <th width="14%" class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>`;

      botMenus.forEach((menu) => {
        const hasChildren = menus.some(
          (m) => m.parentId && m.parentId.toString() === menu._id.toString()
        );
        html += renderMenuRow(menu, menus, true, hasChildren);
        if (hasChildren) {
          const children = menus
            .filter(
              (c) => c.parentId && c.parentId.toString() === menu._id.toString()
            )
            .sort(sortByCreatedAtThenOrder);
          children.forEach((child) => {
            html += renderMenuRow(child, menus, false, false);
          });
        }
      });

      html += `</tbody></table></div>`;
    }

    listContainer.innerHTML = html;
  }

  function normalizeText(value) {
    return String(value || "").toLowerCase();
  }

  function setupParentFilterOptions(menus) {
    const parentSelect = document.getElementById("parentFilterSelect");
    const roots = (menus || [])
      .filter((m) => !m.parentId)
      .sort((a, b) => (a.order || 0) - (b.order || 0));

    const dynamicOptions = roots
      .map((m) => {
        const label = m.title?.en || m.title || "No Title";
        return `<option value="${m._id}">${label}</option>`;
      })
      .join("");

    parentSelect.innerHTML = `
      <option value="all">All Parent Menus</option>
      <option value="root">Root Menus Only</option>
      ${dynamicOptions}
    `;
  }

  function applyFilters() {
    const searchValue = normalizeText(
      document.getElementById("menuSearchInput")?.value
    );
    const parentValue = document.getElementById("parentFilterSelect")?.value;

    let filtered = [...allMenusData];

    if (parentValue === "root") {
      filtered = filtered.filter((m) => !m.parentId);
    } else if (parentValue && parentValue !== "all") {
      filtered = filtered.filter(
        (m) =>
          String(m._id) === parentValue ||
          String(m.parentId || "") === parentValue
      );
    }

    if (searchValue) {
      const matchedIds = new Set();
      const byId = new Map(filtered.map((m) => [String(m._id), m]));

      filtered.forEach((m) => {
        const haystack = [
          m.title?.en,
          m.title?.vi,
          m.title?.zh,
          m.subTitle?.en,
          m.subTitle?.vi,
          m.subTitle?.zh,
          m.route,
          m.tagName,
          m.parentName,
        ]
          .map(normalizeText)
          .join(" ");

        if (haystack.includes(searchValue)) {
          matchedIds.add(String(m._id));
          if (m.parentId && byId.has(String(m.parentId))) {
            matchedIds.add(String(m.parentId));
          }
        }
      });

      filtered = filtered.filter((m) => matchedIds.has(String(m._id)));
    }

    renderMenus(filtered);
    initMenuToggle();
  }

  function renderMenuRow(menu, allMenus, isParent, hasChildren) {
    const rowClass = isParent ? "row-parent" : "row-child";
    const childrenDisplay =
      isParent && !hasChildren
        ? ""
        : !isParent
        ? `data-parent-id="${menu.parentId}" class="child-row d-none"`
        : "";

    return `
    <tr class="${rowClass}" data-menu-id="${menu._id}" ${childrenDisplay}>
      <td>
        <div class="menu-details">
          ${
            isParent && hasChildren
              ? `<button class="toggle-menu-children" data-menu-id="${menu._id}" title="Expand/Collapse">
                   <svg class="toggle-icon" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                     <path d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
                   </svg>
                 </button>`
              : isParent
              ? '<span style="width: 24px; display: inline-block;"></span>'
              : "  "
          }
          ${!isParent ? '<span class="indent-marker">↳</span>' : ""}
          ${
            menu.image
              ? `<img src="${menu.image}" style="width: 45px; height: 34px; object-fit: cover; border-radius: 4px; margin-right: 12px;" />`
              : ""
          }
          <div class="menu-text">
            <div class="menu-title">${menu.title?.en || "-"}</div>
            ${
              menu.subTitle?.en
                ? `<div class="menu-subtitle">${menu.subTitle.en}</div>`
                : ""
            }
            <div class="menu-meta">${menu.route || "/"}</div>
            ${
              menu.tagName
                ? `<span class="menu-tag-badge">${menu.tagName}</span>`
                : ""
            }
          </div>
        </div>
      </td>
      <td class="text-center">
        <span class="order-badge-table">${menu.order || 0}</span>
      </td>
      <td>
        <span class="parent-label ${isParent ? "parent-root" : "parent-child"}">
          ${isParent ? "ROOT" : menu.parentName || "—"}
        </span>
      </td>
      <td class="text-center">
        ${
          menu.parentId
            ? `<div class="status-toggle-group">
          <span class="status-dot ${
            menu.showHomePage ? "dot-active" : "dot-hidden"
          }" style="background: ${
                menu.showHomePage ? "#2ecc71" : "#bdc3c7"
              };"></span>
          <div class="form-check form-switch m-0">
            <input class="form-check-input" type="checkbox" ${
              menu.showHomePage ? "checked" : ""
            } 
              onchange="toggleShowHomePage('${menu._id}', this)" />
          </div>
        </div>`
            : ""
        }
      </td>
      <td class="text-center">
        ${
          String(menu.parentId || "") === INSIGHTS_PARENT_ID
            ? `<button
          type="button"
          class="featured-star-btn ${menu.featuredInsights ? "active" : ""}"
          aria-label="Toggle Featured Insights"
          title="Toggle Featured Insights"
          onclick="toggleFeaturedInsights('${menu._id}', this)">
          ${menu.featuredInsights ? "★" : "☆"}
        </button>`
            : '<span class="text-muted">&mdash;</span>'
        }
      </td>
      <td class="text-center">
        <div class="status-toggle-group">
          <span class="status-dot ${
            menu.isStatus ? "dot-active" : "dot-hidden"
          }"></span>
          <div class="form-check form-switch m-0">
            <input class="form-check-input" type="checkbox" ${
              menu.isStatus ? "checked" : ""
            } 
              onchange="toggleMenuStatus('${menu._id}', this)" />
          </div>
        </div>
      </td>
      <td class="text-end ps-2">
        <a href="/dashboard/menus/${
          menu._id
        }/edit" class="action-circle" title="Edit">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7M18.5 2.5a2.121 2.121 0 113 3L12 15l-4 1 1-4 9.5-9.5z"></path>
          </svg>
        </a>
        <button onclick="deleteMenu('${
          menu._id
        }')" class="action-circle btn-del" title="Delete">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
          </svg>
        </button>
      </td>
    </tr>`;
  }

  fetch("/api/menus")
    .then((res) => res.json())
    .then((data) => {
      allMenusData = data.data || [];
      setupParentFilterOptions(allMenusData);
      applyFilters();
    })
    .catch(() => {
      allMenusData = [];
      setupParentFilterOptions(allMenusData);
      applyFilters();
    });

  const menuSearchInput = document.getElementById("menuSearchInput");
  if (menuSearchInput) {
    menuSearchInput.addEventListener("input", applyFilters);
  }

  const parentFilterSelect = document.getElementById("parentFilterSelect");
  if (parentFilterSelect) {
    parentFilterSelect.addEventListener("change", applyFilters);
  }

  function toggleMenuStatus(id, el) {
    fetch(`/api/menus/${id}/toggle`, { method: "PATCH" })
      .then((res) => res.json())
      .then((data) => {
        if (!data.success) {
          throw new Error(data.message || "Toggle failed");
        }
        const dot = el.closest("tr").querySelector(".status-dot");
        if (dot) {
          dot.className = data.isStatus
            ? "status-dot dot-active"
            : "status-dot dot-hidden";
        }
        notify("Menu status updated");
      })
      .catch((err) => {
        console.error("Toggle status failed:", err);
        notify("Toggle status failed: " + err.message, true);
      });
  }

  function toggleShowHomePage(id, el) {
    const currentState = el.checked;
    el.disabled = true; // Disable while processing

    console.log(`Toggle homepage for menu ${id}, current state:`, currentState);

    fetch(`/api/menus/${id}/toggle-homepage`, {
      method: "PATCH",
    })
      .then((res) => {
        console.log(`Response status: ${res.status}`);
        if (!res.ok) {
          throw new Error(`HTTP ${res.status}`);
        }
        return res.json();
      })
      .then((data) => {
        console.log("Response data:", data);
        el.disabled = false;
        if (data.success) {
          // Update checkbox to reflect new state
          el.checked = data.showHomePage;
          const row = el.closest("tr");
          const dots = row.querySelectorAll(".status-dot");
          if (dots.length > 0) {
            const homepageDot = dots[0];
            homepageDot.className = data.showHomePage
              ? "status-dot dot-active"
              : "status-dot dot-hidden";
            homepageDot.style.background = data.showHomePage
              ? "#2ecc71"
              : "#bdc3c7";
          }
          notify("Homepage visibility updated");
        } else {
          notify("Toggle failed: " + (data.message || "Unknown error"), true);
          el.checked = currentState; // rollback
        }
      })
      .catch((err) => {
        console.error("Toggle homepage failed:", err);
        el.disabled = false;
        notify("Toggle failed: " + err.message, true);
        el.checked = currentState; // rollback
      });
  }

  function toggleFeaturedInsights(id, el) {
    const wasActive = el.classList.contains("active");
    el.disabled = true;

    fetch(`/api/menus/${id}/toggle-featured-insights`, {
      method: "PATCH",
    })
      .then((res) => {
        if (!res.ok) {
          throw new Error(`HTTP ${res.status}`);
        }
        return res.json();
      })
      .then((data) => {
        el.disabled = false;
        if (!data.success) {
          throw new Error(data.message || "Toggle failed");
        }
        el.classList.toggle("active", !!data.featuredInsights);
        el.textContent = data.featuredInsights ? "★" : "☆";
        notify("Featured Insights updated");
      })
      .catch((err) => {
        console.error("Toggle featured insights failed:", err);
        el.disabled = false;
        el.classList.toggle("active", wasActive);
        el.textContent = wasActive ? "★" : "☆";
        notify("Toggle Featured Insights failed: " + err.message, true);
      });
  }

  function deleteMenu(id) {
    if (!confirm("Confirm delete this menu?")) return;
    fetch(`/api/menus/${id}`, { method: "DELETE" })
      .then((res) => res.json())
      .then((data) => {
        if (data.success) {
          notify("Menu deleted");
          setTimeout(() => location.reload(), 300);
        } else {
          notify("Delete failed: " + (data.message || "Unknown error"), true);
        }
      })
      .catch((err) => {
        notify("Delete failed: " + err.message, true);
      });
  }

  function toggleChildren(parentId, btn) {
    const children = document.querySelectorAll(
      `tr[data-parent-id="${parentId}"]`
    );
    const icon = btn.querySelector(".toggle-icon");
    const isExpanded = btn.classList.contains("expanded");

    children.forEach((child) => {
      if (isExpanded) {
        child.classList.add("d-none");
      } else {
        child.classList.remove("d-none");
      }
    });

    if (isExpanded) {
      btn.classList.remove("expanded");
      icon.style.transform = "rotate(0deg)";
      localStorage.setItem(`menu-children-${parentId}`, "closed");
    } else {
      btn.classList.add("expanded");
      icon.style.transform = "rotate(180deg)";
      localStorage.setItem(`menu-children-${parentId}`, "open");
    }
  }

  function initMenuToggle() {
    // Collapse all by default on initial load
    const collapseAllBtn = document.getElementById("collapse-all-btn");
    const expandAllBtn = document.getElementById("expand-all-btn");

    const allToggleBtns = document.querySelectorAll(".toggle-menu-children");

    // Make sure all children are collapsed initially
    allToggleBtns.forEach((btn) => {
      const menuId = btn.getAttribute("data-menu-id");
      const children = document.querySelectorAll(
        `tr[data-parent-id="${menuId}"]`
      );

      // Ensure collapsed state
      btn.classList.remove("expanded");
      const icon = btn.querySelector(".toggle-icon");
      if (icon) icon.style.transform = "rotate(0deg)";
      children.forEach((child) => child.classList.add("d-none"));
      localStorage.removeItem(`menu-children-${menuId}`);
    });

    // Attach click event listeners
    allToggleBtns.forEach((btn) => {
      btn.addEventListener("click", function (e) {
        e.preventDefault();
        const menuId = this.getAttribute("data-menu-id");
        toggleChildren(menuId, this);
      });
    });
  }
</script>
