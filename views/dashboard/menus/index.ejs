<link rel="stylesheet" href="/css/menus/index.css" />

<div class="d-flex justify-content-between align-items-end mb-4">
  <div>
    <h4 class="fw-800 mb-1" style="color: var(--ui-navy); letter-spacing: -1px">
      MENU SYSTEM
    </h4>
    <div class="d-flex align-items-center gap-2">
      <p class="small text-muted mb-0">Manage site menu structure</p>
    </div>
  </div>

  <a href="/dashboard/menus/create" class="btn-ui-main">
    <span class="plus-symbol">+</span>
    ADD MENU
  </a>
</div>

<div id="menu-list" class="table-container-minimal"></div>

<script>
  function renderMenus(menus) {
    const listContainer = document.getElementById("menu-list");
    if (!menus || !menus.length) {
      listContainer.innerHTML = `<div class="p-5 text-center text-muted">No data available</div>`;
      return;
    } // Sắp xếp dữ liệu theo cấu trúc Cha -> Con

    const structuredData = [];
    const parents = menus.filter((m) => !m.parentId);
    parents.forEach((parent) => {
      structuredData.push(parent);
      const children = menus.filter(
        (c) => c.parentId && c.parentId.toString() === parent._id.toString()
      );
      children.forEach((child) => structuredData.push(child));
    });

    let html = `
  <table class="table-clean">
   <thead>
    <tr>
    <th width="40%">Details</th>
    <th width="20%">Parent</th>
    <th width="20%" class="text-center">Status</th>
    <th width="20%" class="text-end">Actions</th>
    </tr>
   </thead>
   <tbody>`;

    structuredData.forEach((menu) => {
      const isParent = !menu.parentId;
      const rowClass = isParent ? "row-parent" : "row-child";
      const hasChildren =
        isParent &&
        menus.some(
          (m) => m.parentId && m.parentId.toString() === menu._id.toString()
        );

      html += `
    <tr class="${rowClass}" data-menu-id="${menu._id}" ${
        !isParent
          ? `data-parent-id="${menu.parentId}" style="display: none;"`
          : ""
      }>
     <td>
      <div class="indent-wrapper">
       ${
         isParent && hasChildren
           ? `
         <button class="toggle-children" onclick="toggleChildren('${menu._id}', this)" title="Expand/Collapse">
           <svg class="toggle-icon" width="12" height="12" fill="currentColor" viewBox="0 0 16 16">
             <path d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
           </svg>
         </button>
       `
           : isParent
           ? '<span style="width: 24px; display: inline-block;"></span>'
           : ""
       }
       ${!isParent ? '<div class="indent-guide"></div>' : ""}
       <div>
        <div class="menu-info-primary">
         ${menu.title?.en || "-"}
         <div class="small text-muted">${menu.subTitle?.en || ""}</div>
         <span class="type-tag ml-2">${menu.type || "Link"}</span>
        </div>
        <div class="menu-info-secondary">${menu.route || "/"}</div>
       </div>
      </div>
     </td>
     <td>
      <span class="small fw-600 ${
        isParent ? "text-bronze" : "text-muted"
      }" style="font-size: 0.75rem;">
       ${isParent ? "ROOT" : menu.parentName || "—"}
      </span>
     </td>
     <td class="text-center">
      <div class="d-flex align-items-center justify-content-center gap-3">
        <span class="status-dot ${
          menu.isStatus ? "dot-active" : "dot-hidden"
        }"></span>
        <div class="form-check form-switch m-0">
          <input class="form-check-input" type="checkbox" ${
            menu.isStatus ? "checked" : ""
          } 
            onchange="toggleMenuStatus('${menu._id}', this)" />
        </div>
      </div>
     </td>
     <td class="text-end">
      <a href="/dashboard/menus/${
        menu._id
      }/edit" class="action-circle" title="Edit">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7M18.5 2.5a2.121 2.121 0 113 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
      </a>
      <button onclick="deleteMenu('${
        menu._id
      }')" class="action-circle btn-del" title="Delete">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
      </button>
     </td>
    </tr>`;
    });

    html += "</tbody></table>";
    listContainer.innerHTML = html;
  } // Khởi chạy

  fetch("/api/menus")
    .then((res) => res.json())
    .then((data) => renderMenus(data.data))
    .catch(() => renderMenus([]));

  function toggleMenuStatus(id, el) {
    fetch(`/api/menus/${id}/toggle`, { method: "PATCH" })
      .then((res) => res.json())
      .then((data) => {
        const dot = el.closest("td").querySelector(".status-dot");
        dot.className = data.isStatus
          ? "status-dot dot-active"
          : "status-dot dot-hidden";
      });
  }

  function deleteMenu(id) {
    if (!confirm("Confirm delete this menu?")) return;
    fetch(`/api/menus/${id}`, { method: "DELETE" })
      .then((res) => res.json())
      .then((data) => {
        if (data.success) location.reload();
      });
  }

  function toggleChildren(parentId, btn) {
    const children = document.querySelectorAll(
      `tr[data-parent-id="${parentId}"]`
    );
    const icon = btn.querySelector(".toggle-icon");
    const isExpanded = btn.classList.contains("expanded");

    children.forEach((child) => {
      if (isExpanded) {
        child.style.display = "none";
      } else {
        child.style.display = "";
      }
    });

    if (isExpanded) {
      btn.classList.remove("expanded");
      icon.style.transform = "rotate(0deg)";
    } else {
      btn.classList.add("expanded");
      icon.style.transform = "rotate(180deg)";
    }
  }
</script>
