<link rel="stylesheet" href="/css/menus/edit.css" />

<div class="header-minimal mb-5">
  <div class="d-flex justify-content-between align-items-center border-bottom pb-3">
    <div>
      <h4 class="fw-800 text-navy mb-0">EDIT MENU</h4>
      <p class="text-muted small mb-0">ID: <span class="text-bronze"><%= menu._id %></span></p>
    </div>
    <a href="/dashboard/menus" class="btn-back">BACK</a>
  </div>
</div>

<form id="menu-edit-form" class="row">
  <input type="hidden" name="oldImage" value="<%= menu.image || '' %>" />
  <div class="col-md-7">
    <ul class="nav nav-tabs-minimal mb-4" role="tablist">
      <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#lang-en" type="button">ENGLISH</button>
      </li>
      <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#lang-vi" type="button">VIETNAMESE</button>
      </li>
      <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#lang-zh" type="button">中文 (ZH)</button>
      </li>
    </ul>

    <div class="tab-content">
      <div class="tab-pane fade show active" id="lang-en">
        <div class="form-group-minimal mb-4">
          <label>TITLE (EN)</label>
          <input type="text" name="title_en" value="<%= menu.title?.en || '' %>" required />
        </div>
        <div class="form-group-minimal mb-4">
          <label>SUBTITLE (EN)</label>
          <input type="text" name="subtitle_en" value="<%= menu.subTitle?.en || '' %>" />
        </div>
      </div>
      <div class="tab-pane fade" id="lang-vi">
        <div class="form-group-minimal mb-4">
          <label>TITLE (VI)</label>
          <input type="text" name="title_vi" value="<%= menu.title?.vi || '' %>" />
        </div>
        <div class="form-group-minimal mb-4">
          <label>SUBTITLE (VI)</label>
          <input type="text" name="subtitle_vi" value="<%= menu.subTitle?.vi || '' %>" />
        </div>
      </div>
      <div class="tab-pane fade" id="lang-zh">
        <div class="form-group-minimal mb-4">
          <label>标题 (ZH)</label>
          <input type="text" name="title_zh" value="<%= menu.title?.zh || '' %>" />
        </div>
        <div class="form-group-minimal mb-4">
          <label>SUBTITLE (ZH)</label>
          <input type="text" name="subtitle_zh" value="<%= menu.subTitle?.zh || '' %>" />
        </div>
      </div>
    </div>

    <div class="form-group-minimal mb-4">
      <label>Route</label>
      <input type="text" name="route" value="<%= menu.route || '' %>" placeholder="/path-name" />
    </div>

    <div class="form-group-minimal mb-4">
      <label>Tags</label>
      <select name="tagId" id="tagIdSelect" class="tag-select">
        <option value="">-- No tag --</option>
      </select>
      <small class="text-muted d-block mt-1">Choose one tag for this menu.</small>
    </div>

    <div class="row">
      <div class="col-6">
        <div class="form-group-minimal mb-4">
          <label>Position</label>
          <select name="type" id="typeSelect">
            <option value="top" <%= menu.type === 'top' ? 'selected' : '' %>>Header Menu</option>
            <option value="bot" <%= menu.type === 'bot' ? 'selected' : '' %>>Footer Menu</option>
          </select>
        </div>
      </div>
      <div class="col-6">
        <div class="form-group-minimal mb-4">
          <label>Order</label>
          <input type="number" name="order" value="<%= menu.order || 0 %>" />
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-5 ps-md-5">
    <div class="form-group-minimal mb-4">
      <label>Feature Image</label>
      <div class="custom-file-upload">
        <input
          type="file"
          name="image"
          id="imageInput"
          accept="image/*"
        />
        <span class="upload-label">Choose image or drag & drop here</span>
      </div>
      <% if (menu.image) { %>
      <div id="imagePreviewList" class="mt-2 d-flex gap-2">
        <img
          src="<%= menu.image %>"
          alt="Current image"
          class="img-thumbnail"
          style="max-width: 100px; max-height: 100px;"
        />
      </div>
      <% } else { %>
      <div id="imagePreviewList" class="mt-2 d-flex gap-2"></div>
      <% } %>
    </div>

    <div class="form-group-minimal mb-4">
      <label>Parent Menu</label>
      <select name="parentId" id="parentId">
        <option value="">-- Root Menu --</option>
        <optgroup label="Top" id="topMenuGroup"></optgroup>
        <optgroup label="Footer" id="botMenuGroup"></optgroup>
      </select>
    </div>

    <% if (menu.parentId) { %>
    <div class="switch-card mb-3">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <span class="fw-700 small text-navy d-block">SHOW ON HOMEPAGE</span>
          <small class="text-muted" style="font-size: 0.6rem;">Display on homepage menu</small>
        </div>
        <div class="form-check form-switch">
          <input class="form-check-input" type="checkbox" name="showHomePage" id="showHomePage" <%= menu.showHomePage ? 'checked' : '' %>>
        </div>
      </div>
    </div>
    <% } %>

    <div class="switch-card mb-3" id="featuredInsightsCard" style="display: none">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <span class="fw-700 small text-navy d-block">FEATURED INSIGHTS</span>
          <small class="text-muted" style="font-size: 0.6rem;">Mark this menu as featured for insights section</small>
        </div>
        <div>
          <input type="checkbox" name="featuredInsights" id="featuredInsights" style="display: none" <%= menu.featuredInsights ? 'checked' : '' %>>
          <button
            type="button"
            class="featured-star-btn <%= menu.featuredInsights ? 'active' : '' %>"
            id="featuredInsightsStar"
            aria-label="Toggle Featured Insights"
            aria-pressed="<%= menu.featuredInsights ? 'true' : 'false' %>"
          >
            <%= menu.featuredInsights ? '★' : '☆' %>
          </button>
        </div>
      </div>
    </div>

    <div class="switch-card mb-3" id="caseStudiesCard" style="display: none">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <span class="fw-700 small text-navy d-block">CASE STUDIES</span>
          <small class="text-muted" style="font-size: 0.6rem;">Mark this menu for case studies section</small>
        </div>
        <div>
          <input type="checkbox" name="caseStudies" id="caseStudies" style="display: none" <%= menu.caseStudies ? 'checked' : '' %>>
          <button
            type="button"
            class="featured-star-btn <%= menu.caseStudies ? 'active' : '' %>"
            id="caseStudiesStar"
            aria-label="Toggle Case Studies"
            aria-pressed="<%= menu.caseStudies ? 'true' : 'false' %>"
          >
            <%= menu.caseStudies ? '★' : '☆' %>
          </button>
        </div>
      </div>
    </div>

    <div class="switch-card mb-5">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <span class="fw-700 small text-navy d-block">DISPLAY BUTTON</span>
          <small class="text-muted" style="font-size: 0.6rem;">Display as button</small>
        </div>
        <div class="form-check form-switch">
          <input class="form-check-input" type="checkbox" name="isButton" id="isButton" <%= menu.isButton ? 'checked' : '' %>>
        </div>
      </div>
    </div>

    <button type="submit" class="btn-save-minimal">SAVE CHANGES</button>
  </div>
</form>

<script>
  const INSIGHTS_PARENT_ID = "698191a46ea27a5d8ccbf724";

  function notify(message, isError = false) {
    if (typeof window.showToast === "function") {
      window.showToast(message, isError);
      return;
    }
    window.alert(message);
  }

  // 1. XỬ LÝ CHUYỂN TAB (Vanilla JS - Không cần Bootstrap JS)
  const tabButtons = document.querySelectorAll('.nav-tabs-minimal .nav-link');
  const tabPanes = document.querySelectorAll('.tab-content .tab-pane');

  tabButtons.forEach(button => {
    button.addEventListener('click', function() {
      const targetId = this.getAttribute('data-bs-target');

      // Gỡ bỏ class active ở các nút khác
      tabButtons.forEach(btn => btn.classList.remove('active'));
      // Ẩn tất cả các tab content
      tabPanes.forEach(pane => {
        pane.classList.remove('show', 'active');
      });

      // Kích hoạt nút hiện tại và tab tương ứng
      this.classList.add('active');
      const activePane = document.querySelector(targetId);
      if (activePane) {
        activePane.classList.add('show', 'active');
      }
    });
  });

  // 2. FETCH & RENDER PARENT OPTIONS  
  const parentSelect = document.getElementById('parentId');
  const typeSelect = document.getElementById('typeSelect');
  const currentMenuId = '<%= menu._id %>';
  const currentParentId = '<%= menu.parentId ? menu.parentId.toString() : "" %>';
  const currentTagId = '<%= menu.tagId ? menu.tagId.toString() : "" %>';
  const featuredInsightsCard = document.getElementById('featuredInsightsCard');
  const featuredInsightsCheckbox = document.getElementById('featuredInsights');
  const featuredInsightsStar = document.getElementById('featuredInsightsStar');
  const caseStudiesCard = document.getElementById('caseStudiesCard');
  const caseStudiesCheckbox = document.getElementById('caseStudies');
  const caseStudiesStar = document.getElementById('caseStudiesStar');

  function syncTypeWithParent() {
    const selected = parentSelect.options[parentSelect.selectedIndex];
    if (!selected) return;

    const parentType = selected.getAttribute('data-type');
    if (parentSelect.value && parentType) {
      typeSelect.value = parentType;
      typeSelect.style.pointerEvents = 'none';
      typeSelect.style.opacity = '0.5';
    } else {
      typeSelect.style.pointerEvents = 'auto';
      typeSelect.style.opacity = '1';
    }

    const isInsightsMenu = parentSelect.value === INSIGHTS_PARENT_ID;
    featuredInsightsCard.style.display = isInsightsMenu ? 'block' : 'none';
    if (!isInsightsMenu) {
      featuredInsightsCheckbox.checked = false;
    }
    featuredInsightsStar.classList.toggle('active', featuredInsightsCheckbox.checked);
    featuredInsightsStar.textContent = featuredInsightsCheckbox.checked ? '★' : '☆';
    featuredInsightsStar.setAttribute(
      'aria-pressed',
      featuredInsightsCheckbox.checked ? 'true' : 'false'
    );

    caseStudiesCard.style.display = isInsightsMenu ? 'block' : 'none';
    if (!isInsightsMenu) {
      caseStudiesCheckbox.checked = false;
    }
    caseStudiesStar.classList.toggle('active', caseStudiesCheckbox.checked);
    caseStudiesStar.textContent = caseStudiesCheckbox.checked ? '★' : '☆';
    caseStudiesStar.setAttribute(
      'aria-pressed',
      caseStudiesCheckbox.checked ? 'true' : 'false'
    );
  }

  featuredInsightsStar.addEventListener('click', function () {
    if (parentSelect.value !== INSIGHTS_PARENT_ID) return;
    featuredInsightsCheckbox.checked = !featuredInsightsCheckbox.checked;
    featuredInsightsStar.classList.toggle('active', featuredInsightsCheckbox.checked);
    featuredInsightsStar.textContent = featuredInsightsCheckbox.checked ? '★' : '☆';
    featuredInsightsStar.setAttribute(
      'aria-pressed',
      featuredInsightsCheckbox.checked ? 'true' : 'false'
    );
  });

  caseStudiesStar.addEventListener('click', function () {
    if (parentSelect.value !== INSIGHTS_PARENT_ID) return;
    caseStudiesCheckbox.checked = !caseStudiesCheckbox.checked;
    caseStudiesStar.classList.toggle('active', caseStudiesCheckbox.checked);
    caseStudiesStar.textContent = caseStudiesCheckbox.checked ? '★' : '☆';
    caseStudiesStar.setAttribute(
      'aria-pressed',
      caseStudiesCheckbox.checked ? 'true' : 'false'
    );
  });

  fetch('/api/menus')
    .then((res) => res.json())
    .then((data) => {
      const topGroup = document.getElementById('topMenuGroup');
      const botGroup = document.getElementById('botMenuGroup');

      topGroup.innerHTML = '';
      botGroup.innerHTML = '';

      const menus = data.data || data;
      menus.forEach((m) => {
        if (!m || !m._id) return;
        if (String(m._id) === String(currentMenuId)) return;
        if (m.parentId) return;

        const opt = document.createElement('option');
        opt.value = m._id;
        opt.textContent = `↳ ${m.title?.en || m.title || 'No Title'}`;
        opt.dataset.type = m.type || 'top';

        if (String(m._id) === String(currentParentId)) {
          opt.selected = true;
        }

        if (m.type === 'top') topGroup.appendChild(opt);
        else botGroup.appendChild(opt);
      });

      syncTypeWithParent();
    })
    .catch((err) => {
      console.error('Failed to load parent categories:', err);
      syncTypeWithParent();
    });

  parentSelect.addEventListener('change', syncTypeWithParent);

  fetch('/api/tags?limit=300')
    .then((res) => res.json())
    .then((resp) => {
      const tagSelect = document.getElementById('tagIdSelect');
      if (!tagSelect) return;

      const tags = Array.isArray(resp.data) ? resp.data : [];
      tagSelect.innerHTML = '<option value="">-- No tag --</option>';

      tags.forEach((tag) => {
        const opt = document.createElement('option');
        opt.value = tag._id || '';
        opt.textContent = tag.name || tag.slug || 'Unnamed tag';
        if (String(opt.value) === String(currentTagId)) {
          opt.selected = true;
        }
        tagSelect.appendChild(opt);
      });
    })
    .catch((err) => {
      console.error('Failed to load tags:', err);
    });

  // 3. TOGGLE SHOW HOMEPAGE
  const showHomePageCheckbox = document.getElementById('showHomePage');
  if (showHomePageCheckbox) {
    showHomePageCheckbox.addEventListener('change', function() {
      const menuId = '<%= menu._id %>';
      
      fetch(`/api/menus/${menuId}/toggle-homepage`, {
        method: 'PATCH',
      })
      .then(res => res.json())
      .then(resp => {
        if (resp.success) {
          console.log('Homepage display toggled');
        } else {
          notify('Toggle failed', true);
          this.checked = !this.checked; // rollback
        }
      })
      .catch(err => {
        console.error('Toggle error:', err);
        notify('Toggle failed', true);
        this.checked = !this.checked; // rollback
      });
    });
  }

  // 4. IMAGE PREVIEW
  document.getElementById('imageInput').addEventListener('change', function () {
    const preview = document.getElementById('imagePreviewList');
    preview.innerHTML = '';
    if (this.files && this.files[0]) {
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = `<img src="${e.target.result}" class="img-thumbnail" style="max-width: 100px; max-height: 100px;">`;
        preview.insertAdjacentHTML('beforeend', img);
      };
      reader.readAsDataURL(this.files[0]);
    }
  });

  // 5. SUBMIT FORM QUA API
  document.getElementById('menu-edit-form').addEventListener('submit', function(e) {
    e.preventDefault();
    
    // Thu thập dữ liệu form
    const formData = new FormData(this);
    formData.set('isButton', document.getElementById('isButton').checked);
    formData.set(
      'featuredInsights',
      parentSelect.value === INSIGHTS_PARENT_ID && featuredInsightsCheckbox.checked
    );
    formData.set(
      'caseStudies',
      parentSelect.value === INSIGHTS_PARENT_ID && caseStudiesCheckbox.checked
    );
    // Note: showHomePage is NOT included here - it's handled separately via toggle-homepage endpoint

    fetch('/api/menus/<%= menu._id %>', {
      method: 'PUT',
      body: formData
    })
    .then(res => res.json())
    .then(resp => {
      if (resp.success) {
          if (typeof window.redirectWithToast === 'function') {
            window.redirectWithToast('/dashboard/menus', 'Menu updated successfully');
          } else {
            notify('Menu updated successfully');
            setTimeout(() => {
              window.location.href = '/dashboard/menus';
            }, 350);
          }
        } else {
          notify('Update failed: ' + (resp.message || 'Server error'), true);
        }
    })
    .catch(err => {
      console.error('Error:', err);
        notify('Cannot connect to server', true);
    });
  });
</script>