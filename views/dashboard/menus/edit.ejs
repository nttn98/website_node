<link rel="stylesheet" href="/css/menus/edit.css" />

<div class="header-minimal mb-5">
  <div class="d-flex justify-content-between align-items-center border-bottom pb-3">
    <div>
      <h4 class="fw-800 text-navy mb-0">CHỈNH SỬA MENU</h4>
      <p class="text-muted small mb-0">ID: <span class="text-bronze"><%= menu._id %></span></p>
    </div>
    <a href="/dashboard/menus" class="btn-back">QUAY LẠI</a>
  </div>
</div>

<form id="menu-edit-form" class="row">
  <div class="col-md-7">
    <ul class="nav nav-tabs-minimal mb-4" role="tablist">
      <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#lang-en" type="button">ENGLISH</button>
      </li>
      <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#lang-vi" type="button">TIẾNG VIỆT</button>
      </li>
      <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#lang-zh" type="button">中文 (ZH)</button>
      </li>
    </ul>

    <div class="tab-content">
      <div class="tab-pane fade show active" id="lang-en">
        <div class="form-group-minimal mb-4">
          <label>TITLE (EN)</label>
          <input type="text" name="title_en" value="<%= menu.title?.en || '' %>" required />
        </div>
      </div>
      <div class="tab-pane fade" id="lang-vi">
        <div class="form-group-minimal mb-4">
          <label>TIÊU ĐỀ (VI)</label>
          <input type="text" name="title_vi" value="<%= menu.title?.vi || '' %>" />
        </div>
      </div>
      <div class="tab-pane fade" id="lang-zh">
        <div class="form-group-minimal mb-4">
          <label>标题 (ZH)</label>
          <input type="text" name="title_zh" value="<%= menu.title?.zh || '' %>" />
        </div>
      </div>
    </div>

    <div class="form-group-minimal mb-4">
      <label>ĐƯỜNG DẪN (ROUTE)</label>
      <input type="text" name="route" value="<%= menu.route || '' %>" placeholder="/path-name" />
    </div>

    <div class="row">
      <div class="col-6">
        <div class="form-group-minimal mb-4">
          <label>VỊ TRÍ</label>
          <select name="type" id="typeSelect">
            <option value="top" <%= menu.type === 'top' ? 'selected' : '' %>>Header Menu</option>
            <option value="bot" <%= menu.type === 'bot' ? 'selected' : '' %>>Footer Menu</option>
          </select>
        </div>
      </div>
      <div class="col-6">
        <div class="form-group-minimal mb-4">
          <label>THỨ TỰ</label>
          <input type="number" name="order" value="<%= menu.order || 0 %>" />
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-5 ps-md-5">
    <div class="form-group-minimal mb-4">
      <label>DANH MỤC CHA</label>
      <select name="parentId" id="parentId">
        <option value="">-- Menu gốc (Gốc) --</option>
        <% if (menus && menus.length) { %>
          <% menus.forEach(function(m) { 
             if (!menu._id || m._id.toString() !== menu._id.toString()) { %>
            <option value="<%= m._id %>" data-type="<%= m.type %>" 
              <%= (menu.parentId && menu.parentId.toString() === m._id.toString()) ? 'selected' : '' %>>
              ↳ <%= m.title?.en || m.title || '-' %>
            </option>
          <% }} ) %>
        <% } %>
      </select>
    </div>

    <div class="switch-card mb-5">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <span class="fw-700 small text-navy d-block">HIỂN THỊ NÚT</span>
          <small class="text-muted" style="font-size: 0.6rem;">Display as button</small>
        </div>
        <div class="form-check form-switch">
          <input class="form-check-input" type="checkbox" name="isButton" id="isButton" <%= menu.isButton ? 'checked' : '' %>>
        </div>
      </div>
    </div>

    <button type="submit" class="btn-save-minimal">CẬP NHẬT THAY ĐỔI</button>
    <p class="text-center mt-3">
        <a href="/dashboard/menus" class="text-muted small fw-700 text-decoration-none" style="font-size: 0.65rem;">HỦY BỎ</a>
    </p>
  </div>
</form>

<script>
  // 1. XỬ LÝ CHUYỂN TAB (Vanilla JS - Không cần Bootstrap JS)
  const tabButtons = document.querySelectorAll('.nav-tabs-minimal .nav-link');
  const tabPanes = document.querySelectorAll('.tab-content .tab-pane');

  tabButtons.forEach(button => {
    button.addEventListener('click', function() {
      const targetId = this.getAttribute('data-bs-target');

      // Gỡ bỏ class active ở các nút khác
      tabButtons.forEach(btn => btn.classList.remove('active'));
      // Ẩn tất cả các tab content
      tabPanes.forEach(pane => {
        pane.classList.remove('show', 'active');
      });

      // Kích hoạt nút hiện tại và tab tương ứng
      this.classList.add('active');
      const activePane = document.querySelector(targetId);
      if (activePane) {
        activePane.classList.add('show', 'active');
      }
    });
  });

  // 2. LOGIC ĐỒNG BỘ LOẠI MENU (TYPE) VỚI MENU CHA
  const parentSelect = document.getElementById('parentId');
  const typeSelect = document.getElementById('typeSelect');

  function syncTypeWithParent() {
    const selected = parentSelect.options[parentSelect.selectedIndex];
    if (!selected) return;
    
    const parentType = selected.getAttribute('data-type');
    if (parentSelect.value && parentType) {
      typeSelect.value = parentType;
      typeSelect.style.pointerEvents = 'none';
      typeSelect.style.opacity = '0.5';
    } else {
      typeSelect.style.pointerEvents = 'auto';
      typeSelect.style.opacity = '1';
    }
  }

  parentSelect.addEventListener('change', syncTypeWithParent);
  syncTypeWithParent(); // Chạy ngay khi load trang để kiểm tra dữ liệu cũ

  // 3. SUBMIT FORM QUA API
  document.getElementById('menu-edit-form').addEventListener('submit', function(e) {
    e.preventDefault();
    
    // Thu thập dữ liệu form
    const formData = new FormData(this);
    const data = Object.fromEntries(formData.entries());
    
    // Xử lý riêng cho Checkbox (vì FormData mặc định bỏ qua nếu không check)
    data.isButton = document.getElementById('isButton').checked;

    fetch('/api/menus/<%= menu._id %>', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    })
    .then(res => res.json())
    .then(resp => {
      if (resp.success) {
        window.location.href = '/dashboard/menus';
      } else {
        alert('Cập nhật thất bại: ' + (resp.message || 'Lỗi hệ thống'));
      }
    })
    .catch(err => {
      console.error('Error:', err);
      alert('Không thể kết nối với máy chủ');
    });
  });
</script>