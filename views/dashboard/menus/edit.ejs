<link rel="stylesheet" href="/css/menus/edit.css" />

<div class="header-minimal mb-5">
  <div class="d-flex justify-content-between align-items-center border-bottom pb-3">
    <div>
      <h4 class="fw-800 text-navy mb-0">EDIT MENU</h4>
      <p class="text-muted small mb-0">ID: <span class="text-bronze"><%= menu._id %></span></p>
    </div>
    <a href="/dashboard/menus" class="btn-back">BACK</a>
  </div>
</div>

<form id="menu-edit-form" class="row">
  <div class="col-md-7">
    <ul class="nav nav-tabs-minimal mb-4" role="tablist">
      <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#lang-en" type="button">ENGLISH</button>
      </li>
      <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#lang-vi" type="button">VIETNAMESE</button>
      </li>
      <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#lang-zh" type="button">中文 (ZH)</button>
      </li>
    </ul>

    <div class="tab-content">
      <div class="tab-pane fade show active" id="lang-en">
        <div class="form-group-minimal mb-4">
          <label>TITLE (EN)</label>
          <input type="text" name="title_en" value="<%= menu.title?.en || '' %>" required />
        </div>
        <div class="form-group-minimal mb-4">
          <label>SUBTITLE (EN)</label>
          <input type="text" name="subtitle_en" value="<%= menu.subTitle?.en || '' %>" />
        </div>
      </div>
      <div class="tab-pane fade" id="lang-vi">
        <div class="form-group-minimal mb-4">
          <label>TITLE (VI)</label>
          <input type="text" name="title_vi" value="<%= menu.title?.vi || '' %>" />
        </div>
        <div class="form-group-minimal mb-4">
          <label>SUBTITLE (VI)</label>
          <input type="text" name="subtitle_vi" value="<%= menu.subTitle?.vi || '' %>" />
        </div>
      </div>
      <div class="tab-pane fade" id="lang-zh">
        <div class="form-group-minimal mb-4">
          <label>标题 (ZH)</label>
          <input type="text" name="title_zh" value="<%= menu.title?.zh || '' %>" />
        </div>
        <div class="form-group-minimal mb-4">
          <label>SUBTITLE (ZH)</label>
          <input type="text" name="subtitle_zh" value="<%= menu.subTitle?.zh || '' %>" />
        </div>
      </div>
    </div>

    <div class="form-group-minimal mb-4">
      <label>Route</label>
      <input type="text" name="route" value="<%= menu.route || '' %>" placeholder="/path-name" />
    </div>

    <div class="row">
      <div class="col-6">
        <div class="form-group-minimal mb-4">
          <label>Position</label>
          <select name="type" id="typeSelect">
            <option value="top" <%= menu.type === 'top' ? 'selected' : '' %>>Header Menu</option>
            <option value="bot" <%= menu.type === 'bot' ? 'selected' : '' %>>Footer Menu</option>
          </select>
        </div>
      </div>
      <div class="col-6">
        <div class="form-group-minimal mb-4">
          <label>Order</label>
          <input type="number" name="order" value="<%= menu.order || 0 %>" />
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-5 ps-md-5">
    <div class="form-group-minimal mb-4">
      <label>Feature Image</label>
      <div class="custom-file-upload">
        <input
          type="file"
          name="image"
          id="imageInput"
          accept="image/*"
        />
        <span class="upload-label">Choose image or drag & drop here</span>
      </div>
      <% if (menu.image) { %>
      <div id="imagePreviewList" class="mt-2 d-flex gap-2">
        <img
          src="<%= menu.image %>"
          alt="Current image"
          class="img-thumbnail"
          style="max-width: 100px; max-height: 100px;"
        />
      </div>
      <% } else { %>
      <div id="imagePreviewList" class="mt-2 d-flex gap-2"></div>
      <% } %>
    </div>

    <div class="form-group-minimal mb-4">
      <label>Parent Menu</label>
      <select name="parentId" id="parentId">
        <option value="">-- Root Menu --</option>
        <optgroup label="Top" id="topMenuGroup"></optgroup>
        <optgroup label="Footer" id="botMenuGroup"></optgroup>
      </select>
    </div>

    <div class="switch-card mb-5">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <span class="fw-700 small text-navy d-block">DISPLAY BUTTON</span>
          <small class="text-muted" style="font-size: 0.6rem;">Display as button</small>
        </div>
        <div class="form-check form-switch">
          <input class="form-check-input" type="checkbox" name="isButton" id="isButton" <%= menu.isButton ? 'checked' : '' %>>
        </div>
      </div>
    </div>

    <button type="submit" class="btn-save-minimal">SAVE CHANGES</button>
  </div>
</form>

<script>
  // 1. XỬ LÝ CHUYỂN TAB (Vanilla JS - Không cần Bootstrap JS)
  const tabButtons = document.querySelectorAll('.nav-tabs-minimal .nav-link');
  const tabPanes = document.querySelectorAll('.tab-content .tab-pane');

  tabButtons.forEach(button => {
    button.addEventListener('click', function() {
      const targetId = this.getAttribute('data-bs-target');

      // Gỡ bỏ class active ở các nút khác
      tabButtons.forEach(btn => btn.classList.remove('active'));
      // Ẩn tất cả các tab content
      tabPanes.forEach(pane => {
        pane.classList.remove('show', 'active');
      });

      // Kích hoạt nút hiện tại và tab tương ứng
      this.classList.add('active');
      const activePane = document.querySelector(targetId);
      if (activePane) {
        activePane.classList.add('show', 'active');
      }
    });
  });

  // 2. FETCH & RENDER PARENT OPTIONS  
  const parentSelect = document.getElementById('parentId');
  const typeSelect = document.getElementById('typeSelect');
  const currentMenuId = '<%= menu._id %>';
  const currentParentId = '<%= menu.parentId ? menu.parentId.toString() : "" %>';

  function syncTypeWithParent() {
    const selected = parentSelect.options[parentSelect.selectedIndex];
    if (!selected) return;

    const parentType = selected.getAttribute('data-type');
    if (parentSelect.value && parentType) {
      typeSelect.value = parentType;
      typeSelect.style.pointerEvents = 'none';
      typeSelect.style.opacity = '0.5';
    } else {
      typeSelect.style.pointerEvents = 'auto';
      typeSelect.style.opacity = '1';
    }
  }

  fetch('/api/menus')
    .then((res) => res.json())
    .then((data) => {
      const topGroup = document.getElementById('topMenuGroup');
      const botGroup = document.getElementById('botMenuGroup');

      topGroup.innerHTML = '';
      botGroup.innerHTML = '';

      const menus = data.data || data;
      menus.forEach((m) => {
        if (!m || !m._id) return;
        if (String(m._id) === String(currentMenuId)) return;
        if (m.parentId) return;

        const opt = document.createElement('option');
        opt.value = m._id;
        opt.textContent = `↳ ${m.title?.en || m.title || 'No Title'}`;
        opt.dataset.type = m.type || 'top';

        if (String(m._id) === String(currentParentId)) {
          opt.selected = true;
        }

        if (m.type === 'top') topGroup.appendChild(opt);
        else botGroup.appendChild(opt);
      });

      syncTypeWithParent();
    })
    .catch((err) => {
      console.error('Failed to load parent categories:', err);
      syncTypeWithParent();
    });

  parentSelect.addEventListener('change', syncTypeWithParent);

  // 3. IMAGE PREVIEW
  document.getElementById('imageInput').addEventListener('change', function () {
    const preview = document.getElementById('imagePreviewList');
    preview.innerHTML = '';
    if (this.files && this.files[0]) {
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = `<img src="${e.target.result}" class="img-thumbnail" style="max-width: 100px; max-height: 100px;">`;
        preview.insertAdjacentHTML('beforeend', img);
      };
      reader.readAsDataURL(this.files[0]);
    }
  });

  // 4. SUBMIT FORM QUA API
  document.getElementById('menu-edit-form').addEventListener('submit', function(e) {
    e.preventDefault();
    
    // Thu thập dữ liệu form
    const formData = new FormData(this);
    formData.set('isButton', document.getElementById('isButton').checked);

    fetch('/api/menus/<%= menu._id %>', {
      method: 'PUT',
      body: formData
    })
    .then(res => res.json())
    .then(resp => {
      if (resp.success) {
          window.location.href = '/dashboard/menus';
        } else {
          alert('Update failed: ' + (resp.message || 'Server error'));
        }
    })
    .catch(err => {
      console.error('Error:', err);
        alert('Cannot connect to server');
    });
  });
</script>