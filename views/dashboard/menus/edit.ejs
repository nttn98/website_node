<h4 class="mb-4">Edit Menu</h4>

<form method="POST" action="/api/menus/<%= menu._id %>?_method=PUT">

  <!-- ===== LANGUAGE TABS ===== -->
  <ul class="nav nav-tabs mb-3" role="tablist">
    <li class="nav-item">
      <button
        class="nav-link active"
        data-bs-toggle="tab"
        data-bs-target="#lang-en"
        type="button"
      >
        EN
      </button>
    </li>
    <li class="nav-item">
      <button
        class="nav-link"
        data-bs-toggle="tab"
        data-bs-target="#lang-vi"
        type="button"
      >
        VI
      </button>
    </li>
    <li class="nav-item">
      <button
        class="nav-link"
        data-bs-toggle="tab"
        data-bs-target="#lang-zh"
        type="button"
      >
        ZH
      </button>
    </li>
  </ul>

  <!-- ===== TAB CONTENT ===== -->
  <div class="tab-content mb-4">
    <!-- EN -->
    <div class="tab-pane fade show active" id="lang-en">
      <div class="mb-3">
        <label class="form-label">Title (EN)</label>
        <input
          type="text"
          name="title_en"
          class="form-control"
          value="<%= menu.title?.en || '' %>"
          required
        />
      </div>
    </div>

    <!-- VI -->
    <div class="tab-pane fade" id="lang-vi">
      <div class="mb-3">
        <label class="form-label">Title (VI)</label>
        <input
          type="text"
          name="title_vi"
          class="form-control"
          value="<%= menu.title?.vi || '' %>"
        />
      </div>
    </div>

    <!-- ZH -->
    <div class="tab-pane fade" id="lang-zh">
      <div class="mb-3">
        <label class="form-label">Title (ZH)</label>
        <input
          type="text"
          name="title_zh"
          class="form-control"
          value="<%= menu.title?.zh || '' %>"
        />
      </div>
    </div>
  </div>

  <!-- ===== COMMON FIELDS ===== -->


  <!-- ROUTE -->
  <div class="mb-3">
    <label class="form-label">Route</label>
    <input
      type="text"
      name="route"
      class="form-control"
      value="<%= menu.route || '' %>"
    />
  </div>

  <!-- PARENT MENU -->
  <div class="mb-3">
    <label class="form-label">Parent Menu (optional)</label>
    <select name="parentId" id="parentId" class="form-select">
      <option value="">-- None --</option>
      <% if (menus && menus.length) { %>
        <% menus.forEach(function(m) { if (!menu._id || m._id.toString() !== menu._id.toString()) { %>
          <option value="<%= m._id %>" data-type="<%= m.type %>" <%= (menu.parentId && menu.parentId.toString() === m._id.toString()) ? 'selected' : '' %>><%= m.title?.en || m.title || '-' %></option>
        <% }} ) %>
      <% } %>
    </select>
  </div>

  <!-- TYPE -->
  <div class="mb-3">
    <label class="form-label">Type</label>
    <select name="type" id="typeSelect" class="form-select" required>
      <option value="top" <%= menu.type === 'top' ? 'selected' : '' %>>Top menu</option>
      <option value="bot" <%= menu.type === 'bot' ? 'selected' : '' %>>Footer menu</option>
    </select>
  </div>

  <!-- ORDER -->
  <div class="mb-3">
    <label class="form-label">Order</label>
    <input
      type="number"
      name="order"
      class="form-control"
      value="<%= menu.order || 0 %>"
    />
  </div>

  <!-- IS BUTTON -->
  <div class="form-check mb-4">
    <input
      type="checkbox"
      name="isButton"
      class="form-check-input"
      id="isButton"
      <%= menu.isButton ? 'checked' : '' %>
    />
    <label for="isButton" class="form-check-label">
      Display as button
    </label>
  </div>

  <!-- SUBMIT -->
  <button class="btn btn-warning">
    Update
  </button>

  <a href="/dashboard/menus" class="btn btn-secondary ms-2">
    Cancel
  </a>
</form>

<script>
  // Auto-set type if parent selected, else allow user to pick
  const parentSelect = document.getElementById('parentId');
  const typeSelect = document.getElementById('typeSelect');
  function syncTypeWithParent() {
    const selected = parentSelect.options[parentSelect.selectedIndex];
    const parentType = selected.getAttribute('data-type');
    if (parentSelect.value && parentType) {
      typeSelect.value = parentType;
      typeSelect.setAttribute('readonly', 'readonly');
      typeSelect.setAttribute('disabled', 'disabled');
    } else {
      typeSelect.removeAttribute('readonly');
      typeSelect.removeAttribute('disabled');
    }
  }
  parentSelect.addEventListener('change', syncTypeWithParent);
  // On page load, sync if parent is already selected
  syncTypeWithParent();
</script>
