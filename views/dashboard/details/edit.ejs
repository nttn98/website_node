<h4>Edit Detail</h4>
<form id="detail-edit-form">
  <!-- DETAIL (READONLY) -->
  <input type="hidden" name="parentId" value="<%= detail.parentId %>" />
  <div class="mb-3">
    <label class="form-label">Group</label>
    <input type="text" class="form-control" value="<%= detail.parentName %>" readonly />
  </div>
  <!-- MENU (READONLY) -->
  <input type="hidden" name="subParentId" value="<%= detail.subParentId %>" />
  <div class="mb-3">
    <label class="form-label">Menu</label>
    <input type="text" class="form-control" value="<%= detail.subParentName %>" readonly />
  </div>
  <!-- TYPE -->
  <div class="mb-3">
    <label class="form-label">Type</label>
    <select name="type" id="typeSelect" class="form-select" required>
      <option value="html" <%= detail.type === 'html' ? 'selected' : '' %>>HTML Block</option>
      <option value="editor" <%= detail.type === 'editor' ? 'selected' : '' %>>Text Editor</option>
    </select>
  </div>
  <!-- LANGUAGE TABS -->
  <ul class="nav nav-tabs mb-3" role="tablist">
    <li class="nav-item">
      <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-en" type="button">EN</button>
    </li>
    <li class="nav-item">
      <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-vi" type="button">VI</button>
    </li>
    <li class="nav-item">
      <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-zh" type="button">ZH</button>
    </li>
  </ul>
  <div class="tab-content">
    <!-- EN -->
    <div class="tab-pane fade show active" id="tab-en">
      <input class="form-control mb-2" name="title_en" value="<%= detail.title?.en || '' %>" placeholder="Title EN">
      <input class="form-control mb-3" name="subtitle_en" value="<%= detail.subtitle?.en || '' %>" placeholder="Subtitle EN">
    </div>
    <!-- VI -->
    <div class="tab-pane fade" id="tab-vi">
      <input class="form-control mb-2" name="title_vi" value="<%= detail.title?.vi || '' %>" placeholder="Title VI">
      <input class="form-control mb-3" name="subtitle_vi" value="<%= detail.subtitle?.vi || '' %>" placeholder="Subtitle VI">
    </div>
    <!-- ZH -->
    <div class="tab-pane fade" id="tab-zh">
      <input class="form-control mb-2" name="title_zh" value="<%= detail.title?.zh || '' %>" placeholder="Title ZH">
      <input class="form-control mb-3" name="subtitle_zh" value="<%= detail.subtitle?.zh || '' %>" placeholder="Subtitle ZH">
    </div>
  </div>
  <!-- HTML -->
  <div id="htmlBlock" class="<%= detail.type === 'html' ? '' : 'd-none' %>">
    <textarea name="content" class="form-control font-monospace" rows="8"><%= detail.content || '' %></textarea>
  </div>
  <!-- EDITOR -->
  <div id="editorBlock" class="<%= detail.type === 'editor' ? '' : 'd-none' %>">
    <textarea id="editor"><%= detail.content || '' %></textarea>
  </div>
  <div id="localImgWarning" class="mt-2"></div>
  <button class="btn btn-success mt-3" type="submit">Update</button>
</form>

<script>
  document.getElementById('detail-edit-form').addEventListener('submit', function(e) {
    e.preventDefault();
    const form = e.target;
    const formData = new FormData(form);
    fetch('/details/<%= detail._id %>/update', {
      method: 'POST',
      body: formData
    })
      .then(res => res.json())
      .then(resp => {
        if (resp.success) window.location.href = '/details';
        else alert('Update failed');
      })
      .catch(() => alert('Update failed'));
  });
</script>
<script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js"></script>
<script src="/js/content-img-checker.js"></script>
<script>
  const typeSelect = document.getElementById("typeSelect");
  const htmlBlock = document.getElementById("htmlBlock");
  const editorBlock = document.getElementById("editorBlock");
  let editor;
  function toggleType(type) {
    htmlBlock.classList.toggle("d-none", type === "editor");
    editorBlock.classList.toggle("d-none", type === "html");
    if (type === "editor" && !editor) {
      ClassicEditor.create(document.getElementById("editor"), {
        simpleUpload: { uploadUrl: '/api/upload/content-image' }
      }).then(e => {
        editor = e;
        editor.model.document.on("change:data", () => {
          document.querySelector('[name="content"]').value = editor.getData();
          ContentImgChecker.recheck();
        });
      });
    }
  }
  toggleType(typeSelect.value);
  typeSelect.addEventListener("change", e => toggleType(e.target.value));

  // CONTENT IMAGE CHECKER
  var _contentTextarea = document.querySelector('[name="content"]');
  var imgChecker = ContentImgChecker.init({
    textarea: _contentTextarea,
    getHtml: function () { return _contentTextarea.value; },
    setHtml: function (html) {
      _contentTextarea.value = html;
      if (editor) editor.setData(html);
    },
    warningContainerId: 'localImgWarning'
  });
  // Check existing content on load (edit page)
  imgChecker.recheck();
</script>
