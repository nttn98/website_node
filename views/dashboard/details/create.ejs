<h4>Create Detail</h4>
<form id="detail-create-form">
  <!-- DETAIL -->
  <div class="mb-3">
    <label class="form-label">Group</label>
    <select
      name="parentId"
      class="form-select"
      id="parentIdSelect"
      required
    ></select>
  </div>
  <!-- MENU -->
  <div class="mb-3">
    <label class="form-label">Menu</label>
    <select
      name="subParentId"
      class="form-select"
      id="subParentIdSelect"
      required
    ></select>
  </div>
  <!-- TYPE -->
  <div class="mb-3">
    <label class="form-label">Type</label>
    <select name="type" id="typeSelect" class="form-select" required>
      <option value="html">HTML Block</option>
      <option value="editor">Text Editor</option>
    </select>
  </div>
  <!-- LANGUAGE TABS -->
  <ul class="nav nav-tabs mb-3" role="tablist">
    <li class="nav-item">
      <button
        class="nav-link active"
        data-bs-toggle="tab"
        data-bs-target="#tab-en"
        type="button"
      >
        EN
      </button>
    </li>
    <li class="nav-item">
      <button
        class="nav-link"
        data-bs-toggle="tab"
        data-bs-target="#tab-vi"
        type="button"
      >
        VI
      </button>
    </li>
    <li class="nav-item">
      <button
        class="nav-link"
        data-bs-toggle="tab"
        data-bs-target="#tab-zh"
        type="button"
      >
        ZH
      </button>
    </li>
  </ul>
  <div class="tab-content">
    <!-- EN -->
    <div class="tab-pane fade show active" id="tab-en">
      <input class="form-control mb-2" name="title_en" placeholder="Title EN" />
      <input
        class="form-control mb-3"
        name="subtitle_en"
        placeholder="Subtitle EN"
      />
    </div>
    <!-- VI -->
    <div class="tab-pane fade" id="tab-vi">
      <input class="form-control mb-2" name="title_vi" placeholder="Title VI" />
      <input
        class="form-control mb-3"
        name="subtitle_vi"
        placeholder="Subtitle VI"
      />
    </div>
    <!-- ZH -->
    <div class="tab-pane fade" id="tab-zh">
      <input class="form-control mb-2" name="title_zh" placeholder="Title ZH" />
      <input
        class="form-control mb-3"
        name="subtitle_zh"
        placeholder="Subtitle ZH"
      />
    </div>
  </div>
  <!-- HTML -->
  <div id="htmlBlock">
    <textarea
      name="content"
      class="form-control font-monospace"
      rows="8"
    ></textarea>
  </div>
  <!-- EDITOR -->
  <div id="editorBlock" class="d-none">
    <textarea id="editor"></textarea>
  </div>
  <div id="localImgWarning" class="mt-2"></div>
  <button class="btn btn-primary mt-3">Create</button>
  <button class="btn btn-primary mt-3" type="submit">Create</button>
</form>

<script>
  // Lấy danh sách group cho select
  fetch("/groups")
    .then((res) => res.json())
    .then((data) => {
      const groups = data.groups || [];
      const select = document.getElementById("parentIdSelect");
      groups.forEach((g) => {
        const opt = document.createElement("option");
        opt.value = g._id;
        opt.textContent = g.title?.en || g.title || "-";
        select.appendChild(opt);
      });
    });
  // Lấy danh sách menu cho select
  fetch("/api/menus")
    .then((res) => res.json())
    .then((data) => {
      const menus = data.data || [];
      const select = document.getElementById("subParentIdSelect");
      menus.forEach((m) => {
        const opt = document.createElement("option");
        opt.value = m._id;
        opt.textContent = m.title?.en || m.title || "-";
        select.appendChild(opt);
      });
    });
  // Submit form bằng fetch
  document
    .getElementById("detail-create-form")
    .addEventListener("submit", function (e) {
      e.preventDefault();
      const form = e.target;
      const formData = new FormData(form);
      fetch("/details/create", {
        method: "POST",
        body: formData,
      })
        .then((res) => res.json())
        .then((resp) => {
          if (resp.success) window.location.href = "/details";
          else alert("Create failed");
        })
        .catch(() => alert("Create failed"));
    });
</script>
<script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js"></script>
<script src="/js/content-img-checker.js"></script>
<script>
  const typeSelect = document.getElementById("typeSelect");
  const htmlBlock = document.getElementById("htmlBlock");
  const editorBlock = document.getElementById("editorBlock");
  let editor;
  function toggleType(type) {
    htmlBlock.classList.toggle("d-none", type === "editor");
    editorBlock.classList.toggle("d-none", type === "html");
    if (type === "editor" && !editor) {
      ClassicEditor.create(document.getElementById("editor"), {
        simpleUpload: { uploadUrl: "/api/upload/content-image" },
      }).then((e) => {
        editor = e;
        editor.model.document.on("change:data", () => {
          document.querySelector('[name="content"]').value = editor.getData();
          ContentImgChecker.recheck();
        });
      });
    }
  }
  toggleType(typeSelect.value);
  typeSelect.addEventListener("change", (e) => toggleType(e.target.value));

  // CONTENT IMAGE CHECKER
  var _contentTextarea = document.querySelector('[name="content"]');
  ContentImgChecker.init({
    textarea: _contentTextarea,
    getHtml: function () {
      return _contentTextarea.value;
    },
    setHtml: function (html) {
      _contentTextarea.value = html;
      if (editor) editor.setData(html);
    },
    warningContainerId: "localImgWarning",
  });
</script>
